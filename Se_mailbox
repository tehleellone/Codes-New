/* ══════════════════════════════════════════════════════════════
   EXPORT CSV — based on current filtered data
   ══════════════════════════════════════════════════════════════ */
window.mbExportCSV = function() {
    if (MB.gridApi) { MB.gridApi.exportDataAsCsv({ fileName:`SEMailbox_${new Date().toISOString().slice(0,10)}.csv` }); return; }
    const headers=['Tab','From','Subject','Category','Pending Reason','Owner','SM','Team','Received','Completed Date','Age (Days)','Status'];
    const rows=MB.filteredTickets.map(t=>[
        t.tab,
        t.from,
        t.subject,
        t.category,
        t.pendingReason||'',
        t.owner||'',
        t.smFullName,
        t.smTeam,
        t.receivedFmt,
        t.flagDateFmt,
        t.ageDays??'',
        t.status
    ]);
    const csv=[headers,...rows].map(r=>r.map(v=>`"${String(v||'').replace(/"/g,'""')}"`).join(',')).join('\n');
    const a=document.createElement('a');
    a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
    a.download=`SEMailbox_${new Date().toISOString().slice(0,10)}.csv`;
    a.click();
};
window.mbSearch = function(val) { if(MB.gridApi) MB.gridApi.setGridOption('quickFilterText',val); };

/* ══════════════════════════════════════════════════════════════
   AG GRID — export button inside grid
   ══════════════════════════════════════════════════════════════ */
function mbRenderGrid() {
    const el = document.getElementById('mb-ag-grid');
    if (!el) return;
    const statusR = p => {
        if (!p.value) return '—';
        const cls={'Unassigned':'badge-danger','In Progress':'badge-warning','Closed':'badge-success','Completed':'badge-success'}[p.value]||'';
        return `<span class="status-badge ${cls}" style="font-size:10px;">${p.value}</span>`;
    };
    const cols=[
        {field:'status',     headerName:'Status',         width:150,pinned:'left',filter:'agSetColumnFilter',cellRenderer:statusR},
        {field:'smFullName', headerName:'Service Manager',width:165,filter:'agSetColumnFilter'},
        {field:'from',       headerName:'From',           width:200,filter:'agTextColumnFilter'},
        {field:'subject',    headerName:'Subject',        flex:1,   filter:'agTextColumnFilter',tooltipField:'subject',minWidth:220},
        {field:'category',   headerName:'Category',       width:200,filter:'agSetColumnFilter'},
        {field:'pendingReason',headerName:'Pending Reason',width:170,filter:'agSetColumnFilter'},
        {field:'owner',      headerName:'Owner',          width:140,filter:'agSetColumnFilter'},
        {field:'smTeam',     headerName:'Team',           width:110,filter:'agSetColumnFilter'},
        {field:'tab',        headerName:'Source Tab',     width:120,filter:'agSetColumnFilter',
         cellRenderer:p=>`<span style="font-size:10px;padding:2px 8px;border-radius:10px;background:rgba(168,85,247,0.12);color:#a855f7;font-weight:600;">${p.value||''}</span>`},
        {field:'receivedFmt',headerName:'Received',       width:165,filter:'agTextColumnFilter',sort:'desc'},
        {field:'ageDays',    headerName:'Age (Days)',      width:105,filter:'agNumberColumnFilter',comparator:(a,b)=>(a||0)-(b||0),
         cellRenderer:p=>p.value===null||p.value===undefined?'—':`<span style="font-size:12px;font-weight:700;color:${p.value>7?'#e74c3c':p.value>3?'#f39c12':'var(--t2)'};">${p.value}d</span>`},
        {field:'flagDateFmt',headerName:'Completed Date', width:165,filter:'agTextColumnFilter'},
    ];
    if (MB.gridApi) { try{MB.gridApi.destroy();}catch(e){} MB.gridApi=null; }
    el.innerHTML='';
    agGrid.createGrid(el,{
        columnDefs:cols, rowData:MB.filteredTickets,
        defaultColDef:{sortable:true,resizable:true,minWidth:80},
        pagination:true,paginationPageSize:50,paginationPageSizeSelector:[25,50,100,200],
        rowHeight:44,headerHeight:44,animateRows:true,enableCellTextSelection:true,
        getRowStyle:p=>p.data?.status==='Unassigned'?{background:'rgba(231,76,60,0.05)'}:null,
        onGridReady:p=>{MB.gridApi=p.api;},
    });
}

