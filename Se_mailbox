/* 1 — Email trend line — PROPER labels, uses actual dates */
function mbChartTrend(t) {
    const per = MB.trendPeriod;
    const now = new Date();

    // Build buckets based on actual data range or last N periods
    const bucketMap = {};
    t.forEach(x => {
        const d = mbParseDate(x.received); if (!d) return;
        let bkt, lbl;
        if (per==='D') {
            bkt = d.toISOString().split('T')[0];
            lbl = d.toLocaleDateString('en-GB',{day:'2-digit',month:'short'});
        } else if (per==='W') {
            const yr=d.getFullYear();
            const wk=Math.ceil((d-new Date(yr,0,1))/6048e5);
            bkt = `${yr}-W${String(wk).padStart(2,'0')}`;
            lbl = `W${wk} ${String(yr).slice(2)}`;
        } else {
            bkt = d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
            lbl = d.toLocaleDateString('en-GB',{month:'short',year:'numeric'});
        }
        if (!bucketMap[bkt]) bucketMap[bkt]={lbl,count:0};
        bucketMap[bkt].count++;
    });

    const sorted = Object.keys(bucketMap).sort();
    const labels = sorted.map(k=>bucketMap[k].lbl);
    const data   = sorted.map(k=>bucketMap[k].count);

    // Render toggles
    const wrap = document.getElementById('mb-trend-toggles');
    if (wrap) wrap.innerHTML = [['D','Daily'],['W','Weekly'],['M','Monthly']].map(([v,l])=>
        `<button type="button" onclick="MB.trendPeriod='${v}';if(MB.chartsVisible)mbChartTrend(MB.filteredTickets);"
        style="padding:4px 10px;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;
        border:1px solid ${v===per?'transparent':'var(--border)'};
        background:${v===per?'var(--grad)':'var(--bg-secondary)'};
        color:${v===per?'#fff':'var(--t3)'};">${l}</button>`
    ).join('');

    mbMakeChart('trend',{
        type:'line',
        data:{ labels, datasets:[{
            label:'Emails Received', data,
            borderColor:'#4c6fff', backgroundColor:'rgba(76,111,255,0.15)',
            borderWidth:2.5, pointRadius:4, pointBackgroundColor:'#4c6fff',
            pointBorderColor:'#fff', pointBorderWidth:2, tension:0.3, fill:true,
        }]},
        options:{
            responsive:true, maintainAspectRatio:false,
            plugins:{datalabels:{display:false},legend:{display:false}},
            scales:{
                x:{...MB_AX.x, ticks:{...MB_AX.x.ticks,maxRotation:45,maxTicksLimit:20}},
                y:{...MB_AX.y},
            },
        },
    });
}

