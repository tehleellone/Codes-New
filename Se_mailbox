/* 3 — SM workload with toggle + numbers on bars */
function mbChartWorkload(t) {
    const ws = MB.workloadStatus||'inprogress';
    const wrap = document.getElementById('mb-workload-toggles');
    if (wrap) wrap.innerHTML = [['inprogress','In Progress'],['unassigned','Unassigned'],['closed','Closed'],['all','All']].map(([v,l])=>
        `<button type="button" onclick="MB.workloadStatus='${v}';if(MB.chartsVisible)mbChartWorkload(MB.filteredTickets);"
        style="padding:3px 9px;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;
        border:1px solid ${v===ws?'transparent':'var(--border)'};
        background:${v===ws?'var(--grad)':'var(--bg-secondary)'};
        color:${v===ws?'#fff':'var(--t3)'};">${l}</button>`
    ).join('');

    const smMap={};
    t.forEach(x=>{
        const n=x.smFullName||'No SM';
        if (n==='Unassigned'||n==='') return;
        if (!smMap[n]) smMap[n]={unassigned:0,inprogress:0,closed:0,total:0};
        smMap[n].total++;
        if (x.status==='Unassigned')  smMap[n].unassigned++;
        if (x.status==='In Progress') smMap[n].inprogress++;
        if (x.status==='Closed'||x.status==='Completed') smMap[n].closed++;
    });

    let names;
    if (ws==='inprogress') names=Object.keys(smMap).sort((a,b)=>smMap[b].inprogress-smMap[a].inprogress);
    else if (ws==='unassigned') names=Object.keys(smMap).sort((a,b)=>smMap[b].unassigned-smMap[a].unassigned);
    else if (ws==='closed') names=Object.keys(smMap).sort((a,b)=>smMap[b].closed-smMap[a].closed);
    else names=Object.keys(smMap).sort((a,b)=>smMap[b].total-smMap[a].total);

    const datasets = ws==='all' ? [
        {label:'Unassigned',  data:names.map(n=>smMap[n].unassigned), backgroundColor:'rgba(231,76,60,0.85)',  borderRadius:4,borderSkipped:false},
        {label:'In Progress', data:names.map(n=>smMap[n].inprogress), backgroundColor:'rgba(243,156,18,0.85)', borderRadius:4,borderSkipped:false},
        {label:'Closed',      data:names.map(n=>smMap[n].closed),     backgroundColor:'rgba(39,174,96,0.85)',  borderRadius:4,borderSkipped:false},
    ] : [{
        label: ws==='inprogress'?'In Progress':ws==='unassigned'?'Unassigned':'Closed',
        data: names.map(n=>smMap[n][ws]),
        backgroundColor: ws==='inprogress'?'rgba(243,156,18,0.85)':ws==='unassigned'?'rgba(231,76,60,0.85)':'rgba(39,174,96,0.85)',
        borderRadius:4, borderSkipped:false,
    }];

    mbMakeChart('workload',{
        type:'bar',
        data:{labels:names, datasets},
        options:{
            responsive:true,maintainAspectRatio:false,
            plugins:{
                datalabels:{display:false},
                legend:{display:ws==='all',...MB_LEG},
            },
            scales:{
                x:{...(ws==='all'?{stacked:true}:{}),grid:{display:false},ticks:{font:{size:10},color:'rgba(160,160,180,0.8)',maxRotation:35}},
                y:{...(ws==='all'?{stacked:true}:{}),grid:{color:'rgba(168,85,247,0.08)'},ticks:{font:{size:10},color:'rgba(160,160,180,0.8)',precision:0}},
            },
        },
        // Plugin to draw numbers on top of bars
        plugins:[{
            id:'barLabels',
            afterDatasetsDraw(chart){
                const ctx=chart.ctx;
                chart.data.datasets.forEach((_,di)=>{
                    const meta=chart.getDatasetMeta(di);
                    meta.data.forEach((bar,idx)=>{
                        const val=chart.data.datasets[di].data[idx];
                        if (!val) return;
                        ctx.save();
                        ctx.font='bold 10px Inter,sans-serif';
                        ctx.fillStyle='rgba(160,160,180,0.9)';
                        ctx.textAlign='center';
                        ctx.textBaseline='bottom';
                        ctx.fillText(val, bar.x, bar.y-2);
                        ctx.restore();
                    });
                });
            }
        }],
    });
}

/* 4 — Avg days in progress per SM */
