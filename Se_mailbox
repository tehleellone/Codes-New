/* ── SM TILES — sorted desc by In Progress, no Unassigned ───── */
function mbRenderSMTiles() {
    const container = document.getElementById('mb-sm-tiles');
    if (!container) return;

    const smMap = {};
    // Use allTickets for tile building (show full picture even when filtered)
    MB.filteredTickets.forEach(t => {
        // SKIP unassigned in SM tiles — unassigned has no SM
        if (!t.smFullName || t.smFullName==='Unassigned' || t.smFullName==='') return;
        const n = t.smFullName;
        if (!smMap[n]) smMap[n] = { name:n, total:0, inprogress:0, closed:0, sent:0, team:t.smTeam, ages:[], cats:{} };
        const s = smMap[n];
        s.total++;
        if (t.status==='In Progress') s.inprogress++;
        if (t.status==='Closed'||t.status==='Completed') s.closed++;
        if (t.ageDays!==null&&t.ageDays!==undefined) s.ages.push(t.ageDays);
        if (t.category) s.cats[t.category]=(s.cats[t.category]||0)+1;
    });
    // Add sent count per SM from sentTickets
    MB.sentTickets.forEach(t => {
        const n = t.smFullName;
        if (!n||n==='Unassigned'||n==='') return;
        if (smMap[n]) smMap[n].sent++;
    });

    // Sort desc by In Progress
    const smList = Object.values(smMap).sort((a,b)=>b.inprogress-a.inprogress||b.total-a.total);

    if (!smList.length) {
        container.innerHTML = '<div style="color:var(--t3);padding:20px;text-align:center;">No data loaded.</div>';
        return;
    }

    container.innerHTML = smList.map((sm, i) => {
        const isSelected = MB.filterSMs.length===1 && MB.filterSMs[0]===sm.name;
        const topCats    = Object.entries(sm.cats).sort((a,b)=>b[1]-a[1]).slice(0,2);
        const avgAge     = sm.ages.length ? (sm.ages.reduce((a,b)=>a+b,0)/sm.ages.length).toFixed(1) : '—';
        const ageColor   = avgAge!=='—' ? (parseFloat(avgAge)>7?'#e74c3c':parseFloat(avgAge)>3?'#f39c12':'#27ae60') : 'var(--t3)';
        const grad       = MB_CLR.smColors[i%MB_CLR.smColors.length];
        const initials   = sm.name.split(' ').filter(Boolean).map(w=>w[0]).join('').substring(0,2).toUpperCase();
        const safeN      = sm.name.replace(/'/g,"\\'");

        return `<div class="manager-row ${isSelected?'selected':''}" onclick="mbSMTileClick('${safeN}')"
            style="${isSelected?'border-color:var(--acc);background:rgba(168,85,247,0.06);':''}cursor:pointer;">

            <!-- Avatar -->
            <div style="display:flex;align-items:center;gap:10px;min-width:170px;flex-shrink:0;">
                <div style="width:42px;height:42px;border-radius:50%;background:${grad};display:flex;align-items:center;justify-content:center;font-weight:800;font-size:15px;color:#fff;flex-shrink:0;">${initials}</div>
                <div>
                    <div style="font-size:13px;font-weight:800;color:var(--t1);line-height:1.3;">${sm.name}</div>
                    <div style="font-size:10px;color:var(--t3);">${sm.team||'TSM SE'}</div>
                </div>
            </div>

            <!-- Status pills -->
            <div style="display:flex;gap:5px;flex-wrap:wrap;min-width:260px;align-items:center;">
                <span style="padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;background:rgba(76,111,255,0.1);color:#4c6fff;">📬 ${sm.total} Total</span>
                <span style="padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;background:rgba(243,156,18,0.1);color:#f39c12;">🟡 ${sm.inprogress} In Progress</span>
                <span style="padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;background:rgba(39,174,96,0.1);color:#27ae60;">✅ ${sm.closed} Closed</span>
                <span style="padding:3px 9px;border-radius:20px;font-size:11px;font-weight:700;background:rgba(52,152,219,0.1);color:#3498db;">📤 ${sm.sent} Sent</span>
            </div>

            <!-- Avg days -->
            <div style="min-width:90px;text-align:center;flex-shrink:0;">
                <div style="font-size:9px;font-weight:700;text-transform:uppercase;color:var(--t3);letter-spacing:.04em;margin-bottom:2px;">Avg Days Open</div>
                <div style="font-size:1.25rem;font-weight:900;color:${ageColor};">${avgAge}d</div>
            </div>

            <!-- Top issues -->
            <div style="min-width:160px;flex-shrink:0;">
                <div style="font-size:9px;font-weight:700;text-transform:uppercase;color:var(--t3);letter-spacing:.04em;margin-bottom:4px;">Top Issues</div>
                ${topCats.map(([cat,cnt])=>`<div style="display:flex;justify-content:space-between;gap:4px;font-size:10px;margin-bottom:2px;">
                    <span style="color:var(--t2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:130px;">${cat}</span>
                    <span style="color:var(--acc);font-weight:700;">${cnt}</span>
