function resetAll(){
  selHD=null;selAD=null;selAM=null;selStatusTile=null; hideAD(); hideAM();
  document.querySelectorAll('.ms-dropdown input:not([disabled])').forEach(cb=>cb.checked=false);
  FILTER_DEFS.forEach(fd=>updateMsText(fd.key));
  applyAll();
  updateSelectionBadge();
}

// ══════════════════════════════════════════════════════════════════
//  SIDEBAR / THEME / SECTION SWITCHING
// ══════════════════════════════════════════════════════════════════
function toggleSidebar(){
  const sb=el('sidebar'); sb.classList.toggle('collapsed');
  const collapsed=sb.classList.contains('collapsed');
  el('sidebarToggleIcon').innerHTML=collapsed?
    '<polyline points="9 18 15 12 9 6"/><polyline points="15 18 21 12 15 6"/>':
    '<polyline points="15 18 9 12 15 6"/><polyline points="9 18 3 12 9 6"/>';
}
function switchSection(id){
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  const target=document.getElementById(id);
  if(target) target.scrollIntoView({behavior:'smooth',block:'start'});
  event.currentTarget.classList.add('active');
}
function applyTheme(base,dark){
  if(base==='duralux') document.body.setAttribute('data-theme',dark?'duralux-dark':'duralux');
  else { if(dark) document.body.setAttribute('data-theme','dark'); else document.body.removeAttribute('data-theme'); }
  const icon=el('themeIcon');
  if(icon) icon.innerHTML=dark?
    '<path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>':
    '<circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>';
}
function glkShowDashboard(){
    document.getElementById('dashboard-view').style.display='block';
    document.getElementById('table-nav').style.display='block';
    document.getElementById('revenue-forecast-view').style.display='none';
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
    document.getElementById('navDashboard').classList.add('active');
}
function glkShowRevenueForecast(){
    document.getElementById('dashboard-view').style.display='none';
    document.getElementById('table-nav').style.display='none';
    document.getElementById('revenue-forecast-view').style.display='block';
    document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
    document.getElementById('navRevenueForecast').classList.add('active');
    rfInit();
    if(rfChartsVisible) rfScheduleChartRender();
}
function changeTheme(event){
  const base=event.target.value;
  const cur=document.body.getAttribute('data-theme')||'';
  const isDark=cur==='dark'||cur==='duralux-dark';
  applyTheme(base,isDark);
  try{localStorage.setItem('glk_base_theme',base);}catch(e){}
  setTimeout(()=>{renderCharts();rfScheduleChartRender();},100);
}
function toggleTheme(){
  const cur=document.body.getAttribute('data-theme')||'';
  const isDark=cur==='dark'||cur==='duralux-dark';
  const isDural=cur==='duralux'||cur==='duralux-dark';
  applyTheme(isDural?'duralux':'magenta',!isDark);
  try{localStorage.setItem('glk_dark_mode',String(!isDark));}catch(e){}
  setTimeout(()=>{renderCharts();rfScheduleChartRender();},100);
}
function updateSelectionBadge(){
  const b=el('selectionBadge'); if(!b) return;
  const parts=[];
  if(selHD) parts.push('HD: '+selHD);
  if(selAD) parts.push('AD: '+selAD);
  if(selAM) parts.push('AM: '+selAM);
  if(selStatusTile) parts.push('Status: '+selStatusTile);
  if(parts.length){ b.textContent=parts.join(' › '); b.style.display='flex'; }
  else { b.textContent=''; b.style.display='none'; }
}

// ══════════════════════════════════════════════════════════════════
//  REVENUE FORECAST
// ══════════════════════════════════════════════════════════════════
const RF_ROW_DIMS=[
  {key:'typeOfRequest',label:'Type of Request'},
  {key:'typeOfContract',label:'Type of Contract'},
  {key:'vertical',label:'Vertical'},
  {key:'productFamily',label:'Product Family'},
  {key:'productCategory',label:'Product Category'},
  {key:'services',label:'Services'},
  {key:'headDirector',label:'Head Director'},
  {key:'accountDirector',label:'Account Director'},
  {key:'amName',label:'Account Manager'},
  {key:'status',label:'Status'},
  {key:'closureProb',label:'Closure Probability'},
  {key:'complexity',label:'Complexity'},
  {key:'prepaidPostpaid',label:'Pre/Postpaid'},
  {key:'customerCode',label:'Customer Code'},
  {key:'bidManager',label:'Bid Manager'},
  {key:'projectManager',label:'Project Manager'},
  {key:'customerName',label:'Customer'},
];
const RF_METRICS=[
  {key:'mrc',label:'MRC'},
  {key:'otc',label:'OTC'},
  {key:'tcv',label:'TCV'},
  {key:'pcv',label:'Cat. Value (PCV)'},
  {key:'gaPoints',label:'GA Points'},
  {key:'count',label:'Count of Opportunities'},
];
const RF_FILTER_DEFS=[
  {key:'rf_typeOfRequest',field:'typeOfRequest',label:'Type of Request'},
  {key:'rf_typeOfContract',field:'typeOfContract',label:'Type of Contract'},
  {key:'rf_vertical',field:'vertical',label:'Vertical'},
  {key:'rf_status',field:'status',label:'Opp. Status'},
  {key:'rf_closureProb',field:'closureProb',label:'Closure Probability'},
  {key:'rf_year',field:'_rfyear',label:'Year (Expected Activation)'},
];
const RF_MODAL_COLS=[
  {key:'customerName',label:'Customer'},
  {key:'amName',label:'Account Manager'},
  {key:'headDirector',label:'Head Director'},
  {key:'accountDirector',label:'Account Director'},
  {key:'expectedActivation',label:'Expected Activation',fmt:(v)=>fmtDate(v)},
  {key:'mrc',label:'MRC',fmt:(v)=>fmt(v)},
  {key:'otc',label:'OTC',fmt:(v)=>fmt(v)},
  {key:'tcv',label:'TCV',fmt:(v)=>fmt(v)},
  {key:'pcv',label:'Cat. Value',fmt:(v)=>fmt(v)},
  {key:'status',label:'Status'},
  {key:'closureProb',label:'Closure Prob.'},
];
let rfRowDim='typeOfRequest';
let rfMetric='mrc';
let rfModalCtx=null;      // {rowVal, monthIdx, year, excludedOnly}
let rfModalSortKey='customerName';
let rfModalSortDir=1;
let rfModalSearch='';
let rfChartsVisible=false;
let RF_EXCLUDED=new Set();
try{ RF_EXCLUDED=new Set(JSON.parse(localStorage.getItem('glk_rf_excluded')||'[]')); }catch(e){ RF_EXCLUDED=new Set(); }
function rfSaveExcluded(){ try{ localStorage.setItem('glk_rf_excluded', JSON.stringify([...RF_EXCLUDED])); }catch(e){} }
// Default to "remaining year only" — most useful default for a forward-looking forecast.
let rfHidePast=true;
try{ const saved=localStorage.getItem('glk_rf_hidepast'); if(saved!==null) rfHidePast=(saved==='true'); }catch(e){}
const RF_TODAY=new Date();
const rfCurrentMonthIdx=RF_TODAY.getMonth();
const rfCurrentYear=RF_TODAY.getFullYear();
let rfFiltersBuilt=false;

function rfEnsureDefaultYear(){
  const yearKey='rf_year';
  const drop=el('msd_'+yearKey);
  if(!drop) return;
  if(getChecked(yearKey).length) return;
  const target=drop.querySelector('input[value="'+String(rfCurrentYear)+'"]');
  if(target){ target.checked=true; updateMsText(yearKey); }
}
function rfApplyDefaultFilters(){
  rfEnsureDefaultYear();
  rfHidePast=true;
  const cb=el('rfHidePastToggle'); if(cb) cb.checked=true;
  try{ localStorage.setItem('glk_rf_hidepast','true'); }catch(e){}
}

function rfInit(){
  if(!el('rfFiltersGrid') || !el('rfFiltersGrid').children.length){ rfBuildFilters(); rfBuildTabs(); }
  else { rfEnsureDefaultYear(); }
  const cb=el('rfHidePastToggle'); if(cb) cb.checked=rfHidePast;
  rfLoadScenariosFromStorage();
  rfRefreshScenarioSelect();
  rfLoadScenario(rfActiveScenarioName);
  rfRenderAll();
}

// ── data helpers ─────────────────────────────────────────────────
// Table 1 & 2 both key off Expected Activation directly; the cascade (Table 2)
// already models "billed the month after activation" via its origin+1 roll-forward.
function rfGetYear(bid){ if(!bid.expectedActivation) return null; const d=new Date(bid.expectedActivation); return isNaN(d)?null:String(d.getFullYear()); }
function rfGetMonthIdx(bid){ if(!bid.expectedActivation) return null; const d=new Date(bid.expectedActivation); return isNaN(d)?null:d.getMonth(); }
function probToFraction(p){ if(!p) return 0; const n=parseFloat(p); return isNaN(n)?0:n/100; }
function rfGetBaseBids(){
  return ALL_BIDS.filter(b=>b.expectedActivation && !isNaN(new Date(b.expectedActivation)));
}
function rfGetFilterVals(fd){
  const base=rfGetBaseBids();
  if(fd.field==='_rfyear') return [...new Set(base.map(rfGetYear).filter(Boolean))].sort();
  if(fd.field==='closureProb') return PROB_ORDER.filter(p=>base.some(b=>b.closureProb===p));
  return [...new Set(base.map(b=>b[fd.field]).filter(v=>v&&v!=='—'))].sort();
}
function rfApplyUiFilters(bids){
  const checks={};
  RF_FILTER_DEFS.forEach(fd=>{ checks[fd.key]=getChecked(fd.key); });
  return bids.filter(function(b){
    for(const fd of RF_FILTER_DEFS){
      const vals=checks[fd.key]; if(!vals.length) continue;
      const bv=fd.field==='_rfyear'?rfGetYear(b):b[fd.field];
      if(!vals.includes(bv)) return false;
    }
    return true;
  });
}
function rfVisibleBids(){ return rfApplyUiFilters(rfGetBaseBids()); }
function rfActiveBids(){ return rfVisibleBids().filter(b=>!RF_EXCLUDED.has(b.id)); }
function rfGetCellBids(rowVal,monthIdx,year,includeExcluded,blockId){
  let bids;
  if(blockId){
    const block=RF_EXTRA_BLOCKS.find(function(b){ return b.id===blockId; });
    bids=block?rfGetBlockBids(block):[];
  } else {
    bids=includeExcluded?rfVisibleBids():rfActiveBids();
  }
  if(rowVal!=null) bids=bids.filter(b=>b[rfRowDim]===rowVal);
  if(monthIdx!=null) bids=bids.filter(b=>rfGetMonthIdx(b)===monthIdx);
  if(year!=null) bids=bids.filter(b=>rfGetYear(b)===year);
  return bids;
}
function rfMetricVal(b){ return rfMetric==='count' ? 1 : num(b[rfMetric]); }
function rfSum(bids){ return bids.reduce((s,b)=>s+rfMetricVal(b),0); }
function rfFmtVal(v){ if(rfMetric==='count') return String(Math.round(v*10)/10); if(rfMetric==='gaPoints') return fmtGA(v); return fmt(v); }
function rfYearBase(bids,year){
  const yb=bids.filter(b=>rfGetYear(b)===year);
  const arr=new Array(12).fill(0);
  for(let m=0;m<12;m++) arr[m]=rfSum(yb.filter(b=>rfGetMonthIdx(b)===m));
  return arr;
}
// "Hide past months" visibility rules — Table 1 aggregates by calendar month across years,
// Table 2 is per calendar year, so a whole past year can be hidden outright.
function rfPivotMonthVisible(m){ return !rfHidePast || m>=rfCurrentMonthIdx; }
function rfCascadeYearVisible(year){ return !rfHidePast || Number(year)>=rfCurrentYear; }
function rfCascadeMonthVisible(year,m){
  if(!rfHidePast) return true;
  const y=Number(year);
  if(y>rfCurrentYear) return true;
  if(y<rfCurrentYear) return false;
  return m>=rfCurrentMonthIdx;
}
function rfCascadeOriginVisible(year,origin){
  if(!rfHidePast) return true;
  if(Number(year)>rfCurrentYear) return true;
  if(Number(year)<rfCurrentYear) return false;
  return origin>=rfCurrentMonthIdx;
}
function rfSetHidePast(v){ rfHidePast=v; try{ localStorage.setItem('glk_rf_hidepast',String(v)); }catch(e){} rfRenderAll(); }
function rfVisibleBidsForCharts(){
  let bids=rfActiveBids();
  if(rfHidePast){
    bids=bids.filter(function(b){
      const y=rfGetYear(b), m=rfGetMonthIdx(b);
      if(y==null||m==null) return false;
      return rfCascadeMonthVisible(y,m);
    });
  }
  return bids;
}

// ── filters UI (reuses existing ms-dropdown engine via 'rf_' prefixed keys) ──
function rfBuildFilters(){
  const grid=el('rfFiltersGrid'); if(!grid) return; grid.innerHTML='';
  RF_FILTER_DEFS.forEach(function(fd){
    const div=document.createElement('div'); div.className='filter-group';
    div.innerHTML='<div class="filter-label">'+fd.label+'</div>';
    const wrap=document.createElement('div'); wrap.className='ms-wrap'; wrap.id='ms_'+fd.key;
    const trig=document.createElement('div'); trig.className='ms-trigger'; trig.id='mst_'+fd.key;
    trig.innerHTML='<span id="mstext_'+fd.key+'">All</span><svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>';
    trig.onclick=function(e){e.stopPropagation();toggleMs(fd.key);};
    const drop=document.createElement('div'); drop.className='ms-dropdown'; drop.id='msd_'+fd.key;
    rfGetFilterVals(fd).forEach(function(v){
      const opt=document.createElement('div'); opt.className='ms-option';
      const cid='cb_'+fd.key+'_'+v.toString().replace(/[^a-zA-Z0-9]/g,'_');
      const preCheck = (fd.field==='_rfyear' && v===String(rfCurrentYear) && !rfFiltersBuilt);
      opt.innerHTML='<input type="checkbox" id="'+cid+'" value="'+v+'"'+(preCheck?' checked':'')+' onchange="rfOnFilterChange(\''+fd.key+'\')"><label for="'+cid+'">'+v+'</label>';
      drop.appendChild(opt);
    });
    wrap.appendChild(trig); wrap.appendChild(drop); div.appendChild(wrap); grid.appendChild(div);
  });
  rfEnsureDefaultYear();
  RF_FILTER_DEFS.forEach(fd=>updateMsText(fd.key));
  rfFiltersBuilt=true;
}
function rfOnFilterChange(key){ updateMsText(key); rfRenderAll(); }
function rfClearAllFilters(){
  document.querySelectorAll('#rfFiltersGrid .ms-dropdown input').forEach(cb=>cb.checked=false);
  rfApplyDefaultFilters();
  RF_FILTER_DEFS.forEach(fd=>updateMsText(fd.key));
  rfRenderAll();
}
// Group-by / Metric are single dropdowns exposing every available dimension — no artificial limits.
function rfBuildTabs(){
  const rowWrap=el('rfRowDimTabs');
  if(rowWrap){
    rowWrap.innerHTML='<select class="color-scheme-selector" id="rfRowDimSelect" onchange="rfSetRowDim(this.value)" style="min-width:210px;">'+
      RF_ROW_DIMS.map(function(rd){ return '<option value="'+rd.key+'"'+(rd.key===rfRowDim?' selected':'')+'>'+rd.label+'</option>'; }).join('')+
      '</select>';
  }
  const metWrap=el('rfMetricTabs');
  if(metWrap){
    metWrap.innerHTML='<select class="color-scheme-selector" id="rfMetricSelect" onchange="rfSetMetric(this.value)" style="min-width:190px;">'+
      RF_METRICS.map(function(m){ return '<option value="'+m.key+'"'+(m.key===rfMetric?' selected':'')+'>'+m.label+'</option>'; }).join('')+
      '</select>';
  }
}
function rfSetRowDim(k){ rfRowDim=k; rfRenderAll(); }
function rfSetMetric(k){ rfMetric=k; rfRenderAll(); }

// ── Scenario blocks (multi-table budget model) ───────────────────
const RF_BLOCK_COLORS=['#ef4444','#f59e0b','#06b6d4','#8b5cf6','#ec4899','#16a34a'];
let RF_EXTRA_BLOCKS=[];
let rfActiveScenarioName='Default';
let rfScenariosCache={};

function rfScenarioStorageKey(){
  return 'glk_rf_scenarios_'+(USER&&USER.email?USER.email.toLowerCase():'default');
}
function rfLoadScenariosFromStorage(){
  try{ rfScenariosCache=JSON.parse(localStorage.getItem(rfScenarioStorageKey())||'{}'); }catch(e){ rfScenariosCache={}; }
}
function rfRefreshScenarioSelect(){
  const sel=el('rfScenarioSelect'); if(!sel) return;
  rfLoadScenariosFromStorage();
  const names=Object.keys(rfScenariosCache).sort();
  if(!names.includes('Default')) rfScenariosCache.Default={blocks:[],savedAt:null};
  sel.innerHTML=['Default',...names.filter(n=>n!=='Default')].map(function(n){
    return '<option value="'+n+'"'+(n===rfActiveScenarioName?' selected':'')+'>'+n+'</option>';
  }).join('');
}
function rfSaveScenario(){
  const name=prompt('Save scenario as:', rfActiveScenarioName||'Scenario '+new Date().toLocaleDateString());
  if(!name||!name.trim()) return;
  rfSyncAllBlockFiltersFromDom();
  rfScenariosCache[name.trim()]={
    blocks:RF_EXTRA_BLOCKS.map(function(b){ return {id:b.id,name:b.name,color:b.color,op:b.op,filters:JSON.parse(JSON.stringify(b.filters||{}))}; }),
    savedAt:new Date().toISOString()
  };
  try{ localStorage.setItem(rfScenarioStorageKey(), JSON.stringify(rfScenariosCache)); }catch(e){}
  rfActiveScenarioName=name.trim();
  rfRefreshScenarioSelect();
  alert('Scenario "'+rfActiveScenarioName+'" saved.');
}
function rfLoadScenario(name){
  if(!name) return;
  rfLoadScenariosFromStorage();
  const sc=rfScenariosCache[name];
  rfActiveScenarioName=name;
  if(sc&&sc.blocks){
    RF_EXTRA_BLOCKS=sc.blocks.map(function(b){
      return {id:b.id||('b'+Date.now()+Math.random().toString(36).slice(2,5)),name:b.name||'Block',color:b.color||RF_BLOCK_COLORS[0],op:b.op||'none',filters:b.filters||{}};
    });
  } else { RF_EXTRA_BLOCKS=[]; }
  rfRenderBlocks();
  rfRenderNetTable();
  rfScheduleChartRender();
}
function rfSyncBlockFiltersFromDom(block){
  if(!block.filters) block.filters={};
  RF_FILTER_DEFS.forEach(function(fd){
    const key='rfb_'+block.id+'_'+fd.key;
    block.filters[fd.key]=getChecked(key);
  });
}
function rfSyncAllBlockFiltersFromDom(){ RF_EXTRA_BLOCKS.forEach(rfSyncBlockFiltersFromDom); }

function rfGetBlockBids(block){
  let bids=rfGetBaseBids().filter(function(b){ return !RF_EXCLUDED.has(b.id); });
  const filters=block.filters||{};
  return bids.filter(function(b){
    for(const fd of RF_FILTER_DEFS){
      const vals=filters[fd.key];
      if(!vals||!vals.length) continue;
      const bv=fd.field==='_rfyear'?rfGetYear(b):b[fd.field];
      if(!vals.includes(bv)) return false;
    }
    return true;
  });
}
function rfBuildMatrix(bids){
  const visibleMonths=[]; for(let m=0;m<12;m++) if(rfPivotMonthVisible(m)) visibleMonths.push(m);
  const rowLabel=RF_ROW_DIMS.find(r=>r.key===rfRowDim).label;
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  const totalLabel=rfHidePast?'Remaining Total':'Grand Total';
  if(!bids.length||!visibleMonths.length) return null;
  const rows=[...new Set(bids.map(b=>b[rfRowDim]).filter(v=>v&&v!=='—'))].sort();
  const cells={}; const colTotals={}; visibleMonths.forEach(m=>colTotals[m]=0);
  const rowTotals={}; let grandTotal=0;
  rows.forEach(function(rowVal){
    let rowTotal=0;
    visibleMonths.forEach(function(m){
      const val=rfSum(bids.filter(function(b){ return b[rfRowDim]===rowVal&&rfGetMonthIdx(b)===m; }));
      cells[rowVal+'|'+m]=val;
      colTotals[m]+=val; rowTotal+=val;
    });
    rowTotals[rowVal]=rowTotal; grandTotal+=rowTotal;
  });
  return {visibleMonths,rows,cells,colTotals,rowTotals,grandTotal,rowLabel,metricLabel,totalLabel};
}
function rfPaintMatrixHtml(matrix, drillOpts){
  if(!matrix) return '<div style="padding:1.5rem;text-align:center;color:var(--t3);">No data matches filters.</div>';
  const {visibleMonths,rows,cells,colTotals,rowTotals,grandTotal,rowLabel,totalLabel,isNet}=matrix;
  const clickFn=drillOpts&&drillOpts.blockId
    ? function(rv,m){ const rvArg=rv==null?'null':JSON.stringify(rv); const mArg=m==null?'null':m; return 'rfOpenBlockDrilldown(\''+drillOpts.blockId+'\','+rvArg+','+mArg+',null)'; }
    : function(rv,m){ const rvArg=rv==null?'null':JSON.stringify(rv); const mArg=m==null?'null':m; return 'rfOpenDrilldown('+rvArg+','+mArg+',null)'; };
  function cellClass(v){ if(!isNet||!v) return ''; return v<0?' rf-cell-neg':(v>0?' rf-cell-pos':''); }
  let html='<table class="rf-table"><thead><tr><th>'+rowLabel+'</th>';
  visibleMonths.forEach(m=>html+='<th>'+MONTH_NAMES[m]+'</th>');
  html+='<th class="rf-total-col">'+totalLabel+'</th></tr></thead><tbody>';
  rows.forEach(function(rowVal){
    html+='<tr><td>'+rowVal+'</td>';
    visibleMonths.forEach(function(m){
      const val=cells[rowVal+'|'+m]||0;
      html+= val ? '<td class="rf-cell-btn'+cellClass(val)+'" onclick="'+clickFn(rowVal,m)+'">'+rfFmtVal(val)+'</td>' : '<td class="rf-cell-empty">—</td>';
    });
    const rt=rowTotals[rowVal]||0;
    html+= rt ? '<td class="rf-total-col rf-cell-btn'+cellClass(rt)+'" onclick="'+clickFn(rowVal,null)+'">'+rfFmtVal(rt)+'</td></tr>' : '<td class="rf-total-col">—</td></tr>';
  });
  html+='</tbody><tfoot><tr><td>'+totalLabel+'</td>';
  visibleMonths.forEach(function(m){
    const v=colTotals[m]||0;
    html+= v ? '<td class="rf-cell-btn'+cellClass(v)+'" onclick="'+clickFn(null,m)+'">'+rfFmtVal(v)+'</td>' : '<td class="rf-cell-empty">—</td>';
  });
  html+= grandTotal ? '<td class="rf-total-col rf-cell-btn'+cellClass(grandTotal)+'" onclick="'+clickFn(null,null)+'">'+rfFmtVal(grandTotal)+'</td></tr></tfoot></table>' : '<td class="rf-total-col">—</td></tr></tfoot></table>';
  return html;
}
function rfComputeNetMatrix(pipelineMat, blockEntries){
  if(!pipelineMat) return null;
  const hasOp=blockEntries.some(function(e){ return e.op==='add'||e.op==='subtract'; });
  if(!hasOp) return null;
  const visibleMonths=pipelineMat.visibleMonths;
  const allRows=new Set(pipelineMat.rows);
  blockEntries.forEach(function(e){
    if(e.op==='none'||!e.matrix) return;
    e.matrix.rows.forEach(function(r){ allRows.add(r); });
  });
  const rows=[...allRows].sort();
  const cells={}; const colTotals={}; visibleMonths.forEach(m=>colTotals[m]=0);
  const rowTotals={}; let grandTotal=0;
  rows.forEach(function(rowVal){
    let rowTotal=0;
    visibleMonths.forEach(function(m){
      let val=pipelineMat.cells[rowVal+'|'+m]||0;
      blockEntries.forEach(function(e){
        if(e.op==='none'||!e.matrix) return;
        const v=e.matrix.cells[rowVal+'|'+m]||0;
        val+=e.op==='add'?v:-v;
      });
      cells[rowVal+'|'+m]=val;
      colTotals[m]+=val; rowTotal+=val;
    });
    rowTotals[rowVal]=rowTotal; grandTotal+=rowTotal;
  });
  return Object.assign({},pipelineMat,{rows,cells,colTotals,rowTotals,grandTotal,isNet:true,totalLabel:'Net Total'});
}
function rfGetBlockMatrices(){
  return RF_EXTRA_BLOCKS.map(function(block){
    return {block: block, matrix: rfBuildMatrix(rfGetBlockBids(block)), op: block.op};
  });
}
function rfNetFormulaText(blockEntries){
  let t='Pipeline';
  blockEntries.forEach(function(e){
    if(e.op==='add') t+=' + '+e.block.name;
    else if(e.op==='subtract') t+=' − '+e.block.name;
  });
  return t;
}

function rfAddBlock(){
  const idx=RF_EXTRA_BLOCKS.length;
  RF_EXTRA_BLOCKS.push({
    id:'b'+Date.now()+Math.random().toString(36).slice(2,5),
    name:'Scenario Table '+(idx+1),
    color:RF_BLOCK_COLORS[idx%RF_BLOCK_COLORS.length],
    op:idx===0?'subtract':'none',
    filters:{ rf_year:[String(rfCurrentYear)] }
  });
  rfRenderBlocks();
  rfRenderNetTable();
  rfScheduleChartRender();
}
function rfRemoveBlock(id){
  RF_EXTRA_BLOCKS=RF_EXTRA_BLOCKS.filter(function(b){ return b.id!==id; });
  rfRenderBlocks();
  rfRenderNetTable();
  rfScheduleChartRender();
}
function rfBlockOpChange(id, op){
  const b=RF_EXTRA_BLOCKS.find(function(x){ return x.id===id; });
  if(b){ b.op=op; rfRenderNetTable(); rfScheduleChartRender(); }
}
function rfBlockNameChange(id, name){
  const b=RF_EXTRA_BLOCKS.find(function(x){ return x.id===id; });
  if(b){ b.name=name; rfRenderNetTable(); rfScheduleChartRender(); }
}
function rfBlockFilterChange(blockId, msKey){
  updateMsText(msKey);
  const block=RF_EXTRA_BLOCKS.find(function(b){ return b.id===blockId; });
  if(!block) return;
  if(!block.filters) block.filters={};
  const fdKey=msKey.replace('rfb_'+blockId+'_','');
  block.filters[fdKey]=getChecked(msKey);
  const tbl=el('rfBlockTable_'+blockId);
  if(tbl) tbl.innerHTML=rfPaintMatrixHtml(rfBuildMatrix(rfGetBlockBids(block)),{blockId:blockId});
  rfRenderNetTable();
  rfScheduleChartRender();
}
function rfBuildBlockFilters(block){
  let html='<div class="filters-grid">';
  RF_FILTER_DEFS.forEach(function(fd){
    const msKey='rfb_'+block.id+'_'+fd.key;
    const saved=block.filters[fd.key]||[];
    const vals=rfGetFilterVals(fd);
    html+='<div class="filter-group"><div class="filter-label">'+fd.label+'</div>';
    html+='<div class="ms-wrap" id="ms_'+msKey+'">';
    html+='<div class="ms-trigger" id="mst_'+msKey+'" onclick="event.stopPropagation();toggleMs(\''+msKey+'\')"><span id="mstext_'+msKey+'">'+(saved.length?saved.length+' selected':'All')+'</span><svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg></div>';
    html+='<div class="ms-dropdown" id="msd_'+msKey+'">';
    vals.forEach(function(v){
      const cid='cb_'+msKey+'_'+v.toString().replace(/[^a-zA-Z0-9]/g,'_');
      const chk=saved.includes(v)?' checked':'';
      html+='<div class="ms-option"><input type="checkbox" id="'+cid+'" value="'+v+'"'+chk+' onchange="rfBlockFilterChange(\''+block.id+'\',\''+msKey+'\')"><label for="'+cid+'">'+v+'</label></div>';
    });
    html+='</div></div></div>';
  });
  html+='</div>';
  return html;
}
function rfRenderBlocks(){
  const container=el('rfExtraBlocksContainer'); if(!container) return;
  if(!RF_EXTRA_BLOCKS.length){ container.innerHTML=''; return; }
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  container.innerHTML=RF_EXTRA_BLOCKS.map(function(block, i){
    const matrix=rfBuildMatrix(rfGetBlockBids(block));
    const opLabel=block.op==='add'?'+ Add to Pipeline':(block.op==='subtract'?'− Subtract from Pipeline':'No calculation');
    return '<div class="rf-block-card" style="--blk-color:'+block.color+'" id="rfBlock_'+block.id+'">'+
      '<div class="rf-block-head">'+
        '<input class="rf-block-name" value="'+block.name.replace(/"/g,'&quot;')+'" onchange="rfBlockNameChange(\''+block.id+'\',this.value)" title="Rename table">'+
        '<div class="rf-block-op-wrap"><span>Calculation vs Pipeline:</span>'+
          '<select onchange="rfBlockOpChange(\''+block.id+'\',this.value)">'+
            '<option value="none"'+(block.op==='none'?' selected':'')+'>Do nothing</option>'+
            '<option value="add"'+(block.op==='add'?' selected':'')+'>+ Add</option>'+
            '<option value="subtract"'+(block.op==='subtract'?' selected':'')+'>− Subtract</option>'+
          '</select></div>'+
        '<span style="font-size:.68rem;color:var(--t3);">'+opLabel+'</span>'+
        '<button type="button" class="rf-block-remove" onclick="rfRemoveBlock(\''+block.id+'\')" title="Remove table"><svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12"/></svg></button>'+
      '</div>'+
      '<div class="rf-block-filters">'+rfBuildBlockFilters(block)+'</div>'+
      '<div class="rf-panel-head" style="border-bottom:1px solid var(--border);padding:.65rem 1rem;">'+
        '<div class="rf-panel-sub">Filtered pipeline slice · '+metricLabel+' · same row/metric as Table 1</div></div>'+
      '<div id="rfBlockTable_'+block.id+'" class="rf-table-scroll">'+rfPaintMatrixHtml(matrix,{blockId:block.id})+'</div>'+
    '</div>';
  }).join('');
  RF_EXTRA_BLOCKS.forEach(function(block){
    RF_FILTER_DEFS.forEach(function(fd){
      updateMsText('rfb_'+block.id+'_'+fd.key);
    });
  });
}
function rfRenderNetTable(){
  const panel=el('rfNetPanel'); const container=el('rfNetTable'); if(!panel||!container) return;
  const pipelineMat=rfBuildMatrix(rfActiveBids());
  const blockEntries=rfGetBlockMatrices();
  const netMat=rfComputeNetMatrix(pipelineMat, blockEntries);
  if(!netMat){
    panel.style.display='none';
    container.innerHTML='';
    return;
  }
  panel.style.display='block';
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  set('rfNetTitle','Net Forecast — '+metricLabel);
  set('rfNetFormula', rfNetFormulaText(blockEntries));
  container.innerHTML=rfPaintMatrixHtml(netMat, null);
}

function rfOpenBlockDrilldown(blockId, rowVal, monthIdx, year){
  rfModalCtx={rowVal,monthIdx,year,excludedOnly:false,blockId:blockId};
  rfModalSortKey='customerName'; rfModalSortDir=1; rfModalSearch='';
  rfRenderModal();
}

// ── Export: Excel & PDF ──────────────────────────────────────────
function rfFmtExport(v){
  if(v===null||v===undefined||v==='—') return '—';
  const n=num(v);
  if(!n) return '—';
  const sign=n<0?'-':'';
  const abs=Math.abs(n);
  if(abs>=1e9) return sign+(abs/1e9).toFixed(2)+' B';
  if(abs>=1e6) return sign+(abs/1e6).toFixed(2)+' M';
  if(abs>=1e3) return sign+(abs/1e3).toFixed(1)+' K';
  return sign+Math.round(abs).toLocaleString('en-US');
}
function rfExcelStyles(){
  return '<style>body{font-family:Calibri,Arial,sans-serif;margin:20px;color:#1a1025;}'+
    'h1{font-size:22px;color:#7c3aed;margin:0 0 6px;}h2{font-size:15px;color:#4c6fff;margin:28px 0 10px;padding-bottom:6px;border-bottom:2px solid #e9d5ff;}'+
    'h3{font-size:13px;margin:22px 0 8px;font-weight:700;}.meta{font-size:11px;color:#666;margin-bottom:18px;}'+
    '.xtable{border-collapse:collapse;width:100%;margin-bottom:8px;}.xtable th,.xtable td{border:1px solid #d1d5db;padding:10px 14px;font-size:11px;}'+
    '.xtable th{color:#fff;font-weight:700;text-align:center;white-space:nowrap;}.xtable td.num{text-align:right;white-space:nowrap;mso-number-format:"\\@";}'+
    '.xtable td.label{text-align:left;font-weight:600;background:#fafafa;}.xtable tr.total td{font-weight:800;background:#f3e8ff;}'+
    '.kpi td:first-child{font-weight:600;background:#faf5ff;width:220px;}.kpi td:last-child{text-align:right;font-weight:700;mso-number-format:"\\@";}'+
    '.spacer{height:16px;}</style>';
}
function rfExcelCell(v, opts){
  opts=opts||{};
  const cls=(opts.label?' label':' num');
  let style='';
  if(opts.color) style='color:'+opts.color+';';
  if(opts.bg) style+='background:'+opts.bg+';';
  return '<td class="'+cls.trim()+'" style="'+style+'">'+(opts.label?(v||''):rfFmtExport(v))+'</td>';
}
function rfExcelMatrixTable(title, matrix, headerBg, rowTint, showNeg){
  if(!matrix) return '';
  const {visibleMonths,rows,cells,colTotals,rowTotals,grandTotal,rowLabel,totalLabel}=matrix;
  let h='<h3 style="color:'+headerBg+';">'+title+'</h3><table class="xtable"><colgroup><col style="width:180px;">';
  visibleMonths.forEach(function(){ h+='<col style="width:92px;">'; });
  h+='<col style="width:110px;"></colgroup><tr><th style="background:'+headerBg+';text-align:left;">'+rowLabel+'</th>';
  visibleMonths.forEach(function(m){ h+='<th style="background:'+headerBg+';">'+MONTH_NAMES[m]+'</th>'; });
  h+='<th style="background:'+headerBg+';">'+totalLabel+'</th></tr>';
  rows.forEach(function(rowVal, i){
    const bg=i%2===0?rowTint:'#ffffff';
    h+='<tr>'+rfExcelCell(rowVal,{label:true,bg:bg});
    visibleMonths.forEach(function(m){
      const v=cells[rowVal+'|'+m]||0;
      let color='';
      if(showNeg&&v<0) color='#b91c1c'; else if(showNeg&&v>0) color='#15803d';
      h+=rfExcelCell(v,{bg:bg,color:color});
    });
    const rt=rowTotals[rowVal]||0;
    h+=rfExcelCell(rt,{bg:bg,color:showNeg&&rt<0?'#b91c1c':(showNeg&&rt>0?'#15803d':'')})+'</tr>';
  });
  h+='<tr class="total"><td class="label" style="background:'+headerBg+';color:#fff;">'+totalLabel+'</td>';
  visibleMonths.forEach(function(m){
    const v=colTotals[m]||0;
    h+=rfExcelCell(v,{bg:'#f3e8ff',color:showNeg&&v<0?'#b91c1c':(showNeg&&v>0?'#15803d':'')});
  });
  h+=rfExcelCell(grandTotal,{bg:'#ede9fe',color:showNeg&&grandTotal<0?'#b91c1c':'#5b21b6'})+'</tr></table><div class="spacer"></div>';
  return h;
}
function rfExportExcel(){
  rfSyncAllBlockFiltersFromDom();
  const pipelineMat=rfBuildMatrix(rfActiveBids());
  const blockEntries=rfGetBlockMatrices();
  const netMat=rfComputeNetMatrix(pipelineMat, blockEntries);
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  const rowLabel=RF_ROW_DIMS.find(r=>r.key===rfRowDim).label;
  const conf=rfConfidenceFor(rfActiveBids());
  const dateStr=new Date().toISOString().split('T')[0];
  let html='<?xml version="1.0"?><html xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:x="urn:schemas-microsoft-com:office:excel"><head><meta charset="utf-8">';
  html+=rfExcelStyles()+'</head><body>';
  html+='<h1>'+APP_NAME+' — Budget Scenario Export</h1>';
  html+='<div class="meta"><strong>Date:</strong> '+dateStr+' &nbsp;|&nbsp; <strong>Prepared by:</strong> '+(USER.name||'')+' &nbsp;|&nbsp; <strong>Metric:</strong> '+metricLabel+' &nbsp;|&nbsp; <strong>Group By:</strong> '+rowLabel+'</div>';
  html+='<h2>Executive Summary</h2><table class="xtable kpi"><tr><th style="background:#7c3aed;text-align:left;">KPI</th><th style="background:#7c3aed;">Value ('+metricLabel+')</th></tr>';
  html+='<tr><td>Total Active Pipeline</td><td>'+rfFmtExport(conf.bestCaseVal)+'</td></tr>';
  html+='<tr><td>Committed (Won / Billed)</td><td style="color:#15803d;">'+rfFmtExport(conf.committedVal)+'</td></tr>';
  html+='<tr><td>Probability-Weighted Forecast</td><td>'+rfFmtExport(conf.weightedVal)+'</td></tr>';
  if(netMat) html+='<tr><td style="background:#dbeafe;font-weight:800;">Net Budget Forecast</td><td style="color:#1d4ed8;font-weight:800;">'+rfFmtExport(netMat.grandTotal)+'</td></tr>';
  html+='</table><div class="spacer"></div>';
  html+=rfExcelMatrixTable('Table 1 — Pipeline Pivot', pipelineMat, '#15803d', '#ecfdf5', false);
  blockEntries.forEach(function(e){
    const opTag=e.block.op==='add'?'+ ADD':(e.block.op==='subtract'?'− SUBTRACT':'VIEW ONLY');
    html+=rfExcelMatrixTable('Scenario: '+e.block.name+' ('+opTag+')', e.matrix, e.block.color, e.block.color+'14', false);
  });
  if(netMat) html+=rfExcelMatrixTable('Net Forecast — '+rfNetFormulaText(blockEntries), netMat, '#1d4ed8', '#eff6ff', true);
  html+='<p style="font-size:10px;color:#888;margin-top:24px;">Generated by '+APP_NAME+' · Revenue Forecast module</p></body></html>';
  const blob=new Blob([html],{type:'application/vnd.ms-excel;charset=utf-8'});
  const a=document.createElement('a'); a.href=URL.createObjectURL(blob);
  a.download='Revenue_Forecast_'+dateStr+'.xls'; a.click();
}
function rfBuildPdfReportHtml(chartImages){
  rfSyncAllBlockFiltersFromDom();
  const pipelineMat=rfBuildMatrix(rfActiveBids());
  const blockEntries=rfGetBlockMatrices();
  const netMat=rfComputeNetMatrix(pipelineMat, blockEntries);
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  const conf=rfConfidenceFor(rfActiveBids());
  const dateStr=new Date().toLocaleDateString('en-GB',{day:'2-digit',month:'short',year:'numeric'});
  let h='<div id="rfPdfRoot" style="font-family:Inter,Calibri,Arial,sans-serif;padding:36px 40px;background:#fff;color:#1a1025;box-sizing:border-box;">';
  h+='<div style="border-bottom:4px solid #7c3aed;padding-bottom:18px;margin-bottom:28px;">';
  h+='<h1 style="margin:0;color:#7c3aed;font-size:26px;font-weight:900;">'+APP_NAME+'</h1>';
  h+='<p style="margin:8px 0 0;font-size:13px;color:#555;">Budget Analysis Report · '+dateStr+' · '+metricLabel+' · '+(USER.name||'User')+'</p></div>';
  h+='<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:28px;">';
  [['Pipeline',conf.bestCaseVal,'#7c3aed'],['Committed',conf.committedVal,'#15803d'],['Weighted',conf.weightedVal,'#d97706'],['Net Forecast',netMat?netMat.grandTotal:conf.bestCaseVal,'#2563eb']].forEach(function(k){
    h+='<div style="background:linear-gradient(135deg,#faf5ff,#fff);border-radius:12px;padding:16px;border:1px solid #e9d5ff;border-left:5px solid '+k[2]+';"><div style="font-size:10px;font-weight:800;color:#666;text-transform:uppercase;">'+k[0]+'</div><div style="font-size:20px;font-weight:900;color:'+k[2]+';margin-top:6px;">'+rfFmtExport(k[1])+'</div></div>';
  });
  h+='</div>';
  if(netMat) h+='<div style="font-size:13px;background:#eff6ff;padding:12px 16px;border-radius:10px;border-left:4px solid #2563eb;margin-bottom:24px;"><strong>Budget Formula:</strong> '+rfNetFormulaText(blockEntries)+'</div>';
  if(chartImages&&chartImages.length){
    h+='<h2 style="color:#7c3aed;font-size:16px;margin:28px 0 12px;">Forecast Visuals</h2>';
    chartImages.forEach(function(c){
      h+='<div style="margin-bottom:22px;page-break-inside:avoid;"><div style="font-size:12px;font-weight:800;color:#444;margin-bottom:8px;">'+c.title+'</div><img src="'+c.img+'" style="width:100%;max-width:980px;border:1px solid #e5e7eb;border-radius:10px;"></div>';
    });
  }
  function pdfTable(title, matrix, color){
    if(!matrix) return '';
    let t='<h2 style="color:'+color+';font-size:15px;margin:28px 0 10px;padding-bottom:6px;border-bottom:2px solid '+color+'33;">'+title+'</h2>';
    t+='<table style="width:100%;border-collapse:collapse;font-size:10px;margin-bottom:12px;">';
    t+='<tr style="background:'+color+';color:#fff;"><th style="padding:10px 12px;text-align:left;">'+matrix.rowLabel+'</th>';
    matrix.visibleMonths.forEach(function(m){ t+='<th style="padding:10px 8px;text-align:right;">'+MONTH_NAMES[m]+'</th>'; });
    t+='<th style="padding:10px 12px;text-align:right;">'+matrix.totalLabel+'</th></tr>';
    matrix.rows.forEach(function(rv,i){
      t+='<tr style="background:'+(i%2?'#fff':'#faf5ff')+';"><td style="padding:8px 12px;font-weight:600;border-bottom:1px solid #eee;">'+rv+'</td>';
      matrix.visibleMonths.forEach(function(m){
        const v=matrix.cells[rv+'|'+m]||0;
        t+='<td style="padding:8px;text-align:right;border-bottom:1px solid #eee;'+(matrix.isNet&&v<0?'color:#dc2626;font-weight:700;':'')+'">'+(v?rfFmtExport(v):'—')+'</td>';
      });
      t+='<td style="padding:8px 12px;font-weight:700;text-align:right;border-bottom:1px solid #eee;">'+rfFmtExport(matrix.rowTotals[rv]||0)+'</td></tr>';
    });
    t+='<tr style="background:'+color+'22;font-weight:800;"><td style="padding:10px 12px;">'+matrix.totalLabel+'</td>';
    matrix.visibleMonths.forEach(function(m){ t+='<td style="padding:10px 8px;text-align:right;">'+rfFmtExport(matrix.colTotals[m]||0)+'</td>'; });
    t+='<td style="padding:10px 12px;text-align:right;color:'+color+';">'+rfFmtExport(matrix.grandTotal)+'</td></tr></table>';
    return t;
  }
  h+=pdfTable('Pipeline Pivot', pipelineMat, '#15803d');
  blockEntries.forEach(function(e){ h+=pdfTable(e.block.name+' ('+e.block.op+')', e.matrix, e.block.color); });
  if(netMat) h+=pdfTable('Net Forecast', netMat, '#2563eb');
  h+='<p style="font-size:10px;color:#999;margin-top:32px;border-top:1px solid #eee;padding-top:12px;">'+APP_NAME+' · Confidential budget analysis</p></div>';
  return h;
}
async function rfCaptureChartImages(){
  const specs=[
    {id:'rfChartForecast',title:'12-Month Revenue Forecast'},
    {id:'rfChartWaterfall',title:'Budget Bridge'},
    {id:'rfChartScenario',title:'Scenario Comparison'},
    {id:'rfChartNetForecast',title:'Net Budget Forecast'},
    {id:'rfChartRunRate',title:'Run-Rate Build-Up'}
  ];
  const out=[];
  specs.forEach(function(s){
    const canvas=el(s.id);
    if(canvas&&canvas.width>0) out.push({title:s.title,img:canvas.toDataURL('image/png',1.0)});
  });
  return out;
}
async function rfExportPDF(){
  const JSPDF=(window.jspdf&&window.jspdf.jsPDF)?window.jspdf.jsPDF:(typeof jsPDF!=='undefined'?jsPDF:null);
  if(!JSPDF||typeof html2canvas==='undefined'){ alert('PDF libraries still loading — please try again in a moment.'); return; }
  const wasVisible=rfChartsVisible;
  if(!wasVisible){ rfChartsVisible=true; el('rfChartsSection').style.display='block'; el('rfChartsToggleText').textContent='Hide Forecast Charts'; }
  rfRenderCharts();
  rfResizeAllCharts();
  await new Promise(function(r){ setTimeout(r,700); });
  const chartImages=await rfCaptureChartImages();
  if(!wasVisible){ rfChartsVisible=false; el('rfChartsSection').style.display='none'; el('rfChartsToggleText').textContent='Show Forecast Charts'; }
  const wrap=document.createElement('div');
  wrap.style.cssText='position:fixed;left:-9999px;top:0;width:1100px;';
  wrap.innerHTML=rfBuildPdfReportHtml(chartImages);
  document.body.appendChild(wrap);
  const root=wrap.querySelector('#rfPdfRoot');
  try{
    const canvas=await html2canvas(root,{scale:2,useCORS:true,backgroundColor:'#ffffff',windowWidth:1100});
    const img=canvas.toDataURL('image/png');
    const pdf=new JSPDF('p','mm','a4');
    const pw=pdf.internal.pageSize.getWidth();
    const ph=pdf.internal.pageSize.getHeight();
    const margin=10;
    const imgW=pw-margin*2;
    const imgH=(canvas.height*imgW)/canvas.width;
    let heightLeft=imgH;
    let yPos=0;
    pdf.addImage(img,'PNG',margin,margin-yPos,imgW,imgH);
    heightLeft-=ph-margin*2;
    while(heightLeft>0){
      yPos+=ph-margin*2;
      pdf.addPage();
      pdf.addImage(img,'PNG',margin,margin-yPos,imgW,imgH);
      heightLeft-=ph-margin*2;
    }
    pdf.save('Revenue_Forecast_'+new Date().toISOString().split('T')[0]+'.pdf');
  }catch(err){
    alert('PDF export failed: '+(err.message||err));
  }finally{
    document.body.removeChild(wrap);
  }
}

// ── render: everything ───────────────────────────────────────────
function rfRenderAll(){
  rfRenderExcludedBanner();
  rfRenderPivot();
  rfRenderBlocks();
  rfRenderNetTable();
  rfRenderCascade();
  if(rfModalCtx) rfRenderModal();
  rfScheduleChartRender();
}

// ── TABLE 1: pivot ────────────────────────────────────────────────
function rfRenderPivot(){
  const container=el('rfPivotTable'); if(!container) return;
  const rowLabel=RF_ROW_DIMS.find(r=>r.key===rfRowDim).label;
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  set('rfPivotTitle', metricLabel+' by '+rowLabel+' & Month (Expected Activation)'+(rfHidePast?' — remaining year':''));
  const bids=rfActiveBids();
  if(!bids.length){ container.innerHTML='<div style="padding:2rem;text-align:center;color:var(--t3);">No data matches the current filters.</div>'; return; }
  const visibleMonths=[]; for(let m=0;m<12;m++) if(rfPivotMonthVisible(m)) visibleMonths.push(m);
  if(!visibleMonths.length){ container.innerHTML='<div style="padding:2rem;text-align:center;color:var(--t3);">No months to show — try turning off "Hide past months".</div>'; return; }
  const totalLabel = rfHidePast ? 'Remaining Total' : 'Grand Total';
  const rows=[...new Set(bids.map(b=>b[rfRowDim]).filter(v=>v&&v!=='—'))].sort();
  let html='<table class="rf-table"><thead><tr><th>'+rowLabel+'</th>';
  visibleMonths.forEach(m=>html+='<th>'+MONTH_NAMES[m]+'</th>');
  html+='<th class="rf-total-col">'+totalLabel+'</th></tr></thead><tbody>';
  const colTotals={}; visibleMonths.forEach(m=>colTotals[m]=0);
  let grandTotal=0;
  rows.forEach(function(rowVal){
    html+='<tr><td>'+rowVal+'</td>';
    let rowTotal=0;
    visibleMonths.forEach(function(m){
      const val=rfSum(rfGetCellBids(rowVal,m,null,false));
      colTotals[m]+=val; rowTotal+=val;
      html+= val ? '<td class="rf-cell-btn" onclick="rfOpenDrilldown('+JSON.stringify(rowVal)+','+m+',null)">'+rfFmtVal(val)+'</td>' : '<td class="rf-cell-empty">—</td>';
    });
    grandTotal+=rowTotal;
    html+= rowTotal ? '<td class="rf-total-col rf-cell-btn" onclick="rfOpenDrilldown('+JSON.stringify(rowVal)+',null,null)">'+rfFmtVal(rowTotal)+'</td></tr>' : '<td class="rf-total-col">—</td></tr>';
  });
  html+='</tbody><tfoot><tr><td>'+totalLabel+'</td>';
  visibleMonths.forEach(function(m){
    html+= colTotals[m] ? '<td class="rf-cell-btn" onclick="rfOpenDrilldown(null,'+m+',null)">'+rfFmtVal(colTotals[m])+'</td>' : '<td class="rf-cell-empty">—</td>';
  });
  html+= grandTotal ? '<td class="rf-total-col rf-cell-btn" onclick="rfOpenDrilldown(null,null,null)">'+rfFmtVal(grandTotal)+'</td></tr></tfoot></table>' : '<td class="rf-total-col">—</td></tr></tfoot></table>';
  container.innerHTML=html;
}

// ── TABLE 2: recurring revenue roll-forward (cascade) ────────────
function rfRenderCascade(){
  const container=el('rfCascadeTables'); if(!container) return;
  const bids=rfActiveBids();
  if(!bids.length){ container.innerHTML='<div style="padding:1rem;color:var(--t3);">No data matches the current filters.</div>'; return; }
  const years=[...new Set(bids.map(rfGetYear).filter(Boolean))].sort().filter(rfCascadeYearVisible);
  if(!years.length){ container.innerHTML='<div style="padding:1rem;color:var(--t3);">No upcoming years to show — try turning off "Hide past months".</div>'; return; }
  const totalLabel = rfHidePast ? 'Remaining Total' : 'Grand Total';
  let html='';
  years.forEach(function(year){
    const base=rfYearBase(bids,year);
    if(!base.some(v=>v)) return;
    const visibleMonths=[]; for(let m=0;m<12;m++) if(rfCascadeMonthVisible(year,m)) visibleMonths.push(m);
    if(!visibleMonths.length) return;

    html+='<div class="rf-cascade-block"><div class="rf-cascade-block-title">'+year+'</div>';
    html+='<div class="rf-panel"><div class="rf-table-scroll"><table class="rf-table"><thead><tr><th>Cohort</th>';
    visibleMonths.forEach(m=>html+='<th>'+MONTH_NAMES[m]+'</th>');
    html+='<th class="rf-total-col">Total</th></tr></thead><tbody>';

    html+='<tr><td>New This Month</td>';
    let baseVisTotal=0;
    visibleMonths.forEach(function(m){
      if(!rfCascadeOriginVisible(year,m)) return;
      baseVisTotal+=base[m];
      html+= base[m] ? '<td class="rf-cell-btn" onclick="rfOpenDrilldown(null,'+m+',\''+year+'\')">'+rfFmtVal(base[m])+'</td>' : '<td class="rf-cell-empty">—</td>';
    });
    html+='<td class="rf-total-col">'+rfFmtVal(baseVisTotal)+'</td></tr>';

    const colTotals={}; visibleMonths.forEach(m=>colTotals[m]=0);
    let grand=0;
    for(let origin=0; origin<11; origin++){
      if(!base[origin]) continue;
      if(!rfCascadeOriginVisible(year,origin)) continue;
      const rowCells={};
      for(let target=origin+1; target<12; target++) rowCells[target]=base[origin];
      let rowTotal=0, hasVisibleCell=false;
      visibleMonths.forEach(function(m){ if(rowCells[m]!=null){ hasVisibleCell=true; colTotals[m]+=rowCells[m]; rowTotal+=rowCells[m]; } });
      if(!hasVisibleCell) continue;
      grand+=rowTotal;
      html+='<tr><td>'+MONTH_NAMES[origin]+' cohort</td>';
      visibleMonths.forEach(function(m){
        html+= rowCells[m]!=null ? '<td class="rf-cell-btn" onclick="rfOpenDrilldown(null,'+origin+',\''+year+'\')">'+rfFmtVal(rowCells[m])+'</td>' : '<td class="rf-cell-empty">—</td>';
      });
      html+='<td class="rf-total-col rf-cell-btn" onclick="rfOpenDrilldown(null,'+origin+',\''+year+'\')">'+rfFmtVal(rowTotal)+'</td></tr>';
    }
    html+='</tbody><tfoot><tr><td>'+totalLabel+'</td>';
    visibleMonths.forEach(function(m){ html+='<td>'+(colTotals[m]?rfFmtVal(colTotals[m]):'—')+'</td>'; });
    html+='<td class="rf-total-col">'+rfFmtVal(grand)+'</td></tr></tfoot></table></div></div></div>';
  });
  container.innerHTML=html || '<div style="padding:1rem;color:var(--t3);">No recurring revenue to roll forward.</div>';
}

// ── excluded items banner ─────────────────────────────────────────
function rfRenderExcludedBanner(){
  const box=el('rfExcludedBanner'); if(!box) return;
  const excludedBids=rfVisibleBids().filter(b=>RF_EXCLUDED.has(b.id));
  if(!excludedBids.length){ box.innerHTML=''; return; }
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  const totalVal=rfSum(excludedBids);
  box.innerHTML='<div class="rf-excluded-banner" onclick="rfOpenExcludedList()">'+
    '<span>🚫 <strong>'+excludedBids.length+'</strong> item'+(excludedBids.length!==1?'s':'')+' excluded from this report ('+metricLabel+' '+rfFmtVal(totalVal)+') — click to review / restore</span>'+
    '<span style="font-size:.7rem;color:var(--t3);">Saved in this browser only</span></div>';
}
function rfOpenExcludedList(){
  rfModalCtx={rowVal:null,monthIdx:null,year:null,excludedOnly:true};
  rfModalSortKey='customerName'; rfModalSortDir=1; rfModalSearch='';
  rfRenderModal();
}

// ── drill-down modal ───────────────────────────────────────────────
function rfCellTitle(rowVal,monthIdx,year){
  const parts=[];
  if(rowVal!=null) parts.push(rowVal);
  if(monthIdx!=null) parts.push(MONTH_NAMES[monthIdx]+(year!=null?(' '+year):''));
  else if(year!=null) parts.push(year);
  return parts.length?parts.join(' — '):'All Opportunities';
}
function rfOpenDrilldown(rowVal,monthIdx,year){
  rfModalCtx={rowVal,monthIdx,year,excludedOnly:false};
  rfModalSortKey='customerName'; rfModalSortDir=1; rfModalSearch='';
  rfRenderModal();
}
function rfCloseDrilldown(){
  const ov=document.getElementById('rfModalOverlay'); if(ov) ov.remove();
  rfModalCtx=null;
}
function rfModalSort(key){
  if(rfModalSortKey===key) rfModalSortDir*=-1; else { rfModalSortKey=key; rfModalSortDir=1; }
  rfRenderModal();
}
function rfModalSearchInput(v){
  rfModalSearch=v.toLowerCase();
  const caret=document.activeElement===document.getElementById('rfModalSearchInput');
  rfRenderModal();
  if(caret){ const inp=document.getElementById('rfModalSearchInput'); if(inp){ inp.focus(); const len=inp.value.length; inp.setSelectionRange(len,len); } }
}
function rfToggleExclude(id){
  if(RF_EXCLUDED.has(id)) RF_EXCLUDED.delete(id); else RF_EXCLUDED.add(id);
  rfSaveExcluded();
  rfRenderAll();
}
function rfSortBids(list){
  const key=rfModalSortKey, dir=rfModalSortDir;
  return list.slice().sort(function(a,b){
    let av,bv;
    if(key==='expectedActivation'){ av=new Date(a[key]||0).getTime(); bv=new Date(b[key]||0).getTime(); }
    else if(['mrc','otc','tcv','pcv','gaPoints'].includes(key)){ av=num(a[key]); bv=num(b[key]); }
    else { av=(a[key]||'').toString().toLowerCase(); bv=(b[key]||'').toString().toLowerCase(); }
    if(av<bv) return -1*dir; if(av>bv) return 1*dir; return 0;
  });
}
function rfModalRowHtml(b,isRemoved){
  const tds=RF_MODAL_COLS.map(function(c){ const raw=b[c.key]; const v=c.fmt?c.fmt(raw,b):(raw||'—'); return '<td>'+v+'</td>'; }).join('');
  const btn= isRemoved
    ? '<td><button type="button" class="rf-action-btn restore" onclick="rfToggleExclude('+b.id+')">Restore</button></td>'
    : '<td><button type="button" class="rf-action-btn remove" onclick="rfToggleExclude('+b.id+')">Remove</button></td>';
  return '<tr'+(isRemoved?' class="rf-removed-row"':'')+'>'+tds+btn+'</tr>';
}
function rfModalHeadHtml(){
  return RF_MODAL_COLS.map(function(c){
    const dirIcon = rfModalSortDir===1
      ? '<svg viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"/></svg>'
      : '<svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>';
    return '<th class="'+(rfModalSortKey===c.key?'sorted':'')+'" onclick="rfModalSort(\''+c.key+'\')">'+c.label+dirIcon+'</th>';
  }).join('')+'<th></th>';
}
function rfRenderModal(){
  if(!rfModalCtx) return;
  const {rowVal,monthIdx,year,excludedOnly,blockId}=rfModalCtx;
  let all=rfGetCellBids(rowVal,monthIdx,year,true,blockId||null);
  if(rfModalSearch){
    all=all.filter(function(b){ return Object.values(b).some(function(v){ return String(v).toLowerCase().includes(rfModalSearch); }); });
  }
  const active = excludedOnly ? [] : rfSortBids(all.filter(b=>!RF_EXCLUDED.has(b.id)));
  const removed = rfSortBids(all.filter(b=>RF_EXCLUDED.has(b.id)));
  const title = excludedOnly ? 'All Excluded Items' : (blockId ? (RF_EXTRA_BLOCKS.find(b=>b.id===blockId)||{}).name+' — '+rfCellTitle(rowVal,monthIdx,year) : rfCellTitle(rowVal,monthIdx,year));
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  const totalVal = rfSum(active);
  const sub = excludedOnly
    ? removed.length+' item'+(removed.length!==1?'s':'')+' currently excluded across the whole report'
    : active.length+' active bid'+(active.length!==1?'s':'')+' · Total '+metricLabel+' '+rfFmtVal(totalVal)+(removed.length?(' · '+removed.length+' removed'):'');
  const colspan=RF_MODAL_COLS.length+1;

  let body='';
  if(!excludedOnly){
    body += '<div style="overflow-x:auto;"><table class="rf-modal-table"><thead><tr>'+rfModalHeadHtml()+'</tr></thead><tbody>'+
      (active.map(b=>rfModalRowHtml(b,false)).join('') || '<tr><td colspan="'+colspan+'" style="text-align:center;color:var(--t3);padding:1.5rem;">No bids match.</td></tr>')+
      '</tbody></table></div>';
  }
  if(removed.length){
    body += '<div class="rf-modal-section-title">'+(excludedOnly?'Excluded Items':'Removed From This Report')+' ('+removed.length+')</div>'+
      '<div style="overflow-x:auto;"><table class="rf-modal-table"><thead><tr>'+rfModalHeadHtml()+'</tr></thead><tbody>'+
      removed.map(b=>rfModalRowHtml(b,true)).join('')+
      '</tbody></table></div>';
  } else if(excludedOnly){
    body += '<div style="text-align:center;color:var(--t3);padding:2rem;">Nothing excluded right now.</div>';
  }

  const html=
    '<div class="rf-modal-overlay" id="rfModalOverlay" onclick="if(event.target===this) rfCloseDrilldown();">'+
      '<div class="rf-modal">'+
        '<div class="rf-modal-header">'+
          '<div><div class="rf-modal-title">'+title+'</div><div class="rf-modal-sub">'+sub+'</div></div>'+
          '<div class="rf-modal-close" onclick="rfCloseDrilldown()"><svg viewBox="0 0 24 24" style="width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div>'+
        '</div>'+
        '<div class="rf-modal-body">'+
          (excludedOnly ? '' : '<div class="rf-modal-toolbar"><input type="text" id="rfModalSearchInput" class="rf-modal-search" placeholder="Search customer, AM, status..." oninput="rfModalSearchInput(this.value)" value="'+rfModalSearch+'"><div class="rf-modal-count">'+active.length+' shown</div></div>')+
          body+
        '</div>'+
      '</div>'+
    '</div>';

  const wrapper=document.createElement('div'); wrapper.innerHTML=html;
  const newOverlay=wrapper.firstElementChild;
  const existing=document.getElementById('rfModalOverlay');
  if(existing) existing.replaceWith(newOverlay); else document.body.appendChild(newOverlay);
}
document.addEventListener('keydown',function(e){ if(e.key==='Escape' && rfModalCtx) rfCloseDrilldown(); });

// ── FORECAST CHARTS (BA / CEO / budget-level view) ────────────────
function rfToggleCharts(){
  rfChartsVisible=!rfChartsVisible;
  el('rfChartsSection').style.display=rfChartsVisible?'block':'none';
  el('rfChartsToggleText').textContent=rfChartsVisible?'Hide Forecast Charts':'Show Forecast Charts';
  if(rfChartsVisible) rfScheduleChartRender();
}
function rfScheduleChartRender(){
  if(!rfChartsVisible) return;
  requestAnimationFrame(function(){
    requestAnimationFrame(function(){
      rfRenderCharts();
      rfResizeAllCharts();
    });
  });
}
function rfResizeAllCharts(){
  Object.keys(CHARTS).forEach(function(k){
    if(k.indexOf('rf')===0 && CHARTS[k] && typeof CHARTS[k].resize==='function'){
      try{ CHARTS[k].resize(); }catch(e){}
    }
  });
}
function rfSafeChart(key, fn){
  try{ fn(); }catch(err){
    console.error('Chart render failed ('+key+'):', err);
    destroyChart(key);
  }
}
function rfConfidenceFor(bids){
  const notLost=bids.filter(b=>!STATUS_LOST.includes(b.status));
  const committed=bids.filter(b=>STATUS_WON.includes(b.status));
  const bestCaseVal=notLost.reduce((s,b)=>s+rfMetricVal(b),0);
  const committedVal=committed.reduce((s,b)=>s+rfMetricVal(b),0);
  const weightedVal=notLost.reduce(function(s,b){ const frac=STATUS_WON.includes(b.status)?1:probToFraction(b.closureProb); return s+rfMetricVal(b)*frac; },0);
  return {bestCaseVal,committedVal,weightedVal};
}
function rfBuildRunRateData(){
  const bids=rfActiveBids();
  const years=[...new Set(bids.map(rfGetYear).filter(Boolean))].sort();
  if(!years.length) return null;
  const year = years.find(y=>Number(y)>=rfCurrentYear) || years[0];
  const base=rfYearBase(bids,year);
  const cumulative=[]; let run=0;
  for(let m=0;m<12;m++){ run+=base[m]; cumulative.push(run); }
  const visibleMonths=[]; for(let m=0;m<12;m++) if(rfCascadeMonthVisible(year,m)) visibleMonths.push(m);
  return {year,base,cumulative,visibleMonths};
}
function rfBuildForecastMonthlyData(){
  const bids=rfActiveBids();
  const visibleMonths=[]; for(let m=0;m<12;m++) if(rfPivotMonthVisible(m)) visibleMonths.push(m);
  if(!visibleMonths.length) return null;
  const pipeline=visibleMonths.map(function(m){ return rfSum(bids.filter(function(b){ return rfGetMonthIdx(b)===m; })); });
  const committed=visibleMonths.map(function(m){
    return rfSum(bids.filter(function(b){ return rfGetMonthIdx(b)===m&&STATUS_WON.includes(b.status); }));
  });
  const weighted=visibleMonths.map(function(m){
    return bids.filter(function(b){ return rfGetMonthIdx(b)===m&&!STATUS_LOST.includes(b.status); })
      .reduce(function(s,b){ return s+rfMetricVal(b)*(STATUS_WON.includes(b.status)?1:probToFraction(b.closureProb)); },0);
  });
  const pipelineMat=rfBuildMatrix(bids);
  const netMat=rfComputeNetMatrix(pipelineMat, rfGetBlockMatrices());
  const net=netMat?visibleMonths.map(function(m){ return netMat.colTotals[m]||0; }):pipeline;
  return {labels:visibleMonths.map(function(m){ return MONTH_NAMES[m]; }),pipeline,committed,weighted,net,visibleMonths};
}
function rfBuildWaterfallData(){
  const conf=rfConfidenceFor(rfActiveBids());
  const blockEntries=rfGetBlockMatrices();
  let subtractTotal=0, addTotal=0;
  blockEntries.forEach(function(e){
    if(!e.matrix) return;
    if(e.op==='subtract') subtractTotal+=e.matrix.grandTotal||0;
    if(e.op==='add') addTotal+=e.matrix.grandTotal||0;
  });
  const pipeline=conf.bestCaseVal;
  const net=pipeline+addTotal-subtractTotal;
  const items=[{label:'Pipeline',value:pipeline,color:'#15803d'}];
  blockEntries.forEach(function(e){
    if(!e.matrix||e.op==='none') return;
    const v=e.matrix.grandTotal||0;
    items.push({label:e.block.name+(e.op==='subtract'?' (−)':' (+)'),value:e.op==='subtract'?-v:v,color:e.block.color});
  });
  items.push({label:'Net Forecast',value:net,color:'#2563eb'});
  return items;
}
function rfRenderKpis(){
  const grid=el('rfKpiGrid'); if(!grid) return;
  const bids=rfActiveBids();
  const notLost=bids.filter(b=>!STATUS_LOST.includes(b.status));
  const committed=bids.filter(b=>STATUS_WON.includes(b.status));
  const conf=rfConfidenceFor(bids);
  const runData=rfBuildRunRateData();
  const excludedBids=rfVisibleBids().filter(b=>RF_EXCLUDED.has(b.id));
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  const cards=[
    {label:'Total Active Pipeline', value:rfFmtVal(conf.bestCaseVal), sub:notLost.length+' opportunities (excl. dead)', color:'var(--grad)'},
    {label:'Committed (Won / Billed)', value:rfFmtVal(conf.committedVal), sub:committed.length+' opportunities locked in', color:'#16a34a'},
    {label:'Weighted Forecast', value:rfFmtVal(conf.weightedVal), sub:'Probability-adjusted '+metricLabel, color:'#f59e0b'},
    {label:'Run-Rate by Year End', value: runData?rfFmtVal(runData.cumulative[11]):'—', sub: runData?('Cumulative '+metricLabel+' live by Dec '+runData.year):'No data', color:'#4c6fff'},
    {label:'Excluded From Report', value:String(excludedBids.length), sub:excludedBids.length?(rfFmtVal(rfSum(excludedBids))+' '+metricLabel+' set aside'):'Nothing excluded', color:'#6b7280'},
  ];
  grid.innerHTML=cards.map(function(k){ return '<div class="rf-kpi-card" style="--kpi-color:'+k.color+';"><div class="rf-kpi-label">'+k.label+'</div><div class="rf-kpi-value">'+k.value+'</div><div class="rf-kpi-sub">'+k.sub+'</div></div>'; }).join('');
}
function rfCenterTextPlugin(id,c,bigText,smallText){
  return {id,beforeDraw(chart){
    const{ctx,chartArea:{width,height,left,top}}=chart;
    ctx.save();
    ctx.font='bold 21px Inter';
    ctx.fillStyle=c.text==='rgba(255,255,255,0.6)'?'rgba(255,255,255,0.92)':'rgba(20,10,35,0.88)';
    ctx.textAlign='center';ctx.textBaseline='middle';
    ctx.fillText(bigText,left+width/2,top+height/2-10);
    ctx.font='600 10.5px Inter';ctx.fillStyle=c.text;
    ctx.fillText(smallText,left+width/2,top+height/2+13);
    ctx.restore();
  }};
}
function rfRenderChartForecast(){
  destroyChart('rfForecast');
  const canvas=el('rfChartForecast'); if(!canvas) return;
  const data=rfBuildForecastMonthlyData(); if(!data) return;
  const c=getChartColors();
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  CHARTS.rfForecast=new Chart(canvas,{
    type:'line',
    data:{labels:data.labels,datasets:[
      {label:'Committed (Won/Billed)',data:data.committed,borderColor:'#15803d',backgroundColor:'rgba(21,128,61,.08)',fill:true,tension:.35,borderWidth:2.5,pointRadius:3},
      {label:'Weighted Forecast',data:data.weighted,borderColor:'#d97706',backgroundColor:'rgba(217,119,6,.06)',fill:true,tension:.35,borderWidth:2.5,pointRadius:3},
      {label:'Full Pipeline',data:data.pipeline,borderColor:c.p1,borderDash:[6,4],fill:false,tension:.35,borderWidth:2,pointRadius:2},
      {label:'Net Budget Forecast',data:data.net,borderColor:'#2563eb',backgroundColor:'rgba(37,99,235,.12)',fill:true,tension:.35,borderWidth:3,pointRadius:4}
    ]},
    options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
      plugins:{
        legend:{position:'top',align:'end',labels:{color:c.text,font:{size:11,weight:'600'},usePointStyle:true,padding:14}},
        tooltip:{backgroundColor:'rgba(0,0,0,.85)',padding:12,cornerRadius:10,callbacks:{label:ctx=>' '+ctx.dataset.label+': '+rfFmtVal(ctx.parsed.y)+' '+metricLabel}}
      },
      scales:{
        x:{ticks:{color:c.text,font:{size:11,weight:'600'}},grid:{display:false}},
        y:{ticks:{color:c.text,callback:v=>rfFmtVal(v)},grid:{color:c.grid},border:{dash:[4,4]},beginAtZero:true}
      }}});
}
function rfRenderChartWaterfall(){
  destroyChart('rfWaterfall');
  const canvas=el('rfChartWaterfall'); if(!canvas) return;
  const items=rfBuildWaterfallData(); if(!items||!items.length) return;
  const c=getChartColors();
  const labels=items.map(function(i){ return i.label; });
  const colors=items.map(function(i){ return i.color; });
  CHARTS.rfWaterfall=new Chart(canvas,{
    type:'bar',
    data:{labels,datasets:[{label:'Budget Bridge',data:items.map(function(i){ return i.value; }),backgroundColor:colors,borderRadius:8,borderSkipped:false,barPercentage:.55}]},
    options:{responsive:true,maintainAspectRatio:false,
      plugins:{
        legend:{display:false},
        tooltip:{backgroundColor:'rgba(0,0,0,.85)',padding:12,cornerRadius:10,callbacks:{label:ctx=>' '+rfFmtVal(ctx.parsed.y)}}
      },
      scales:{
        x:{ticks:{color:c.text,font:{size:10,weight:'600'},maxRotation:45,minRotation:0},grid:{display:false}},
        y:{ticks:{color:c.text,callback:v=>rfFmtVal(v)},grid:{color:c.grid},border:{dash:[4,4]}}
      }}});
}
function rfRenderChartRunRate(){
  destroyChart('rfRunRate');
  const canvas=el('rfChartRunRate'); if(!canvas) return;
  const data=rfBuildRunRateData();
  if(!data || !data.visibleMonths.length) return;
  const c=getChartColors();
  const ctx=canvas.getContext('2d');
  const lineGrad=ctx.createLinearGradient(0,0,0,320);
  lineGrad.addColorStop(0,c.p2a+'0.38)'); lineGrad.addColorStop(1,c.p2a+'0.02)');
  const barGrad=ctx.createLinearGradient(0,0,0,320);
  barGrad.addColorStop(0,c.p1a+'0.95)'); barGrad.addColorStop(1,c.p1a+'0.45)');
  const labels=data.visibleMonths.map(m=>MONTH_NAMES[m]+" '"+String(data.year).slice(2));
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  CHARTS.rfRunRate=new Chart(canvas,{
    type:'bar',
    data:{labels,datasets:[
      {type:'bar',label:'New This Month',data:data.visibleMonths.map(m=>data.base[m]),backgroundColor:barGrad,borderRadius:8,borderSkipped:false,order:2,barPercentage:.6,categoryPercentage:.7},
      {type:'line',label:'Cumulative Run-Rate',data:data.visibleMonths.map(m=>data.cumulative[m]),borderColor:c.p2,backgroundColor:lineGrad,fill:true,tension:.4,pointRadius:4,pointHoverRadius:7,pointBackgroundColor:c.p2,pointBorderColor:'#fff',pointBorderWidth:2,borderWidth:3,order:1},
    ]},
    options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
      plugins:{
        legend:{position:'top',align:'end',labels:{color:c.text,font:{size:12,weight:'600'},usePointStyle:true,pointStyleWidth:10,padding:16,boxHeight:8}},
        tooltip:{backgroundColor:'rgba(0,0,0,.85)',padding:13,cornerRadius:10,titleFont:{size:12,weight:'700'},bodyFont:{size:12},callbacks:{label:ctx=>' '+ctx.dataset.label+': '+rfFmtVal(ctx.parsed.y)+' '+metricLabel}}
      },
      scales:{
        x:{ticks:{color:c.text,font:{size:11,weight:'600'}},grid:{display:false}},
        y:{ticks:{color:c.text,font:{size:11},callback:v=>rfFmtVal(v)},grid:{color:c.grid},border:{dash:[4,4]},beginAtZero:true}
      }}});
}
function rfRenderChartConfidence(){
  destroyChart('rfConfidence');
  const canvas=el('rfChartConfidence'); if(!canvas) return;
  const d=rfConfidenceFor(rfVisibleBidsForCharts());
  const c=getChartColors();
  const rows=[
    {label:'Committed (Won / Billed)',val:d.committedVal,color:'#16a34a'},
    {label:'Weighted Forecast',val:d.weightedVal,color:c.p1},
    {label:'Best Case (All Active)',val:d.bestCaseVal,color:c.p2},
  ];
  CHARTS.rfConfidence=new Chart(canvas,{type:'bar',plugins:[dataLabelPlugin],
    data:{labels:rows.map(r=>r.label),
      datasets:[{data:rows.map(r=>r.val),backgroundColor:rows.map(r=>r.color),borderRadius:8,borderSkipped:false,barPercentage:.55,categoryPercentage:.7}]},
    options:{indexAxis:'y',responsive:true,maintainAspectRatio:false,
      plugins:{legend:{display:false},tooltip:{backgroundColor:'rgba(0,0,0,.85)',padding:13,cornerRadius:10,callbacks:{label:ctx=>' '+rfFmtVal(ctx.parsed.x)}}},
      scales:{
        x:{ticks:{color:c.text,font:{size:11},callback:v=>rfFmtVal(v)},grid:{color:c.grid},border:{dash:[4,4]},beginAtZero:true},
        y:{ticks:{color:c.text,font:{size:12,weight:'600'}},grid:{display:false}}
      }}});
}
function rfRenderChartGroup(){
  destroyChart('rfGroup');
  const canvas=el('rfChartGroup'); if(!canvas) return;
  const bids=rfVisibleBidsForCharts();
  const rowLabel=RF_ROW_DIMS.find(r=>r.key===rfRowDim).label;
  set('rfGroupChartTitle','Pipeline by '+rowLabel);
  const groups={};
  bids.forEach(function(b){ const k=b[rfRowDim]||'—'; groups[k]=(groups[k]||0)+rfMetricVal(b); });
  let entries=Object.entries(groups).filter(function(e){return e[1]>0;}).sort((a,b)=>b[1]-a[1]);
  if(entries.length>7){ const rest=entries.slice(7).reduce((s,e)=>s+e[1],0); entries=entries.slice(0,7); if(rest>0) entries.push(['Other',rest]); }
  const c=getChartColors();
  const palette=['#a855f7','#c724b1','#4c6fff','#06b6d4','#16a34a','#f59e0b','#ef4444','#6b7280'];
  const total=entries.reduce((s,e)=>s+e[1],0);
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  CHARTS.rfGroup=new Chart(canvas,{type:'doughnut',plugins:[rfCenterTextPlugin('rfGroupCenter',c,rfFmtVal(total),'Total '+metricLabel)],
    data:{labels:entries.map(e=>e[0]),datasets:[{data:entries.map(e=>e[1]),backgroundColor:palette,borderWidth:4,borderColor:'var(--bg-card)',hoverOffset:12}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'62%',
      plugins:{
        legend:{position:'right',labels:{color:c.text,font:{size:11,weight:'600'},padding:10,usePointStyle:true,pointStyleWidth:10}},
        tooltip:{backgroundColor:'rgba(0,0,0,.85)',padding:13,cornerRadius:10,callbacks:{label:ctx=>{const pct=total?(ctx.parsed/total*100).toFixed(1):'0';return ' '+ctx.label+': '+rfFmtVal(ctx.parsed)+' ('+pct+'%)';}}}
      }}});
}
function rfRenderChartStatusMix(){
  destroyChart('rfStatusMix');
  const canvas=el('rfChartStatusMix'); if(!canvas) return;
  const bids=rfVisibleBidsForCharts();
  const realized=rfSum(bids.filter(b=>STATUS_WON.includes(b.status)));
  const pipeline=rfSum(bids.filter(b=>STATUS_IP.includes(b.status)));
  const dead=rfSum(bids.filter(b=>STATUS_LOST.includes(b.status)));
  const vals=[realized,pipeline,dead];
  const c=getChartColors();
  const total=vals.reduce((a,b)=>a+b,0);
  const pctRealized=total?((realized/total)*100).toFixed(0):'0';
  CHARTS.rfStatusMix=new Chart(canvas,{type:'doughnut',plugins:[rfCenterTextPlugin('rfStatusCenter',c,pctRealized+'%','Realized')],
    data:{labels:['Realized (Won/Billed)','Active Pipeline','Dead (Lost/Cancelled/No Bid)'],
      datasets:[{data:vals,backgroundColor:['#16a34a','#a855f7','#6b7280'],borderWidth:4,borderColor:'var(--bg-card)',hoverOffset:12}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'62%',
      plugins:{
        legend:{position:'right',labels:{color:c.text,font:{size:11,weight:'600'},padding:10,usePointStyle:true,pointStyleWidth:10}},
        tooltip:{backgroundColor:'rgba(0,0,0,.85)',padding:13,cornerRadius:10,callbacks:{label:ctx=>{const pct=total?(ctx.parsed/total*100).toFixed(1):'0';return ' '+ctx.label+': '+rfFmtVal(ctx.parsed)+' ('+pct+'%)';}}}
      }}});
}
function rfRenderChartProb(){
  destroyChart('rfProb');
  const canvas=el('rfChartProb'); if(!canvas) return;
  const bids=rfVisibleBidsForCharts().filter(b=>!STATUS_LOST.includes(b.status));
  const vals=PROB_ORDER.map(p=>rfSum(bids.filter(b=>b.closureProb===p)));
  const counts=PROB_ORDER.map(p=>bids.filter(b=>b.closureProb===p).length);
  const c=getChartColors();
  const palette=['#ef4444','#f97316','#eab308','#10b981','#6366f1'];
  const total=vals.reduce((a,b)=>a+b,0);
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  CHARTS.rfProb=new Chart(canvas,{type:'doughnut',plugins:[rfCenterTextPlugin('rfProbCenter',c,rfFmtVal(total),'Total '+metricLabel)],
    data:{labels:PROB_ORDER.map((p,i)=>p+' — '+counts[i]+' bid'+(counts[i]!==1?'s':'')+' — '+rfFmtVal(vals[i])),
      datasets:[{data:vals,backgroundColor:palette,borderWidth:4,borderColor:'var(--bg-card)',hoverOffset:14}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'62%',
      plugins:{
        legend:{position:'right',labels:{color:c.text,font:{size:10.5,weight:'600'},padding:10,usePointStyle:true,pointStyleWidth:10,
          generateLabels:chart=>chart.data.labels.map((lbl,i)=>({text:lbl,fillStyle:palette[i],strokeStyle:palette[i],fontColor:c.text,hidden:false,index:i}))
        }},
        tooltip:{backgroundColor:'rgba(0,0,0,.85)',padding:13,cornerRadius:10,callbacks:{label:ctx=>{const pct=total?(ctx.parsed/total*100).toFixed(1):'0';return [' '+rfFmtVal(ctx.parsed)+' ('+pct+'%)',' '+counts[ctx.dataIndex]+' bid(s)'];}}}
      }}});
}
function rfRenderChartScenario(){
  destroyChart('rfScenario');
  const canvas=el('rfChartScenario'); if(!canvas) return;
  const pipelineMat=rfBuildMatrix(rfActiveBids());
  if(!pipelineMat) return;
  const blockEntries=rfGetBlockMatrices();
  const netMat=rfComputeNetMatrix(pipelineMat, blockEntries);
  const c=getChartColors();
  const labels=pipelineMat.visibleMonths.map(m=>MONTH_NAMES[m]);
  const datasets=[{
    type:'bar', label:'Pipeline', data:pipelineMat.visibleMonths.map(m=>pipelineMat.colTotals[m]||0),
    backgroundColor:c.p1a+'0.85)', borderRadius:6, barPercentage:.65, categoryPercentage:.72
  }];
  const palette=['#ef4444','#f59e0b','#06b6d4','#8b5cf6','#ec4899'];
  blockEntries.forEach(function(e,i){
    if(!e.matrix||e.op==='none') return;
    datasets.push({
      type:'bar',
      label:e.block.name+' ('+(e.op==='add'?'+':'−')+')',
      data:e.matrix.visibleMonths.map(function(m){ return e.matrix.colTotals[m]||0; }),
      backgroundColor:palette[i%palette.length]+'cc', borderRadius:6, barPercentage:.65, categoryPercentage:.72
    });
  });
  if(netMat){
    datasets.push({
      type:'line', label:'Net Forecast', data:netMat.visibleMonths.map(m=>netMat.colTotals[m]||0),
      borderColor:'#2563eb', backgroundColor:'rgba(37,99,235,.12)', fill:true,
      tension:.35, pointRadius:5, pointBackgroundColor:'#2563eb', borderWidth:3, order:0
    });
  }
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  CHARTS.rfScenario=new Chart(canvas,{
    type:'bar',
    data:{labels,datasets},
    options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
      plugins:{
        legend:{position:'top',align:'end',labels:{color:c.text,font:{size:11,weight:'600'},usePointStyle:true,padding:12}},
        tooltip:{backgroundColor:'rgba(0,0,0,.85)',padding:12,cornerRadius:10,callbacks:{label:ctx=>' '+ctx.dataset.label+': '+rfFmtVal(ctx.parsed.y)+' '+metricLabel}}
      },
      scales:{
        x:{ticks:{color:c.text,font:{size:11,weight:'600'}},grid:{display:false}},
        y:{ticks:{color:c.text,callback:v=>rfFmtVal(v)},grid:{color:c.grid},border:{dash:[4,4]},beginAtZero:true}
      }}});
}
function rfRenderChartNetForecast(){
  destroyChart('rfNetForecast');
  const canvas=el('rfChartNetForecast'); if(!canvas) return;
  const pipelineMat=rfBuildMatrix(rfActiveBids());
  if(!pipelineMat) return;
  const netMat=rfComputeNetMatrix(pipelineMat, rfGetBlockMatrices());
  const c=getChartColors();
  const src=netMat||pipelineMat;
  const labels=src.visibleMonths.map(m=>MONTH_NAMES[m]);
  const vals=src.visibleMonths.map(m=>src.colTotals[m]||0);
  let cum=0; const cumulative=vals.map(function(v){ cum+=v; return cum; });
  const barColors=vals.map(function(v){ return v>=0?'rgba(22,163,74,.75)':'rgba(239,68,68,.75)'; });
  const metricLabel=RF_METRICS.find(m=>m.key===rfMetric).label;
  const barLabel=netMat?('Net Monthly '+metricLabel):('Pipeline Monthly '+metricLabel);
  const lineLabel=netMat?'Cumulative Net':'Cumulative Pipeline';
  CHARTS.rfNetForecast=new Chart(canvas,{
    type:'bar',
    data:{labels,datasets:[
      {type:'bar',label:barLabel,data:vals,backgroundColor:barColors,borderRadius:8,borderSkipped:false,order:2,barPercentage:.55},
      {type:'line',label:lineLabel,data:cumulative,borderColor:'#2563eb',backgroundColor:'rgba(37,99,235,.1)',fill:true,tension:.4,pointRadius:4,borderWidth:3,order:1}
    ]},
    options:{responsive:true,maintainAspectRatio:false,interaction:{mode:'index',intersect:false},
      plugins:{
        legend:{position:'top',align:'end',labels:{color:c.text,font:{size:11,weight:'600'},usePointStyle:true,padding:12}},
        tooltip:{backgroundColor:'rgba(0,0,0,.85)',padding:12,cornerRadius:10,callbacks:{label:ctx=>' '+ctx.dataset.label+': '+rfFmtVal(ctx.parsed.y)}}
      },
      scales:{
        x:{ticks:{color:c.text,font:{size:11,weight:'600'}},grid:{display:false}},
        y:{ticks:{color:c.text,callback:v=>rfFmtVal(v)},grid:{color:c.grid},border:{dash:[4,4]},beginAtZero:true}
      }}});
}
function rfRenderCharts(){
  if(!rfChartsVisible) return;
  rfRenderKpis();
  rfSafeChart('rfForecast', rfRenderChartForecast);
  rfSafeChart('rfWaterfall', rfRenderChartWaterfall);
  rfSafeChart('rfRunRate', rfRenderChartRunRate);
  rfSafeChart('rfScenario', rfRenderChartScenario);
  rfSafeChart('rfNetForecast', rfRenderChartNetForecast);
  rfSafeChart('rfConfidence', rfRenderChartConfidence);
  rfSafeChart('rfGroup', rfRenderChartGroup);
  rfSafeChart('rfStatusMix', rfRenderChartStatusMix);
  rfSafeChart('rfProb', rfRenderChartProb);
}

// ══════════════════════════════════════════════════════════════════
//  INIT
// ══════════════════════════════════════════════════════════════════
window.addEventListener('load',function(){
  el('landingPage').classList.add('is-visible');
  try{
    const bt=localStorage.getItem('glk_base_theme')||'magenta';
    const dm=localStorage.getItem('glk_dark_mode')==='true';
    const sel=el('colorSchemeSelector'); if(sel) sel.value=bt;
    applyTheme(bt,dm);
  }catch(e){}
  initAccess();
});
</script></body>
</html>
