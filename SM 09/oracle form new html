                        idx: idx
                    });
                }
            });
            if (!workItems.length) {
                alert_("bulkAlert", "error", "Nothing to submit — all rows are marked delete/remove or the file is empty.");
                return;
            }
            var target = document.getElementById("bulkTarget").value;
            var listName = target === "master" ? "Master Data" : "Oracle Activation";
            var metaType = target === "master" ? "SP.Data.Master_x0020_DataListItem" : "SP.Data.Oracle_x0020_ActivationListItem";
            document.getElementById("bulkSubmitBtn").disabled = true;
            document.getElementById("bulkProgress").style.display = "block";
            var done = 0,
                errors = 0,
                total = workItems.length,
                errorDetails = [];

            function updateProg() {
                var pct = Math.round((done + errors) / total * 100);
                document.getElementById("progressBar").style.width = pct + "%";
                document.getElementById("progressBar").textContent = pct + "%";
                document.getElementById("progressText").textContent = "Processed: " + (done + errors) + "/" + total + " | Success: " + done + " | Errors: " + errors;
            }
            updateProg();

            function buildPayload(r) {
                if (target === "master") {
                    return {
                        Title: r.Entity || null,
                        End_x0020_User_x0020_Email: r.Email || null,
                        End_x0020_User_x0020_First_x0020: r.FirstName || null,
                        End_x0020_User_x0020_First_x00200: r.LastName || null,
                        Subscriber: r.Subscriber || null,
                        Sub_x0020_Level: r.SubLevel || null,
                        L20_x0020_AC: r.L20AC || null,
                        MSISDN: r.MSISDN || null,
                        Tariff_x0020__x0028_Rate_x0020_P: r.Tariff || null,
                        Current_Status: r.Status || null,
                        Device_x0020_Model: r.DeviceModel || null,
                        Device_x0020_Offer: r.DeviceOffer || null,
                        Expiry_x0020_Date: r.ExpiryDate || null,
                        SIM_x0020_Serial_x0020__x0028_IC: r.SIMSerial || null,
                        Activation_x0020_Date_x0020__x20: r.ActivationDateSIM || null,
                        Contract_x0020_Start_x0020_Date_: r.ContractStartSIM || null,
                        Contract_x0020_End_x0020_Date_x0: r.ContractEndSIM || null,
                        Contract_x0020_Start_x0020_Date_0: r.ContractStartHandset || null,
                        Contract_x0020_End_x0020_Date_x00: r.ContractEndHandset || null,
                        DeactivationDate_x0020_Sim: r.DeactivationDateSIM || null,
                        EmailLower: (r.Email || "").toLowerCase()
                    };
                }
                return {
                    Title: r.Email || null,
                    End_x0020_User_x0020_First_x0020: r.FirstName || null,
                    End_x0020_User_x0020_Last_x0020_: r.LastName || null,
                    Entity: r.Entity || null,
                    Subscriber: r.Subscriber || null,
                    Account_x0020_Code: r.SubLevel || null,
                    Transaction_x0020_Type: r.TransactionType || null,
                    PO_x0020_No: r.PONo || null,
                    PO_x0020_Date: r.PODate || null,
                    Activity_x0020_Ref_x002e__x0020_: r.ActivityRefNo || null,
                    Activity_x0020_Date: r.ActivityDate || null,
                    SR_x0020_Date: r.SRDate || null,
                    SO_x0020_No: r.SONo || null,
                    SO_x0020_Creation_x0020_Date: r.SOCreationDate || null,
                    Ship_x0020_To: r.ShipTo || null,
                    Activity_x0020_Ref_x002e__x0020_0: r.ActivityRefNo2 || null,
                    Activity_x0020_Date_x0020_2: r.ActivityDate2 || null,
                    SO_x0020_No_x0020_2: r.SONo2 || null,
                    SO_x0020_Creation_x0020_Date_x00: r.SOCreationDate2 || null,
                    MSISDN: r.MSISDN || null,
                    SIM_x0020_Serial_x0020__x0028_IC: r.SIMSerial || null,
                    SIM_x0020_Type: r.SIMType || null,
                    Tariff_x0020__x0028_Rate_x0020_P: r.Tariff || null,
                    Add_x002d_ons: r.Addons || null,
                    Activation_x0020_Date_x0020__x20: r.ActivationDateSIM || null,
                    Contract_x0020_Start_x0020_Date_: r.ContractStartSIM || null,
                    Contract_x0020_End_x0020_Date_x0: r.ContractEndSIM || null,
                    Device_x0020__x0028_Brand_x0029_: r.DeviceBrand || null,
                    Device_x0020_Subcategory: r.DeviceSubcat || null,
                    Capacity: r.Capacity || null,
                    IMEI: r.IMEI || null,
                    Quantity: r.Quantity || null,
                    Activation_x0020_Date_x0020__x200: r.ActivationDateHandset || null,
                    Contract_x0020_End_x0020_Date_x00: r.ContractEndHandset || null,
                    Future_x0020_Termination_x0020_D: r.FutureTermDate || null,
                    Status: r.Status || null,
                    Reason: r.Reason || null,
                    Pending_x0020_With: r.PendingWith || null,
                    Completed_x0020_Date: r.CompletedDate || null,
                    Remarks: r.Remarks || null,
                    EmailLower: (r.Email || "").toLowerCase()
                };
            }

            function postItem(payload, cb) {
                payload.__metadata = {
                    type: metaType
                };
                var x = new XMLHttpRequest();
                x.open("POST", getSite() + "/_api/web/lists/getbytitle('" + listName + "')/items", true);
                x.setRequestHeader("Accept", "application/json;odata=verbose");
                x.setRequestHeader("Content-Type", "application/json;odata=verbose");
                x.setRequestHeader("X-RequestDigest", getDigest());
                x.onreadystatechange = function() {
                    if (x.readyState === 4) {
                        var ok = x.status >= 200 && x.status < 300;
                        cb(ok, ok ? null : parseSharePointError(x.responseText, x.status));
                    }
                };
                x.send(JSON.stringify(payload));
            }

            function patchItem(id, payload, cb) {
                var x1 = new XMLHttpRequest();
                x1.open("GET", getSite() + "/_api/web/lists/getbytitle('" + listName + "')/items(" + id + ")", true);
                x1.setRequestHeader("Accept", "application/json;odata=verbose");
                x1.onreadystatechange = function() {
                    if (x1.readyState === 4) {
                        if (x1.status >= 200 && x1.status < 300) {
                            var etag = x1.getResponseHeader("ETag");
                            var sparsePayload = {
                                __metadata: {
                                    type: metaType
                                }
                            };
                            for (var key in payload) {
                                if (payload.hasOwnProperty(key) && key !== "__metadata" && payload[key] !== null && payload[key] !== "" && payload[key] !== undefined) {
                                    sparsePayload[key] = payload[key];
                                }
                            }
                            var x2 = new XMLHttpRequest();
                            x2.open("PATCH", getSite() + "/_api/web/lists/getbytitle('" + listName + "')/items(" + id + ")", true);
                            x2.setRequestHeader("Accept", "application/json;odata=verbose");
                            x2.setRequestHeader("Content-Type", "application/json;odata=verbose");
                            x2.setRequestHeader("X-RequestDigest", getDigest());
                            x2.setRequestHeader("If-Match", etag);
                            x2.onreadystatechange = function() {
                                if (x2.readyState === 4) {
                                    var ok = x2.status >= 200 && x2.status < 300;
                                    cb(ok, ok ? null : parseSharePointError(x2.responseText, x2.status));
                                }
                            };
                            x2.send(JSON.stringify(sparsePayload));
                        } else {
                            cb(false, parseSharePointError(x1.responseText, x1.status));
                        }
                    }
                };
                x1.send();
            }

            function deleteItem(id, cb) {
                var x1 = new XMLHttpRequest();
                x1.open("GET", getSite() + "/_api/web/lists/getbytitle('" + listName + "')/items(" + id + ")", true);
                x1.setRequestHeader("Accept", "application/json;odata=verbose");
                x1.onreadystatechange = function() {
                    if (x1.readyState === 4) {
                        if (x1.status >= 200 && x1.status < 300) {
                            var etag = x1.getResponseHeader("ETag");
                            var x2 = new XMLHttpRequest();
                            x2.open("DELETE", getSite() + "/_api/web/lists/getbytitle('" + listName + "')/items(" + id + ")", true);
                            x2.setRequestHeader("Accept", "application/json;odata=verbose");
                            x2.setRequestHeader("X-RequestDigest", getDigest());
                            x2.setRequestHeader("If-Match", etag || "*");
                            x2.onreadystatechange = function() {
                                if (x2.readyState === 4) {
                                    var ok = x2.status >= 200 && x2.status < 300;
                                    cb(ok, ok ? null : parseSharePointError(x2.responseText, x2.status));
                                }
                            };
                            x2.send();
                        } else {
                            cb(false, parseSharePointError(x1.responseText, x1.status));
                        }
                    }
                };
                x1.send();
            }

            function processWork(wIdx) {
                if (wIdx >= total) {
                    document.getElementById("bulkSubmitBtn").disabled = false;
                    var summary = "Done! " + done + " succeeded, " + errors + " errors.";
                    if (errorDetails.length) {
                        summary += "<br><br>" + errorDetails.slice(0, 5).join("<br>");
                    }
                    alert_("bulkAlert", errors > 0 ? "error" : "success", summary, errors > 0);
                    if (errors === 0) {
                        clearBulk(false);
                    }
                    refreshListData(target === "master" ? "master" : "oracle");
                    return;
                }
                var job = workItems[wIdx];
                var r = bulkParsedRows[job.idx];
                function onFail(errMsg) {
                    errors++;
                    errorDetails.push("Row " + (job.idx + 2) + " (" + job.type + "): " + (errMsg || "Request failed"));
                }
                if (job.type === "delete") {
                    deleteItem(r._spItemId, function(ok, errMsg) {
                        if (ok) done++;
                        else onFail(errMsg);
                        updateProg();
                        processWork(wIdx + 1);
                    });
                } else {
                    var payload = buildPayload(r);
                    if (job.type === "update") {
                        patchItem(r._spItemId, payload, function(ok, errMsg) {
                            if (ok) done++;
                            else onFail(errMsg);
                            updateProg();
                            processWork(wIdx + 1);
                        });
                    } else if (target === "oracle") {
                        autoCreateMasterFromBulkRow(r, function() {
                            applyOracleRequestIdToPayload(payload, ensureOracleRequestIdForSubmit(r));
                            postItem(payload, function(ok, errMsg) {
                                if (ok) done++;
                                else onFail(errMsg);
                                updateProg();
                                processWork(wIdx + 1);
                            });
                        });
                    } else {
                        postItem(payload, function(ok, errMsg) {
                            if (ok) done++;
                            else onFail(errMsg);
                            updateProg();
                            processWork(wIdx + 1);
                        });
                    }
                }
            }
            function beginBulkSubmit() {
                if (target === "oracle" && !bulkIdSeq) {
                    fetchNextRequestIdBase(function(base) {
                        bulkIdSeq = {
                            year: base.year,
                            month: base.month,
                            next: base.next
                        };
                        processWork(0);
                    });
                    return;
                }
                processWork(0);
            }
            beginBulkSubmit();
        }

        // ═══ SIDEBAR TOGGLE ═══
        function toggleSidebar() {
            var sb = document.querySelector(".sidebar");
            sb.classList.toggle("collapsed");
            document.getElementById("sidebarIcon").setAttribute("data-lucide", sb.classList.contains("collapsed") ? "panel-left" : "panel-left-off");
            if (typeof lucide !== "undefined") lucide.createIcons();
        }

        // ═══════════════════════════════════════
        // LOAD DROPDOWN CHOICES FROM SHAREPOINT
        // ═══════════════════════════════════════
        function loadDropdownChoices() {
            var lists = [{
                    name: 'Master Data',
                    fields: ['Current_Status', 'Tariff_x0020__x0028_Rate_x0020_P']
                },
                {
                    name: 'Oracle Activation',
                    fields: ['Transaction_x0020_Type', 'SIM_x0020_Type', 'Tariff_x0020__x0028_Rate_x0020_P', 'Add_x002d_ons', 'Device_x0020__x0028_Brand_x0029_', 'Device_x0020_Subcategory', 'Update_x0020_Order', 'Status', 'Reason', 'Pending_x0020_With', 'Capacity']
                }
            ];

            var completed = 0;

            lists.forEach(function(list) {
                var url = getSite() + "/_api/web/lists/getbytitle('" + list.name + "')/fields?$filter=" +
                    list.fields.map(function(f) {
                        return "InternalName eq '" + f + "'";
                    }).join(" or ") +
                    "&$select=InternalName,Choices";

                var x = new XMLHttpRequest();
                x.open("GET", url, true);
                x.setRequestHeader("Accept", "application/json;odata=verbose");
                x.onreadystatechange = function() {
                    if (x.readyState === 4 && x.status >= 200 && x.status < 300) {
                        try {
                            var data = JSON.parse(x.responseText);
                            data.d.results.forEach(function(field) {
                                if (field.Choices && field.Choices.results) {
                                    dropdownChoices[field.InternalName] = field.Choices.results;
                                }
                            });
                        } catch (e) {
                            console.error("Error parsing dropdown choices:", e);
                        }
                        completed++;
                        if (completed === lists.length) {
                            populateAllDropdowns();
                        }
                    }
                };
                x.send();
            });
        }

        function populateAllDropdowns() {
            // Master Data dropdowns
            populateDropdown('md_status', 'Current_Status');

            // Oracle Activation dropdowns
            populateDropdown('oa_transtype', 'Transaction_x0020_Type');
            populateDropdown('oa_updateorder', 'Update_x0020_Order');
            populateDropdown('oa_simtype', 'SIM_x0020_Type');
            populateDropdown('oa_addons', 'Add_x002d_ons');
            populateDropdown('oa_devicebrand', 'Device_x0020__x0028_Brand_x0029_');
            populateDropdown('oa_devicesub', 'Device_x0020_Subcategory');
            populateDropdown('oa_capacity', 'Capacity');
            populateDropdown('oa_status', 'Status');
            populateDropdown('oa_reason', 'Reason');
            populateDropdown('oa_pendingwith', 'Pending_x0020_With');
        }

        function populateDropdown(elementId, fieldName) {
            var select = document.getElementById(elementId);
            if (!select || !dropdownChoices[fieldName]) return;

            // Keep the first option (-- Select --)
            var firstOption = select.options[0];
            select.innerHTML = '';
            select.appendChild(firstOption);

            // Add choices from SharePoint
            dropdownChoices[fieldName].forEach(function(choice) {
                var option = document.createElement('option');
                option.value = choice;
                option.textContent = choice;
                select.appendChild(option);
            });
        }

        // ═══ INIT ═══
        loadDropdownChoices(); // Load dropdown choices on page load
        if (typeof lucide !== "undefined") lucide.createIcons();
    </script>
