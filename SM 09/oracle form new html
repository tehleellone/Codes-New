                    </div>
                </div>

                <!-- BULK UPLOAD / UPDATE -->
                <div id="bulkUpload" class="section">
                    <h2 class="section-title">Bulk Upload / Update</h2>
                    <div id="bulkAlert"></div>
                    <div class="card">
                        <div class="card-title"><i data-lucide="download"></i> Download Example CSV Files</div>
                        <p style="color:var(--text-secondary);font-size:0.88rem;margin-bottom:0.8rem;">Download → fill your data → upload below. Keep the header row exactly as-is.</p>
                        <div style="display:flex;gap:0.7rem;flex-wrap:wrap;">
                            <button type="button" class="btn btn-primary btn-sm" onclick="downloadMasterCSV()"><i data-lucide="download"></i> Master Data Example</button>
                            <button type="button" class="btn btn-primary btn-sm" onclick="downloadOracleCSV()"><i data-lucide="download"></i> Oracle Activation Example</button>
                        </div>
                    </div>
                    <div class="card">
                        <div class="card-title"><i data-lucide="upload"></i> Upload CSV</div>
