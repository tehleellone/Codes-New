        // ─── Header click: first click = sort, second click on already-sorted col = open filter popup ───
        // Actually simpler UX: click sorts. Right-click or shift+click opens filter. OR: we do single click = sort, and add a tiny filter icon that opens the popup.
        // Best UX matching AG Grid: single click on header sorts. The filter popup opens via a small filter icon on the right side of the header.
        // Let's do: click on the label area = sort. Click on the filter-dot or right portion = open popup. Simplest: always sort on click, but if column already has filter, clicking the filter-dot opens popup.
        // Actually cleanest matching AG Grid exactly: click = sort. Filter popup opens when you click the column header again while it's already sorted (toggle). No — that's confusing.
        // Match the screenshot exactly: the filter popup appears BELOW the column header. In real AG Grid, you click the small dropdown arrow. Let's add a tiny ▾ icon on each header that opens the popup.

        function gridHeaderClick(e, cid, col) {
            // If the click target is the resize handle, ignore
            if (e.target.classList.contains("dg-resize")) return;
            // If click is on the filter dot, open popup
            if (e.target.classList.contains("dg-filter-dot")) {
                openColFilterPopup(cid, col, e);
                return;
            }
            // Otherwise sort
            gridSort(cid, col);
        }

        function gridSort(cid, col) {
            var g = grids[cid];
            if (!g) return;
            if (g.sortCol === col) g.sortAsc = !g.sortAsc;
            else {
                g.sortCol = col;
                g.sortAsc = true;
            }
            g.page = 0;
            renderGrid(g);
        }

        function gridGlobalSearch(cid, val) {
            var g = grids[cid];
            if (!g) return;
            g.globalSearch = val;
            g.page = 0;
            var container = document.getElementById(cid);
            var searchInput = container.querySelector('.dg-search');
            var cursorPos = searchInput ? searchInput.selectionStart : 0;
            renderGrid(g);
            // Restore focus and cursor position
            setTimeout(function() {
                var newInput = document.getElementById(cid).querySelector('.dg-search');
                if (newInput) {
                    newInput.focus();
                    newInput.setSelectionRange(cursorPos, cursorPos);
                }
            }, 0);
        }

        function gridClearAll(cid) {
            var g = grids[cid];
            if (!g) return;
            g.globalSearch = "";
            g.colFilters = {};
            g.page = 0;
            renderGrid(g);
        }

        function gridPage(cid, p) {
            var g = grids[cid];
            if (!g) return;
            g.page = p;
            renderGrid(g);
        }

        function gridPageSize(cid, size) {
            var g = grids[cid];
            if (!g) return;
            g.pageSize = size;
            g.page = 0;
            renderGrid(g);
        }

        // ─── Column filter popup ───
        function openColFilterPopup(cid, col, e) {
            e.stopPropagation();
            closePopup();
            var g = grids[cid];
            if (!g) return;
            var currentFilter = g.colFilters[col] || {
                op: "contains",
                val: ""
            };

            var popup = document.createElement("div");
            popup.className = "dg-col-filter";
            popup.innerHTML =
                '<select id="cfOp"><option value="contains"' + (currentFilter.op === "contains" ? " selected" : "") + '>Contains</option>' +
                '<option value="startsWith"' + (currentFilter.op === "startsWith" ? " selected" : "") + '>Starts With</option>' +
                '<option value="endsWith"' + (currentFilter.op === "endsWith" ? " selected" : "") + '>Ends With</option>' +
                '<option value="equals"' + (currentFilter.op === "equals" ? " selected" : "") + '>Equals</option>' +
                '<option value="notEquals"' + (currentFilter.op === "notEquals" ? " selected" : "") + '>Not Equals</option>' +
                '</select>' +
                '<input type="text" id="cfVal" placeholder="Filter..." value="' + (currentFilter.val || "") + '" onkeydown="if(event.key===\'Enter\')applyColFilter(\'' + cid + '\',\'' + col + '\')">' +
                '<div class="dg-col-filter-btns">' +
                '<button onclick="clearColFilter(\'' + cid + '\',\'' + col + '\')">Clear</button>' +
                '<button class="apply" onclick="applyColFilter(\'' + cid + '\',\'' + col + '\')">Apply</button>' +
                '</div>';

            // position popup below the th
            var th = document.querySelector('#' + cid + ' th[data-col="' + col + '"]');
            if (!th) {
                // fallback: find by iterating
                var ths = document.getElementById(cid).querySelectorAll("thead th");
                for (var i = 0; i < ths.length; i++) {
                    if (ths[i].getAttribute("data-col") === col) {
                        th = ths[i];
                        break;
                    }
                }
            }
            if (th) {
                th.style.position = "relative";
                th.appendChild(popup);
            }
            activePopup = popup;
            setTimeout(function() {
                var inp = popup.querySelector("#cfVal");
                if (inp) inp.focus();
            }, 30);
        }

        function applyColFilter(cid, col) {
            var g = grids[cid];
            if (!g) return;
            var op = document.getElementById("cfOp").value;
            var val = document.getElementById("cfVal").value;
            if (val.trim()) {
                g.colFilters[col] = {
                    op: op,
                    val: val
                };
            } else {
                delete g.colFilters[col];
            }
            g.page = 0;
            closePopup();
            renderGrid(g);
        }

        function clearColFilter(cid, col) {
            var g = grids[cid];
            if (!g) return;
            delete g.colFilters[col];
            g.page = 0;
            closePopup();
            renderGrid(g);
        }

        // ─── Column resize via drag ───
        var _resizing = null;

        function gridResizeStart(e, cid, col) {
            e.preventDefault();
            e.stopPropagation();
            var g = grids[cid];
            if (!g) return;
            var c = g.columns.find(function(x) {
                return x.key === col;
            });
            if (!c) return;
            _resizing = {
                g: g,
                col: c,
                startX: e.clientX,
                startW: c.width
            };
            document.addEventListener("mousemove", gridResizeMove);
            document.addEventListener("mouseup", gridResizeEnd);
        }

        function gridResizeMove(e) {
            if (!_resizing) return;
            var diff = e.clientX - _resizing.startX;
            _resizing.col.width = Math.max(60, _resizing.startW + diff);
            var g = _resizing.g;
            var idx = g.columns.indexOf(_resizing.col);
            var container = document.getElementById(g.containerId);
            if (!container) return;
            var ths = container.querySelectorAll("thead th");
            if (ths[idx + 1]) ths[idx + 1].style.width = _resizing.col.width + "px";
            var tds = container.querySelectorAll("tbody td");
            var colCount = g.columns.length + 1;
            for (var i = idx + 1; i < tds.length; i += colCount) tds[i].style.width = _resizing.col.width + "px";
        }

        function gridResizeEnd() {
            _resizing = null;
            document.removeEventListener("mousemove", gridResizeMove);
            document.removeEventListener("mouseup", gridResizeEnd);
        }

