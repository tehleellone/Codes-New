<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Oracle Service Request Portal</title>
    <script src="http://sharedspaces:8086/sites/OP/Shared%20Documents/lucide.min.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        h1.ms-core-pageTitle,
        .ms-core-pageTitle {
            display: none !important;
        }

        :root {
            --bg-primary: linear-gradient(135deg, #1a0a27 0%, #2a1a3a 50%, #1d0f19 100%);
            --bg-card: rgba(26, 10, 39, 0.75);
            --bg-header: rgba(26, 10, 39, 0.92);
            --bg-sidebar: linear-gradient(180deg, rgba(40, 16, 65, 0.98), rgba(32, 12, 55, 0.98));
            --bg-content: radial-gradient(circle at top, rgba(32, 10, 52, 0.96), rgba(12, 10, 25, 0.98));
            --bg-input: rgba(22, 8, 36, 0.6);
            --border-color: rgba(146, 72, 185, 0.25);
            --border-hover: rgba(146, 72, 185, 0.6);
            --text-primary: #FFFDFE;
            --text-secondary: #cbd5e1;
            --text-muted: #94a3b8;
            --accent: linear-gradient(135deg, #9248B9, #C724B1);
            --accent-solid: #C724B1;
            --accent-glow: rgba(199, 36, 177, 0.55);
            --nav-active-bg: rgba(199, 36, 177, 0.12);
            --nav-active-border: rgba(199, 36, 177, 0.35);
            --nav-hover-bg: rgba(199, 36, 177, 0.06);
            --shell-bg: radial-gradient(circle at top left, rgba(255, 255, 255, 0.08), transparent 55%), rgba(15, 23, 42, 0.65);
            --shell-shadow: 0 22px 40px rgba(15, 23, 42, 0.65);
        }

        body.light-theme {
            --bg-primary: linear-gradient(135deg, #fdf0fc 0%, #f5e6ff 50%, #fef8ff 100%);
            --bg-card: rgba(255, 255, 255, 0.95);
            --bg-header: rgba(255, 255, 255, 0.98);
            --bg-sidebar: linear-gradient(180deg, rgba(250, 235, 255, 0.98), rgba(245, 230, 255, 0.98));
            --bg-content: radial-gradient(circle at top, rgba(253, 244, 255, 0.98), rgba(255, 255, 255, 0.99));
            --bg-input: rgba(250, 245, 255, 0.9);
            --border-color: rgba(146, 72, 185, 0.18);
            --border-hover: rgba(146, 72, 185, 0.4);
            --text-primary: #1e293b;
            --text-secondary: #475569;
            --text-muted: #64748b;
            --nav-active-bg: rgba(146, 72, 185, 0.08);
            --nav-active-border: rgba(146, 72, 185, 0.25);
            --nav-hover-bg: rgba(146, 72, 185, 0.04);
            --shell-bg: radial-gradient(circle at top left, rgba(248, 244, 255, 0.95), rgba(253, 242, 255, 0.98));
            --shell-shadow: 0 18px 32px rgba(148, 163, 184, 0.45);
        }

        body.cyan-theme {
            --bg-primary: linear-gradient(135deg, #0a1a27 0%, #1a2a3a 50%, #0f1d19 100%);
            --bg-card: rgba(10, 26, 39, 0.78);
            --bg-header: rgba(10, 26, 39, 0.95);
            --bg-sidebar: linear-gradient(180deg, rgba(12, 30, 48, 0.98), rgba(10, 25, 40, 0.98));
            --bg-content: radial-gradient(circle at top, rgba(10, 28, 45, 0.96), rgba(8, 18, 28, 0.98));
            --bg-input: rgba(10, 22, 35, 0.6);
            --border-color: rgba(19, 157, 203, 0.25);
            --border-hover: rgba(19, 157, 203, 0.6);
            --text-primary: #f0f9ff;
            --text-secondary: #cbd5e1;
            --text-muted: #7cb9d4;
            --accent: linear-gradient(135deg, #139DCB, #2193C9);
            --accent-solid: #139DCB;
            --accent-glow: rgba(19, 157, 203, 0.5);
            --nav-active-bg: rgba(19, 157, 203, 0.12);
            --nav-active-border: rgba(19, 157, 203, 0.35);
            --nav-hover-bg: rgba(19, 157, 203, 0.06);
            --shell-bg: radial-gradient(circle at top left, rgba(255, 255, 255, 0.06), transparent 55%), rgba(8, 18, 30, 0.7);
            --shell-shadow: 0 22px 40px rgba(8, 18, 30, 0.7);
        }

        body.cyan-theme.light-theme {
            --bg-primary: linear-gradient(135deg, #f0f9ff 0%, #e6f4ff 50%, #f8fcff 100%);
            --bg-card: rgba(255, 255, 255, 0.96);
            --bg-header: rgba(255, 255, 255, 0.98);
            --bg-sidebar: linear-gradient(180deg, rgba(227, 245, 255, 0.98), rgba(235, 248, 255, 0.98));
            --bg-content: radial-gradient(circle at top, rgba(240, 249, 255, 0.98), rgba(255, 255, 255, 0.99));
            --bg-input: rgba(240, 249, 255, 0.9);
            --border-color: rgba(19, 157, 203, 0.18);
            --border-hover: rgba(19, 157, 203, 0.4);
            --text-primary: #0f172a;
            --text-secondary: #1f2937;
            --text-muted: #6b7280;
            --nav-active-bg: rgba(19, 157, 203, 0.08);
            --nav-active-border: rgba(19, 157, 203, 0.25);
            --nav-hover-bg: rgba(19, 157, 203, 0.04);
            --shell-bg: radial-gradient(circle at top left, rgba(227, 245, 255, 0.95), rgba(240, 249, 255, 0.98));
            --shell-shadow: 0 18px 32px rgba(148, 163, 184, 0.45);
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
        }

        .portal-shell {
            max-width: 1440px;
            margin: 12px auto 24px;
            padding: 10px 14px 18px;
            border-radius: 22px;
            background: var(--shell-bg);
            box-shadow: var(--shell-shadow);
        }

        /* HEADER */
        .header {
            background: var(--bg-header);
            backdrop-filter: blur(10px);
            border-radius: 16px 16px 0 0;
            border: 1px solid var(--border-color);
            border-bottom: none;
            padding: 0.9rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo-section { 
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .logo {
            width: 40px;
            height: 40px;
            background: var(--accent);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 0 20px var(--accent-glow);
            color: #fff;
        }

        .header-title {
            font-size: 1.4rem;
            font-weight: 700;
            background: linear-gradient(135deg, #C724B1, #9248B9, #139DCB);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .header-actions {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .color-scheme-selector {
            padding: 0.45rem 0.9rem;
            background: var(--bg-input);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            color: var(--text-primary);
            font-size: 0.8rem;
            cursor: pointer;
            font-family: inherit;
        }

        .theme-toggle {
            width: 38px;
            height: 38px;
            border-radius: 50%;
            background: var(--bg-input);
            border: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-primary);
        }

        /* LAYOUT */
        .main-container {
            display: flex;
            border-radius: 0 0 16px 16px;
            border: 1px solid var(--border-color);
            border-top: none;
            overflow: hidden;
        }

        .sidebar {
            width: 240px;
            min-width: 240px;
            background: var(--bg-sidebar);
            border-right: 1px solid var(--border-color);
            padding: 1.5rem 0;
            transition: width 0.25s, min-width 0.25s, padding 0.25s, opacity 0.25s;
            overflow: hidden;
        }

        .sidebar.collapsed {
            width: 0;
            min-width: 0;
            padding: 1.5rem 0;
            opacity: 0;
            border-right: none;
        }

        .nav-items {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
            padding: 0 0.9rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 0.9rem;
            padding: 0.7rem 0.9rem;
            border-radius: 12px;
            cursor: pointer;
            color: var(--text-secondary);
            border: 1px solid transparent;
            transition: all 0.2s;
        }

        .nav-item:hover {
            background: var(--nav-hover-bg);
            color: var(--text-primary);
        }

        .nav-item.active {
            background: var(--nav-active-bg);
            border-color: var(--nav-active-border);
            color: var(--text-primary);
            font-weight: 600;
        }

        .nav-section-label {
            font-size: 0.72rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: var(--text-muted);
            padding: 1.2rem 0.9rem 0.4rem;
        }

        .content {
            flex: 1;
            padding: 1.3rem 1.4rem;
            overflow-y: auto;
            background: var(--bg-content);
            min-height: 600px;
        }

        /* SECTIONS */
        .section {
            display: none;
            animation: fadeIn 0.3s;
        }

        .section.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(6px)
            }

            to {
                opacity: 1;
                transform: translateY(0)
            }
        }

        .section-title {
            font-size: 1.35rem;
            font-weight: 700;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #C724B1, #9248B9, #139DCB);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* WELCOME */
        .welcome-card {
            background: var(--bg-card);
            border-radius: 16px;
            border: 1px solid var(--border-color);
            padding: 2rem;
        }

        .welcome-title {
            font-size: 1.9rem;
            font-weight: 700;
            margin-bottom: 1.2rem;
            background: linear-gradient(135deg, #C724B1, #9248B9, #139DCB);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .welcome-text {
            color: var(--text-secondary);
            line-height: 1.75;
            margin-bottom: 0.9rem;
        }

        .feature-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
            gap: 1rem;
            margin-top: 1.8rem;
        }

        .feature-box {
            background: rgba(146, 72, 185, 0.05);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            padding: 1.4rem;
        }

        .feature-icon {
            width: 38px;
            height: 38px;
            background: var(--accent);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 0.9rem;
            color: #fff;
        }

        .feature-title {
            font-weight: 700;
            margin-bottom: 0.4rem;
            color: var(--text-primary);
        }

        .feature-desc {
            font-size: 0.88rem;
            color: var(--text-muted);
            line-height: 1.5;
        }

        /* CARDS */
        .card {
            background: var(--bg-card);
            border-radius: 16px;
            border: 1px solid var(--border-color);
            padding: 1rem 1.1rem;
            margin-bottom: 1.2rem;
        }

        .card-title {
            font-size: 0.82rem;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 0.06em;
            margin-bottom: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* FORMS */
        .form-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.9rem;
        }

        .form-grid-2 {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.9rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.3rem;
        }

        .form-label {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--text-secondary);
        }

        .required-mark {
            color: #ef4444;
        }

        .inp {
            width: 100%;
            padding: 0.62rem 0.8rem;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            background: var(--bg-input);
            color: var(--text-primary);
            font-size: 0.88rem;
            font-family: inherit;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .inp:focus {
            outline: none;
            border-color: var(--border-hover);
            box-shadow: 0 0 0 3px rgba(146, 72, 185, 0.12);
        }

        .inp::placeholder {
            color: var(--text-muted);
        }

        select.inp {
            appearance: auto;
        }

        textarea.inp {
            min-height: 72px;
            resize: vertical;
        }

        /* BUTTONS */
        .btn {
            padding: 0.58rem 1.2rem;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            background: var(--bg-card);
            color: var(--text-primary);
            font-size: 0.88rem;
            font-weight: 600;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            font-family: inherit;
            transition: all 0.2s;
        }

        .btn:hover {
            border-color: var(--border-hover);
        }

        .btn-primary {
            background: var(--accent);
            color: #fff;
            border: none;
            box-shadow: 0 3px 10px rgba(146, 72, 185, 0.35);
        }

        .btn-primary:hover {
            box-shadow: 0 5px 16px rgba(146, 72, 185, 0.5);
            transform: translateY(-1px);
        }

        .btn-primary:disabled {
            opacity: 0.55;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .btn-sm {
            padding: 0.32rem 0.7rem;
            font-size: 0.8rem;
            border-radius: 6px;
        }

        /* ALERTS */
        .alert {
            padding: 0.8rem 1rem;
            border-radius: 10px;
            margin-bottom: 0.9rem;
            display: flex;
            align-items: center;
            gap: 0.7rem;
            border: 1px solid;
            font-size: 0.9rem;
        }

        .alert-success {
            background: rgba(34, 197, 94, 0.1);
            border-color: rgba(34, 197, 94, 0.3);
            color: #22c55e;
        }

        .alert-error {
            background: rgba(239, 68, 68, 0.1);
            border-color: rgba(239, 68, 68, 0.3);
            color: #ef4444;
        }

        .alert-info {
            background: rgba(59, 130, 246, 0.1);
            border-color: rgba(59, 130, 246, 0.3);
            color: #60a5fa;
        }

        .spinner {
            width: 15px;
            height: 15px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: #fff;
            border-radius: 50%;
            animation: spin 0.7s linear infinite;
            display: inline-block;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg)
            }
        }

        /* EMAIL CHECK */
        .email-row {
            display: flex;
            gap: 0.5rem;
            align-items: center;
        }

        .email-row .inp {
            flex: 1;
        }

        .email-status {
            margin-top: 0.4rem;
            font-size: 0.8rem;
            min-height: 1rem;
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        .form-actions {
            display: flex;
            gap: 0.8rem;
            justify-content: flex-end;
            margin-top: 1rem;
        }

        /* EDIT BANNER */
        .edit-banner {
            background: rgba(59, 130, 246, 0.12);
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 10px;
            padding: 0.7rem 1rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            color: #60a5fa;
            font-size: 0.88rem;
        }

        .edit-banner-actions {
            display: flex;
            gap: 0.5rem;
        }

        /* ═══════════════════════════════════════════
   DATAGRID
   ═══════════════════════════════════════════ */
        .dg-wrap {
            border-radius: 12px;
            border: 1px solid var(--border-color);
            overflow: hidden;
            background: var(--bg-card);
        }

        /* Toolbar row: universal search + count + clear */
        .dg-toolbar {
            display: flex;
            align-items: center;
            gap: 0.7rem;
            padding: 0.6rem 0.8rem;
            border-bottom: 1px solid var(--border-color);
            background: var(--bg-header);
        }

        .dg-search-wrap {
            position: relative;
            flex: 1;
            min-width: 180px;
            max-width: 380px;
        }

        .dg-search {
            width: 100%;
            padding: 0.36rem 0.7rem 0.36rem 2.1rem;
            border-radius: 7px;
            border: 1px solid var(--border-color);
            background: var(--bg-input);
            color: var(--text-primary);
            font-size: 0.84rem;
            font-family: inherit;
        }

        .dg-search:focus {
            outline: none;
            border-color: var(--border-hover);
        }

        .dg-search::placeholder {
            color: var(--text-muted);
        }

        .dg-search-icon {
            position: absolute;
            left: 0.55rem;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            pointer-events: none;
            width: 15px;
            height: 15px;
        }

        .dg-count {
            font-size: 0.82rem;
            color: var(--text-muted);
            margin-left: auto;
            white-space: nowrap;
        }

        .dg-clear-btn {
            font-size: 0.78rem;
            color: var(--accent-solid);
            cursor: pointer;
            background: none;
            border: none;
            font-family: inherit;
            font-weight: 600;
            padding: 0.2rem 0.5rem;
            border-radius: 5px;
            display: none;
        }

        .dg-clear-btn:hover {
            background: rgba(146, 72, 185, 0.08);
        }

        .dg-clear-btn.visible {
            display: inline-block;
        }

        /* Scrollable table area */
        .dg-scroll {
            overflow-x: auto;
        }

        .dg-body-scroll {
            max-height: 440px;
            overflow-y: auto;
        }

        .dg-table {
            border-collapse: collapse;
            table-layout: fixed;
            min-width: 100%;
        }

        /* Header */
        .dg-table thead {
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .dg-table thead th {
            background: var(--bg-header);
            color: var(--text-muted);
            font-size: 0.76rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 0.55rem 0.6rem;
            text-align: left;
            border-bottom: 2px solid var(--border-color);
            white-space: nowrap;
            user-select: none;
            position: relative;
            vertical-align: middle;
        }

        .dg-table thead th.dg-action {
            width: 76px;
            min-width: 76px;
            max-width: 76px;
            text-align: center;
            cursor: default;
            border-bottom-width: 2px;
        }

        .dg-table thead th:not(.dg-action) {
            cursor: pointer;
        }

        .dg-table thead th:not(.dg-action):hover {
            color: var(--text-primary);
            background: rgba(146, 72, 185, 0.06);
        }

        /* sort arrow */
        .dg-sort {
            display: inline-block;
            margin-left: 4px;
            opacity: 0.35;
            font-size: 0.68rem;
        }

        .dg-table thead th.dg-sorted .dg-sort {
            opacity: 1;
            color: var(--accent-solid);
        }

        /* active column filter indicator: small colored dot */
        .dg-table thead th.dg-has-filter {
            color: var(--accent-solid) !important;
        }

        .dg-filter-dot {
            display: inline-block;
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: var(--accent-solid);
            margin-left: 5px;
            vertical-align: middle;
        }

        .dg-filter-arrow {
            display: inline-block;
            font-size: 0.65rem;
            color: var(--text-muted);
            margin-left: 3px;
            vertical-align: middle;
            cursor: pointer;
            padding: 0 2px;
            border-radius: 3px;
            transition: color 0.15s, background 0.15s;
        }

        .dg-filter-arrow:hover {
            color: var(--accent-solid);
            background: rgba(146, 72, 185, 0.1);
        }

        /* Column resize handle */
        .dg-resize {
            position: absolute;
            top: 0;
            right: 0;
            width: 5px;
            height: 100%;
            cursor: col-resize;
            z-index: 5;
        }

        .dg-resize:hover {
            background: var(--accent-solid);
        }

        /* ── Column filter popup (AG Grid style) ── */
        .dg-col-filter {
            position: absolute;
            top: calc(100% + 3px);
            left: 0;
            z-index: 200;
            width: 185px;
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 8px;
            box-shadow: 0 10px 28px rgba(0, 0, 0, 0.32);
            padding: 0.55rem;
        }

        .dg-col-filter select {
            width: 100%;
            padding: 0.3rem 0.45rem;
            border-radius: 5px;
            border: 1px solid var(--border-color);
            background: var(--bg-input);
            color: var(--text-primary);
            font-size: 0.8rem;
            font-family: inherit;
            margin-bottom: 0.35rem;
            appearance: auto;
        }

        .dg-col-filter input[type=text] {
            width: 100%;
            padding: 0.3rem 0.45rem;
            border-radius: 5px;
            border: 1px solid var(--border-color);
            background: var(--bg-input);
            color: var(--text-primary);
            font-size: 0.8rem;
            font-family: inherit;
        }

        .dg-col-filter input[type=text]:focus,
        .dg-col-filter select:focus {
            outline: none;
            border-color: var(--border-hover);
        }

        .dg-col-filter input[type=text]::placeholder {
            color: var(--text-muted);
        }

        .dg-col-filter-btns {
            display: flex;
            gap: 0.3rem;
            margin-top: 0.4rem;
            justify-content: flex-end;
        }

        .dg-col-filter-btns button {
            padding: 0.2rem 0.52rem;
            border-radius: 5px;
            font-size: 0.76rem;
            font-family: inherit;
            cursor: pointer;
            border: 1px solid var(--border-color);
            background: var(--bg-card);
            color: var(--text-primary);
        }

        .dg-col-filter-btns button.apply {
            background: var(--accent);
            color: #fff;
            border: none;
        }

        .dg-col-filter-btns button:hover {
            opacity: 0.82;
        }

        /* Body */
        .dg-table tbody tr {
            border-bottom: 1px solid var(--border-color);
            transition: background 0.12s;
        }

        .dg-table tbody tr:nth-child(even) {
            background: rgba(146, 72, 185, 0.025);
        }

        .dg-table tbody tr:hover {
            background: rgba(146, 72, 185, 0.07);
        }

        .dg-table tbody td {
            padding: 0.5rem 0.6rem;
            font-size: 0.85rem;
            color: var(--text-secondary);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            vertical-align: middle;
        }

        .dg-table tbody td.dg-action {
            text-align: center;
            overflow: visible;
        }

        /* View button */
        .btn-view {
            padding: 0.28rem 0.65rem;
            border-radius: 5px;
            background: var(--accent);
            color: #fff;
            border: none;
            font-size: 0.76rem;
            font-weight: 600;
            cursor: pointer;
            white-space: nowrap;
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }

        .btn-view:hover {
            opacity: 0.82;
        }

        /* Pinned action column */
        .dg-action {
            position: sticky;
            left: 0;
            z-index: 2;
            background: var(--bg-header) !important;
            border-right: 2px solid var(--border-color);
        }

        .dg-table tbody tr:nth-child(even) .dg-action {
            background: rgba(26, 10, 39, 0.82) !important;
        }

        .dg-table tbody tr:hover .dg-action {
            background: rgba(146, 72, 185, 0.1) !important;
        }

        body.light-theme .dg-table tbody tr:nth-child(even) .dg-action {
            background: rgba(255, 255, 255, 0.96) !important;
        }

        body.light-theme .dg-table tbody tr:hover .dg-action {
            background: rgba(146, 72, 185, 0.06) !important;
        }

        /* Status bar */
        .dg-statusbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0.5rem 0.7rem;
            border-top: 1px solid var(--border-color);
            background: var(--bg-header);
            font-size: 0.8rem;
            color: var(--text-muted);
            flex-wrap: wrap;
            gap: 0.4rem;
        }

        .dg-pager {
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        .dg-pager button {
            padding: 0.22rem 0.55rem;
            border-radius: 5px;
            border: 1px solid var(--border-color);
            background: var(--bg-card);
            color: var(--text-primary);
            font-size: 0.78rem;
            cursor: pointer;
        }

        .dg-pager button:disabled {
            opacity: 0.35;
            cursor: not-allowed;
        }

        .dg-pager button.active {
            background: var(--accent);
            color: #fff;
            border: none;
        }

        .dg-pager select {
            padding: 0.2rem 0.4rem;
            border-radius: 5px;
            border: 1px solid var(--border-color);
            background: var(--bg-input);
            color: var(--text-primary);
            font-size: 0.78rem;
        }

        /* Empty / loading */
        .dg-empty {
            padding: 2.5rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.92rem;
        }

        /* Progress bar */
        .progress-wrap {
            background: var(--bg-input);
            border-radius: 8px;
            height: 20px;
            overflow: hidden;
            margin-top: 0.6rem;
        }

        .progress-bar {
            height: 100%;
            background: var(--accent);
            border-radius: 8px;
            transition: width 0.25s;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 0.75rem;
            font-weight: 700;
            white-space: nowrap;
            min-width: 30px;
        }

        @media(max-width:900px) {
            .form-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }

        @media(max-width:600px) {

            .form-grid,
            .form-grid-2 {
                grid-template-columns: 1fr;
            }

            .sidebar {
                width: 200px;
                min-width: 200px;
            }
        }
    </style>
</head>

<body>
    <div class="portal-shell">

