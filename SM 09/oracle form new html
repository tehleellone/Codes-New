            alert_("oracleAlert", "info", "Updating...");
            // Step 1: fetch ETag
            var x1 = new XMLHttpRequest();
            x1.open("GET", getSite() + "/_api/web/lists/getbytitle('Oracle Activation')/items(" + id + ")", true);
            x1.setRequestHeader("Accept", "application/json;odata=verbose");
            x1.onreadystatechange = function() {
                if (x1.readyState === 4) {
                    if (x1.status >= 200 && x1.status < 300) {
                        var etag = x1.getResponseHeader("ETag");
                        var payload = getOraclePayload();
                        payload.__metadata = {
                            type: "SP.Data.Oracle_x0020_ActivationListItem"
                        };
                        // Step 2: PATCH with ETag
                        var x2 = new XMLHttpRequest();
                        x2.open("PATCH", getSite() + "/_api/web/lists/getbytitle('Oracle Activation')/items(" + id + ")", true);
                        x2.setRequestHeader("Accept", "application/json;odata=verbose");
                        x2.setRequestHeader("Content-Type", "application/json;odata=verbose");
                        x2.setRequestHeader("X-RequestDigest", getDigest());
                        x2.setRequestHeader("If-Match", etag);
                        x2.onreadystatechange = function() {
                            if (x2.readyState === 4) {
                                if (x2.status >= 200 && x2.status < 300) {
                                    showSubmitSuccess("oracleAlert", "Oracle record updated successfully.", resetOracleForm, "both");
                                } else alert_("oracleAlert", "error", "PATCH failed — Error " + x2.status);
                            }
                        };
                        x2.send(JSON.stringify(payload));
                    } else {
                        alert_("oracleAlert", "error", "Failed to fetch ETag — Error " + x1.status);
                    }
                }
            };
            x1.send();
        }
