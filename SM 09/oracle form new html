        function submitMasterData() {
            var email = document.getElementById("md_email").value.trim(),
                status = document.getElementById("md_status").value;
            if (!email || !status) {
                alert_("masterAlert", "error", "Fill required: Email & Status");
                return;
            }
            var btn = document.getElementById("submitMasterBtn");
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner"></span> Submitting...';
            var payload = getMasterPayload();
            payload.__metadata = {
                type: "SP.Data.Master_x0020_DataListItem"
            };
            var x = new XMLHttpRequest();
            x.open("POST", getSite() + "/_api/web/lists/getbytitle('Master Data')/items", true);
            x.setRequestHeader("Accept", "application/json;odata=verbose");
            x.setRequestHeader("Content-Type", "application/json;odata=verbose");
            x.setRequestHeader("X-RequestDigest", getDigest());
            x.onreadystatechange = function() {
                if (x.readyState === 4) {
                    btn.disabled = false;
                    btn.innerHTML = '<i data-lucide="check"></i> Submit';
                    if (typeof lucide !== "undefined") lucide.createIcons();
                    if (x.status >= 200 && x.status < 300) {
                        showSubmitSuccess("masterAlert", "Master record created successfully.", resetMasterForm, "master");
                    } else alert_("masterAlert", "error", "Error " + x.status);
                }
            };
            x.send(JSON.stringify(payload));
        }

        function updateMasterData() {
            var id = document.getElementById("md_editId").value;
            if (!id) return;
            alert_("masterAlert", "info", "Updating...");
            var btn = document.getElementById("submitMasterBtn");
            if (btn) {
                btn.disabled = true;
                btn.innerHTML = '<span class="spinner"></span> Updating...';
            }
            // Step 1: fetch ETag
            var x1 = new XMLHttpRequest();
            x1.open("GET", getSite() + "/_api/web/lists/getbytitle('Master Data')/items(" + id + ")", true);
            x1.setRequestHeader("Accept", "application/json;odata=verbose");
            x1.onreadystatechange = function() {
                if (x1.readyState === 4) {
                    if (x1.status >= 200 && x1.status < 300) {
                        var etag = x1.getResponseHeader("ETag");
                        var payload = getMasterPayload();
                        payload.__metadata = {
                            type: "SP.Data.Master_x0020_DataListItem"
                        };
                        // Step 2: PATCH with ETag
                        var x2 = new XMLHttpRequest();
                        x2.open("PATCH", getSite() + "/_api/web/lists/getbytitle('Master Data')/items(" + id + ")", true);
                        x2.setRequestHeader("Accept", "application/json;odata=verbose");
                        x2.setRequestHeader("Content-Type", "application/json;odata=verbose");
                        x2.setRequestHeader("X-RequestDigest", getDigest());
                        x2.setRequestHeader("If-Match", etag);
                        x2.onreadystatechange = function() {
                            if (x2.readyState === 4) {
                                if (btn) {
                                    btn.disabled = false;
                                    btn.innerHTML = '<i data-lucide="check"></i> Submit';
                                    if (typeof lucide !== "undefined") lucide.createIcons();
                                }
                                if (x2.status >= 200 && x2.status < 300) {
                                    showSubmitSuccess("masterAlert", "Master record updated successfully.", resetMasterForm, "master");
                                } else {
                                    alert_("masterAlert", "error", "Update failed — Error " + x2.status);
                                }
                            }
                        };
                        x2.send(JSON.stringify(payload));
                    } else {
                        alert_("masterAlert", "error", "✗ Update Failed — Cannot fetch item (Error " + x1.status + ")");
                    }
                }
            };
            x1.send();
        }
