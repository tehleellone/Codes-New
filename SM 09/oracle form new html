        function bulkHeaderToKey(h) {
            var t = bulkNorm(h);
            for (var key in BULK_COL_LABELS) {
                if (key === t || BULK_COL_LABELS[key].toLowerCase() === t.toLowerCase()) return key;
            }
            if (t === "RequestId" || t === "Request ID") return "RequestID";
            return t;
        }

        function bulkColLabel(key) {
            return BULK_COL_LABELS[key] || key;
        }

        function formatDateForInput(dateStr) {
            if (!dateStr) return "";
            try {
                var d = new Date(dateStr);
                if (isNaN(d.getTime())) return "";
                var year = d.getFullYear();
                var month = String(d.getMonth() + 1).padStart(2, '0');
                var day = String(d.getDate()).padStart(2, '0');
                return year + '-' + month + '-' + day;
            } catch (e) {
                return "";
            }
        }

        function parseSharePointDate(dateStr) {
            if (!dateStr) return null;
            var s = String(dateStr).trim();
            var m = s.match(/\/Date\((-?\d+)\)\//);
            if (m) return new Date(parseInt(m[1], 10));
            var d = new Date(s);
            return isNaN(d.getTime()) ? null : d;
        }

        function formatDateForCompare(dateStr) {
            if (!dateStr) return "";
            var s = String(dateStr).trim();
            if (!s) return "";
            var iso = s.match(/^(\d{4})-(\d{2})-(\d{2})$/);
            if (iso) return iso[1] + "-" + iso[2] + "-" + iso[3];
            var isoPrefix = s.match(/^(\d{4})-(\d{2})-(\d{2})[T\s]/);
            if (isoPrefix) return isoPrefix[1] + "-" + isoPrefix[2] + "-" + isoPrefix[3];
            var parts = s.match(/^(\d{1,2})[\/\-](\d{1,2})[\/\-](\d{4})$/);
            if (parts) {
                var p1 = parseInt(parts[1], 10);
                var p2 = parseInt(parts[2], 10);
                var yr = parseInt(parts[3], 10);
                var day, mo;
                if (p1 > 12) {
                    day = p1;
                    mo = p2;
                } else if (p2 > 12) {
                    day = p2;
                    mo = p1;
                } else {
                    mo = p1;
                    day = p2;
                }
                return yr + "-" + String(mo).padStart(2, "0") + "-" + String(day).padStart(2, "0");
            }
            var d = parseSharePointDate(s);
            if (!d) return s;
            return d.getFullYear() + "-" + String(d.getMonth() + 1).padStart(2, "0") + "-" + String(d.getDate()).padStart(2, "0");
        }

        function bulkDatesEqual(csvKey, a, b) {
            if (!a && !b) return true;
            if (!a || !b) return false;
            return normalizeBulkCompareValue(csvKey, a) === normalizeBulkCompareValue(csvKey, b);
        }

        function getBulkDateKeysForTarget(target) {
            if (target === "master") {
                return ["ExpiryDate", "ActivationDateSIM", "ContractStartSIM", "ContractEndSIM", "ContractStartHandset", "ContractEndHandset", "DeactivationDateSIM"];
            }
            return ["PODate", "ActivityDate", "SRDate", "SOCreationDate", "ActivityDate2", "SOCreationDate2", "ActivationDateSIM", "ContractStartSIM", "ContractEndSIM", "ActivationDateHandset", "ContractEndHandset", "FutureTermDate", "CompletedDate"];
        }

        function syncBulkUpdateRowsFromExisting(target) {
            bulkParsedRows.forEach(function(r) {
                if (r._bulkAction !== "update" || !r._existing) return;
                getBulkDateKeysForTarget(target).forEach(function(key) {
                    var csvVal = bulkNorm(r[key]);
                    var spRaw = getExistingCsvValue(r._existing, key, target);
                    var spNorm = spRaw ? normalizeBulkCompareValue(key, spRaw) : "";
                    if (!csvVal && spNorm) {
                        r[key] = spNorm;
                        return;
                    }
                    if (csvVal && spNorm && bulkDatesEqual(key, csvVal, spRaw)) {
                        r[key] = spNorm;
                    }
                });
            });
        }

        function isBulkDateKey(csvKey) {
            return csvKey.indexOf("Date") > -1;
        }

        function normalizeBulkCompareValue(csvKey, val) {
            var v = bulkNorm(val);
            if (!v) return "";
            if (isBulkDateKey(csvKey)) {
                if (csvKey === "EmailReceived" || csvKey === "LoggedInSP" || csvKey === "CompletedDate") {
                    var dt = formatDateTimeForInput(v);
                    return dt || formatDateForCompare(v);
                }
                return formatDateForCompare(v);
            }
            return v;
        }

        function formatDateTimeForInput(dateStr) {
            if (!dateStr) return "";
            try {
                var d = new Date(dateStr);
                if (isNaN(d.getTime())) return "";
                var year = d.getFullYear();
                var month = String(d.getMonth() + 1).padStart(2, '0');
                var day = String(d.getDate()).padStart(2, '0');
                var hours = String(d.getHours()).padStart(2, '0');
                var minutes = String(d.getMinutes()).padStart(2, '0');
                return year + '-' + month + '-' + day + 'T' + hours + ':' + minutes;
            } catch (e) {
                return "";
            }
        }

        function formatDateForDisplay(dateStr) {
            if (!dateStr) return "";
            try {
                var d = new Date(dateStr);
                if (isNaN(d.getTime())) return "";
                var year = d.getFullYear();
                var month = String(d.getMonth() + 1).padStart(2, '0');
                var day = String(d.getDate()).padStart(2, '0');
                return day + '/' + month + '/' + year;
            } catch (e) {
                return String(dateStr);
            }
        }

        function escapeHtml(text) {
            if (!text) return "";
            return String(text)
                .replace(/&/g, "&amp;")
                .replace(/"/g, "&quot;")
                .replace(/'/g, "&#39;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;");
        }

        function parseSharePointError(responseText, status) {
            if (responseText) {
                try {
                    var data = JSON.parse(responseText);
                    if (data.error && data.error.message && data.error.message.value) {
                        return data.error.message.value;
                    }
                } catch (e) {}
            }
            return status ? ("Error " + status) : "Request failed";
        }

        function fetchAllItems(url, allItems, callback) {
            var x = new XMLHttpRequest();
            x.open("GET", url, true);
            x.setRequestHeader("Accept", "application/json;odata=verbose");
            x.onreadystatechange = function() {
                if (x.readyState === 4) {
                    if (x.status >= 200 && x.status < 300) {
                        try {
                            var j = JSON.parse(x.responseText);
                            var items = j.d && j.d.results ? j.d.results : (j.value || []);
                            allItems = allItems.concat(items);

                            // Check for next page
                            var nextUrl = j.d && j.d.__next ? j.d.__next : null;
                            if (nextUrl) {
                                fetchAllItems(nextUrl, allItems, callback);
                            } else {
                                callback(allItems, null);
                            }
                        } catch (e) {
                            callback(allItems, e);
                        }
                    } else {
                        callback(allItems, {
                            status: x.status,
                            text: x.responseText.substring(0, 200)
                        });
                    }
                }
            };
            x.send();
        }
        // close any open column-filter popup
        function closePopup() {
