        // ═══ HELPERS ═══
        function parseRequestIdNum(id) {
            if (!id) return null;
            var s = String(id).trim();
            var m = s.match(/^ORC-SIM-(\d{4})-(\d{2})-(\d+)$/i);
            if (m) {
                return {
                    year: parseInt(m[1], 10),
                    month: parseInt(m[2], 10),
                    num: parseInt(m[3], 10)
                };
            }
            m = s.match(/^ORC-SIM-(\d{4})-(\d+)$/i);
            if (!m) return null;
            return {
                year: parseInt(m[1], 10),
                month: null,
                num: parseInt(m[2], 10)
            };
        }

        function formatRequestId(year, month, num) {
            var mo = month != null ? month : (new Date().getMonth() + 1);
            return "ORC-SIM-" + year + "-" + String(mo).padStart(2, "0") + "-" + String(num).padStart(5, "0");
        }

        function applyOracleRequestIdToPayload(payload, requestId) {
            if (!requestId) return;
            payload.Request_ID = requestId;
        }

        function fetchNextRequestIdBase(cb) {
            var now = new Date();
            var year = now.getFullYear();
            var month = now.getMonth() + 1;
            var prefix = "ORC-SIM-" + year + "-" + String(month).padStart(2, "0") + "-";
            var url = getSite() + "/_api/web/lists/getbytitle('Oracle Activation')/items?$select=Request_ID&$filter=startswith(Request_ID,'" + prefix + "')&$top=5000";
            fetchAllItems(url, [], function(items) {
                var max = 0;
                items.forEach(function(i) {
                    var p = parseRequestIdNum(i.Request_ID);
                    if (p && p.year === year && p.month === month && p.num > max) max = p.num;
                });
                cb({
                    year: year,
                    month: month,
                    next: max + 1
                });
            });
        }

        function reserveRequestIds(count, cb) {
            fetchNextRequestIdBase(function(base) {
                var ids = [];
                for (var i = 0; i < count; i++) {
                    ids.push(formatRequestId(base.year, base.month, base.next + i));
                }
                cb(ids, base.next + count);
            });
        }

        function sortListNewestFirst(items) {
            return items.slice().sort(function(a, b) {
                var da = new Date(a.Modified || a.Created || 0).getTime();
                var db = new Date(b.Modified || b.Created || 0).getTime();
                return db - da;
            });
        }

