        // ═══════════════════════════════════════
        // DATAGRID ENGINE
        // Each grid: { containerId, columns, rows, sortCol, sortAsc, colFilters:{col:{op,val}}, globalSearch, page, pageSize }
        // ═══════════════════════════════════════
        var grids = {};

        function createGrid(containerId, columns, rows) {
            var g = {
                containerId: containerId,
                columns: columns,
                rows: rows,
                sortCol: null,
                sortAsc: true,
                colFilters: {},
                globalSearch: "",
                page: 0,
                pageSize: 25
            };
            grids[containerId] = g;
            renderGrid(g);
            return g;
        }

        function getFilteredSorted(g) {
            var out = g.rows.filter(function(r) {
                // global search: match any column
                if (g.globalSearch.trim()) {
                    var gs = g.globalSearch.trim().toLowerCase();
                    var found = false;
                    g.columns.forEach(function(c) {
                        if (String(r[c.key] || "").toLowerCase().includes(gs)) found = true;
                    });
                    if (!found) return false;
                }
                // per-column filters
                for (var k in g.colFilters) {
                    if (!g.colFilters.hasOwnProperty(k)) continue;
                    var f = g.colFilters[k];
                    if (!f.val || !f.val.trim()) continue;
                    var cellVal = String(r[k] || "").toLowerCase();
                    var fv = f.val.trim().toLowerCase();
                    if (f.op === "contains" && !cellVal.includes(fv)) return false;
                    if (f.op === "startsWith" && !cellVal.startsWith(fv)) return false;
                    if (f.op === "endsWith" && !cellVal.endsWith(fv)) return false;
                    if (f.op === "equals" && cellVal !== fv) return false;
                    if (f.op === "notEquals" && cellVal === fv) return false;
                }
                return true;
            });
            if (g.sortCol) {
                out.sort(function(a, b) {
                    var av = String(a[g.sortCol] || "").toLowerCase(),
                        bv = String(b[g.sortCol] || "").toLowerCase();
                    return g.sortAsc ? av.localeCompare(bv) : bv.localeCompare(av);
                });
            }
            return out;
        }

        function hasActiveColFilters(g) {
            for (var k in g.colFilters) {
                if (g.colFilters.hasOwnProperty(k) && g.colFilters[k].val && g.colFilters[k].val.trim()) return true;
            }
            return false;
        }

        function renderGrid(g) {
            closePopup();
            var filtered = getFilteredSorted(g);
            var total = filtered.length;
            var pages = Math.max(1, Math.ceil(total / g.pageSize));
            if (g.page >= pages) g.page = 0;
            var start = g.page * g.pageSize;
            var pageRows = filtered.slice(start, start + g.pageSize);
            var gridType = g.containerId === "masterGridContainer" ? "master" : "oracle";

            var html = '<div class="dg-wrap">';

            // ── Toolbar: universal search + count ──
            var showClear = (g.globalSearch.trim() || hasActiveColFilters(g)) ? 'visible' : '';
            html += '<div class="dg-toolbar">';
            html += '<div class="dg-search-wrap">';
            html += '<svg class="dg-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>';
            html += '<input class="dg-search" type="text" placeholder="Search all columns..." value="' + escapeHtml(g.globalSearch) + '" oninput="gridGlobalSearch(\'' + g.containerId + '\',this.value)">';
            html += '</div>';
            html += '<button class="dg-clear-btn ' + showClear + '" onclick="gridClearAll(\'' + g.containerId + '\')">\u2715 Clear filters</button>';
            html += '<span class="dg-count">' + total + ' records</span>';
            html += '</div>';

            // ── Scrollable table ──
            html += '<div class="dg-scroll"><div class="dg-body-scroll">';
            html += '<table class="dg-table"><thead><tr>';
            // pinned action col
            html += '<th class="dg-action"></th>';
            // data columns
            g.columns.forEach(function(c) {
                var sortIcon = '<span class="dg-sort">' + (g.sortCol === c.key ? (g.sortAsc ? '▲' : '▼') : '▼') + '</span>';
                var sortedCls = g.sortCol === c.key ? ' dg-sorted' : '';
                var filterCls = g.colFilters[c.key] && g.colFilters[c.key].val && g.colFilters[c.key].val.trim() ? ' dg-has-filter' : '';
                var filterDot = filterCls ? '<span class="dg-filter-dot"></span>' : '';
                html += '<th class="' + sortedCls + filterCls + '" style="width:' + c.width + 'px;" data-col="' + c.key + '" onclick="gridHeaderClick(event,\'' + g.containerId + '\',\'' + c.key + '\')">';
                html += c.label + sortIcon + filterDot + '<span class="dg-filter-arrow" onclick="event.stopPropagation();openColFilterPopup(\'' + g.containerId + '\',\'' + c.key + '\',event)">\u25BE</span>';
                html += '<div class="dg-resize" onmousedown="gridResizeStart(event,\'' + g.containerId + '\',\'' + c.key + '\')"></div>';
                html += '</th>';
            });
            html += '</tr></thead>';

            // ── Body ──
            html += '<tbody>';
            if (pageRows.length === 0) {
                html += '<tr><td colspan="' + (g.columns.length + 1) + '" class="dg-empty">No records found</td></tr>';
            } else {
                pageRows.forEach(function(r) {
                    html += '<tr>';
                    html += '<td class="dg-action"><button type="button" class="btn-view" onclick="event.preventDefault();event.stopPropagation();openEdit(\'' + gridType + '\',' + r.Id + ')"><i data-lucide="eye" style="width:13px;height:13px;"></i> View</button></td>';
                    g.columns.forEach(function(c) {
                        var val = r[c.key];
                        if (c.key === "Title" && g.containerId === "oracleGridContainer") val = r.Title || r.End_x0020_User_x0020_Email || "";
                        if (val != null && val !== "") {
                            // Format dates and datetimes for display
                            if (c.key.indexOf("Date") > -1 || c.key.indexOf("_x0020_Date") > -1 || c.key === "Created" || c.key === "Modified" ||
                                c.key === "Email_x0020_Received" || c.key === "Logged_x0020_in_x0020_SP" || c.key === "Completed_x0020_Date") {
                                val = formatDateForDisplay(val);
                            }
                            html += '<td style="width:' + c.width + 'px;">' + String(val) + '</td>';
                        } else {
                            html += '<td style="width:' + c.width + 'px;"></td>';
                        }
                    });
                    html += '</tr>';
                });
            }
            html += '</tbody></table>';
            html += '</div></div>';

            // ── Status bar + pagination ──
            var showing = pageRows.length > 0 ? (start + 1) + "-" + (start + pageRows.length) + " of " + total : "0";
            html += '<div class="dg-statusbar">';
            html += '<span>Showing ' + showing + '</span>';
            html += '<div class="dg-pager">';
            html += '<select onchange="gridPageSize(\'' + g.containerId + '\',+this.value)"><option value="15"' + (g.pageSize === 15 ? ' selected' : '') + '>15/page</option><option value="25"' + (g.pageSize === 25 ? ' selected' : '') + '>25/page</option><option value="50"' + (g.pageSize === 50 ? ' selected' : '') + '>50/page</option><option value="100"' + (g.pageSize === 100 ? ' selected' : '') + '>100/page</option></select>';
            html += '<button ' + (g.page === 0 ? 'disabled' : '') + ' onclick="gridPage(\'' + g.containerId + '\',' + (g.page - 1) + ')">‹</button>';
            var s = Math.max(0, g.page - 2),
                e = Math.min(pages, g.page + 3);
            for (var i = s; i < e; i++) html += '<button class="' + (i === g.page ? 'active' : '') + '" onclick="gridPage(\'' + g.containerId + '\',' + i + ')">' + (i + 1) + '</button>';
            html += '<button ' + (g.page >= pages - 1 ? 'disabled' : '') + ' onclick="gridPage(\'' + g.containerId + '\',' + (g.page + 1) + ')">›</button>';
            html += '</div></div>';
