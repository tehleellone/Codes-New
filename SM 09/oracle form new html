        function previewCSV() {
            var file = document.getElementById("bulkFileInput").files[0];
            if (!file) return;
            document.getElementById("bulkAlert").innerHTML = "";
            bulkIdSeq = null;
            var reader = new FileReader();
            reader.onload = function(e) {
                var lines = e.target.result.trim().split(/\r?\n/);
                if (lines.length < 2) {
                    alert_("bulkAlert", "error", "Need header + data rows");
                    return;
                }
                var rawHeaders = lines[0].split(",").map(function(h) {
                    return h.trim().replace(/"/g, "");
                });
                bulkHeaders = [];
                rawHeaders.forEach(function(h) {
                    var key = bulkHeaderToKey(h);
                    if (bulkHeaders.indexOf(key) === -1) bulkHeaders.push(key);
                });
                bulkParsedRows = [];
                for (var i = 1; i < lines.length; i++) {
                    if (!lines[i].trim()) continue;
                    var vals = lines[i].split(",").map(function(v) {
                        return v.trim().replace(/"/g, "");
                    });
                    var obj = {};
                    rawHeaders.forEach(function(rawH, idx) {
                        obj[bulkHeaderToKey(rawH)] = vals[idx] || "";
                    });
                    bulkParsedRows.push(obj);
                }
                document.getElementById("bulkPreview").style.display = "block";
                prepareBulkReview();
            };
            reader.readAsText(file);
        }

