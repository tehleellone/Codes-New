            function assignFromSeq(base) {
                var n = base.next;
                needs.forEach(function(r) {
                    setRowRequestId(r, formatRequestId(base.year, base.month, n++));
                });
                bulkIdSeq = {
                    year: base.year,
                    month: base.month,
                    next: n
                };
                if (bulkHeaders.indexOf("RequestID") === -1) {
                    bulkHeaders.unshift("RequestID");
                }
                renderBulkReviewTable();
