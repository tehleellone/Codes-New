      '<label class="filter-label">Status</label>'+
      '<select id="'+idPrefix+'StatusFilter" class="filter-select" onchange="applyFilters()">'+statusOptions+'</select>'+
      '</div>'+
      '<div class="filter-group">'+
      '<label class="filter-label">Age Range</label>'+
      '<select id="'+idPrefix+'AgeFilter" class="filter-select" onchange="applyFilters()">'+
        '<option value="">All Ages</option>'+
        '<option value="0-10">1–10 days</option>'+
        '<option value="11-30">11–30 days</option>'+
        '<option value="31+">31+ days</option>'+
      '</select></div>';
  };

  document.getElementById("chartFilters").innerHTML = block("chart");
  document.getElementById("dataFilters").innerHTML  = block("data");
}

function applyFilters(){
  var activeSection = document.querySelector(".section.active");
  var prefix = activeSection && activeSection.id === "charts" ? "chart" : "data";

  var statusVal = document.getElementById(prefix+"StatusFilter").value || "";
  var ageVal    = document.getElementById(prefix+"AgeFilter").value || "";

  DATA.filtered = DATA.raw.slice();

  if(statusVal){
    DATA.filtered = DATA.filtered.filter(function(r){ return r.status === statusVal; });
  }
  if(ageVal){
    DATA.filtered = DATA.filtered.filter(function(r){
      var a = r.age;
      if(a == null) return false;
      if(ageVal==="0-10") return a>=0 && a<=10;
      if(ageVal==="11-30")return a>=11 && a<=30;
      if(ageVal==="31+")  return a>=31;
      return true;
    });
  }

  renderDashboard();
  renderDataTable();
  renderPagination();
  if(activeSection && activeSection.id === "charts"){ renderCharts(); }
}
function filterByStatus(status){
  // Switch to data section
  var sections = document.querySelectorAll(".section");
  var navItems = document.querySelectorAll(".nav-item");
  sections.forEach(function(s){ s.classList.remove("active"); });
  navItems.forEach(function(n){ n.classList.remove("active"); });
  
  document.getElementById("data").classList.add("active");
  document.querySelector('[data-section="data"]').classList.add("active");
  
  // Apply status filter
  document.getElementById("dataStatusFilter").value = status;
  document.getElementById("dataAgeFilter").value = "";
  
  // Filter the data
  DATA.filtered = DATA.raw.filter(function(r){ return r.status === status; });
  
  // Reset search and pagination
  TABLE_STATE.searchTerm = "";
  TABLE_STATE.currentPage = 1;
  document.getElementById("tableSearch").value = "";
  
  // Render
  renderDataTable();
  renderPagination();
  
  // Scroll to top
  document.querySelector(".content").scrollTop = 0;
}
function filterByAge(ageRange){
  // Switch to data section
  var sections = document.querySelectorAll(".section");
  var navItems = document.querySelectorAll(".nav-item");
  sections.forEach(function(s){ s.classList.remove("active"); });
  navItems.forEach(function(n){ n.classList.remove("active"); });
  
  document.getElementById("data").classList.add("active");
  document.querySelector('[data-section="data"]').classList.add("active");
  
  // Apply age filter
  document.getElementById("dataStatusFilter").value = "";
  document.getElementById("dataAgeFilter").value = ageRange;
  
  // Filter the data
  DATA.filtered = DATA.raw.filter(function(r){
    var a = r.age;
    if(a == null) return false;
    if(ageRange==="0-10") return a>=0 && a<=10;
    if(ageRange==="11-30")return a>=11 && a<=30;
    if(ageRange==="31+")  return a>=31;
    return true;
  });
  
  // Exclude closed statuses from aging filter
  DATA.filtered = DATA.filtered.filter(function(r){
    return CONFIG.closedStatuses.indexOf(r.status) < 0;
  });
  
  // Reset search and pagination
  TABLE_STATE.searchTerm = "";
  TABLE_STATE.currentPage = 1;
  document.getElementById("tableSearch").value = "";
  
  // Render
  renderDataTable();
  renderPagination();
  
  // Scroll to top
  document.querySelector(".content").scrollTop = 0;
}
// ================= DATA TABLE =================
var TABLE_STATE = {
  currentPage: 1,
  rowsPerPage: 25,
  sortColumn: -1,
  sortDirection: "asc",
  searchTerm: ""
};

function buildTableHeaders(){
  var theadRow = document.querySelector(".data-table thead tr");
  if(!theadRow) return;
  var html = "";
  COLUMNS.forEach(function(col, idx){
    html += '<th onclick="sortTable('+idx+')" style="min-width:'+col.minWidth+'">'+
      col.header+' <i data-lucide="chevrons-up-down" class="sort-icon"></i></th>';
  });
  theadRow.innerHTML = html;
  lucide.createIcons();
}

function getFilteredTableData(){
  var filtered = DATA.filtered.slice();

  // search
  if(TABLE_STATE.searchTerm){
    var term = TABLE_STATE.searchTerm;
    filtered = filtered.filter(function(item){
      for(var i=0;i<COLUMNS.length;i++){
        var col = COLUMNS[i];
        if(!col.searchable) continue;
        var v = item[col.field];
        if(v === null || v === undefined) continue;
        var txt = col.type==="date" ? formatDate(v).toLowerCase()
                                    : v.toString().toLowerCase();
        if(txt.indexOf(term)>=0) return true;
      }
      return false;
    });
  }

  // sort
  if(TABLE_STATE.sortColumn >= 0){
    var col = COLUMNS[TABLE_STATE.sortColumn];
    filtered.sort(function(a,b){
      var av = a[col.field], bv = b[col.field];
      if(col.type === "date"){
        av = av ? new Date(av).getTime() : 0;
        bv = bv ? new Date(bv).getTime() : 0;
      }
      if(av < bv) return TABLE_STATE.sortDirection==="asc" ? -1 : 1;
      if(av > bv) return TABLE_STATE.sortDirection==="asc" ? 1 : -1;
      return 0;
    });
  }
  return filtered;
}

function renderDataTable(){
  var tbody = document.getElementById("dataTableBody");
  if(!tbody) return;

  var rows = getFilteredTableData();
  var start = (TABLE_STATE.currentPage-1)*TABLE_STATE.rowsPerPage;
  var end   = start + TABLE_STATE.rowsPerPage;
  var pageRows = rows.slice(start,end);

  var html = "";
  pageRows.forEach(function(item){
    html += "<tr>";
    COLUMNS.forEach(function(col){
      var v = item[col.field];
      var cell;
      if(col.type === "status"){
        var cls = "status-pill ";
        if(CONFIG.closedStatuses.indexOf(v)>=0) cls += "status-completed";
        else if(v && v.indexOf("Process")>=0)   cls += "status-inprocess";
        else if(v && v.indexOf("Pending")>=0)   cls += "status-pending";
        else                                    cls += "status-onhold";
        cell = '<span class="'+cls+'">'+safeValue(v)+'</span>';
      }else if(col.type === "date"){
        cell = formatDate(v);
      }else{
        cell = safeValue(v);
      }
      html += "<td>"+cell+"</td>";
    });
    html += "</tr>";
  });

  if(!html){
    html = '<tr><td colspan="'+COLUMNS.length+'" style="text-align:center;padding:1rem;">No data available</td></tr>';
  }
  tbody.innerHTML = html;
  updateSortIcons();
}

function updateSortIcons(){
  var headers = document.querySelectorAll(".data-table th");
  headers.forEach(function(th, idx){
    var icon = th.querySelector(".sort-icon");
    if(!icon) return;
    if(TABLE_STATE.sortColumn === idx){
      icon.setAttribute("data-lucide", TABLE_STATE.sortDirection==="asc" ? "chevron-up" : "chevron-down");
    }else{
      icon.setAttribute("data-lucide", "chevrons-up-down");
    }
  });
  lucide.createIcons();
}

function sortTable(idx){
  if(TABLE_STATE.sortColumn === idx){
    TABLE_STATE.sortDirection = TABLE_STATE.sortDirection === "asc" ? "desc" : "asc";
  }else{
    TABLE_STATE.sortColumn = idx;
    TABLE_STATE.sortDirection = "asc";
  }
  renderDataTable();
  renderPagination();
}

var searchTimer;
function searchTable(){
  clearTimeout(searchTimer);
  searchTimer = setTimeout(function(){
    var term = document.getElementById("tableSearch").value.toLowerCase();
    TABLE_STATE.searchTerm = term;
    TABLE_STATE.currentPage = 1;
    renderDataTable();
    renderPagination();
  }, 250);
}

function changePage(p){
  TABLE_STATE.currentPage = p;
  renderDataTable();
  renderPagination();
}
function changeRowsPerPage(v){
  TABLE_STATE.rowsPerPage = parseInt(v, 10);
  TABLE_STATE.currentPage = 1;
  renderDataTable();
  renderPagination();
}

function exportDataCSV(){
  var rows = getFilteredTableData();
  if(!rows.length){
    alert("No data to export.");
    return;
  }
  var lines = [COLUMNS.map(function(c){ return c.header; }).join(",")];
  rows.forEach(function(item){
    var vals = COLUMNS.map(function(col){
      var v = item[col.field];
      if(col.type === "date") v = formatDate(v);
      if(v == null || v === undefined) v = "";
      v = String(v).replace(/"/g, '""');
      if(v.indexOf(",") >= 0 || v.indexOf('"') >= 0 || v.indexOf("\n") >= 0) v = '"' + v + '"';
      return v;
    });
    lines.push(vals.join(","));
  });
  var blob = new Blob([lines.join("\n")], { type: "text/csv;charset=utf-8;" });
  var link = document.createElement("a");
  link.href = URL.createObjectURL(blob);
  link.download = "Oracle_Activation_Report.csv";
  document.body.appendChild(link);
  link.click();
  document.body.removeChild(link);
  URL.revokeObjectURL(link.href);
}

function renderPagination(){
  var rows = getFilteredTableData();
  var total = rows.length;
  var pages = Math.max(1, Math.ceil(total / TABLE_STATE.rowsPerPage));
  var cur   = Math.min(TABLE_STATE.currentPage, pages);

  TABLE_STATE.currentPage = cur;

  var html = '<div class="rows-per-page">'+
    '<span>Rows per page:</span>'+
    '<select onchange="changeRowsPerPage(this.value)">'+
      '<option value="25"'+(TABLE_STATE.rowsPerPage===25?' selected':'')+'>25</option>'+
      '<option value="50"'+(TABLE_STATE.rowsPerPage===50?' selected':'')+'>50</option>'+
      '<option value="100"'+(TABLE_STATE.rowsPerPage===100?' selected':'')+'>100</option>'+
    '</select></div>';

  html += '<button class="pagination-btn" onclick="changePage(1)" '+(cur===1?'disabled':'')+'>First</button>';
  html += '<button class="pagination-btn" onclick="changePage('+(cur-1)+')" '+(cur===1?'disabled':'')+'>Prev</button>';

  var start = Math.max(1, cur-2);
  var end   = Math.min(pages, cur+2);
  for(var i=start;i<=end;i++){
    html += '<button class="pagination-btn'+(i===cur?' active':'')+'" onclick="changePage('+i+')">'+i+'</button>';
  }

  html += '<button class="pagination-btn" onclick="changePage('+(cur+1)+')" '+(cur===pages?'disabled':'')+'>Next</button>';
  html += '<button class="pagination-btn" onclick="changePage('+pages+')" '+(cur===pages?'disabled':'')+'>Last</button>';
  html += '<span class="table-info" style="margin-left:6px;font-size:.8rem;color:var(--text-secondary);">Page '+cur+' of '+pages+'</span>';

  document.getElementById("paginationControls").innerHTML = html;

  var from = total ? ( (cur-1)*TABLE_STATE.rowsPerPage + 1 ) : 0;
  var to   = Math.min(cur*TABLE_STATE.rowsPerPage, total);
  document.getElementById("tableRowCount").textContent =
    "Showing "+from+"-"+to+" of "+total+" rows";
}

// ================= CUSTOM CHARTS (simple) =================
var customCharts = {};
var customChartCounter = 0;

function addCustomChart(){
  customChartCounter++;
  var id = "customChart"+customChartCounter;
  var canvasId = id+"Canvas";

  var type  = document.getElementById("chartTypeSelect").value;
  var xAxis = document.getElementById("chartXAxisSelect").value;

  var titleText = (type.charAt(0).toUpperCase()+type.slice(1)) + " – " +
                  (xAxis === "status" ? "Status" : "Age Bucket");

  var html = '<div class="card" id="'+id+'">'+
    '<div class="card-header">'+
      '<div><div class="card-title">'+titleText+'</div></div>'+
      '<button type="button" class="pagination-btn" style="padding:0.2rem 0.6rem;font-size:.75rem;" onclick="removeCustomChart(\''+id+'\')">'+
        '<i data-lucide="x-circle" style="width:14px;height:14px;"></i>&nbsp;Remove</button>'+
    '</div>'+
    '<canvas id="'+canvasId+'" style="width:100%;height:220px;"></canvas>'+
  '</div>';

  document.getElementById("customChartsContainer").insertAdjacentHTML("beforeend", html);
  lucide.createIcons();

  customCharts[id] = { canvasId: canvasId, type: type, xAxis: xAxis };
  renderCustomChart(id);
}

function removeCustomChart(id){
  var el = document.getElementById(id);
  if(el) el.remove();
  delete customCharts[id];
}

function aggregateForCustom(xAxis){
  var agg = {};
  DATA.filtered.forEach(function(r){
    var key = xAxis === "status" ? r.status : getAgeBucket(r.age);
    key = key || "Unknown";
    if(!agg[key]) agg[key] = 0;
    agg[key]++;
  });
  var res = [];
  for(var k in agg){ if(agg.hasOwnProperty(k)) res.push({label:k,value:agg[k]}); }
  res.sort(function(a,b){ return b.value - a.value; });
  return res.slice(0,10);
}

function renderCustomChart(id){
  var cfg = customCharts[id];
  if(!cfg) return;
  var canvas = document.getElementById(cfg.canvasId);
  if(!canvas) return;
  var ctx = canvas.getContext("2d");

  canvas.width  = canvas.clientWidth || 500;
  canvas.height = 220;

  var data = aggregateForCustom(cfg.xAxis);
  if(!data.length){ ctx.clearRect(0,0,canvas.width,canvas.height); return; }

  if(cfg.type === "bar")  renderCustomBar(ctx, canvas, data);
  if(cfg.type === "line") renderCustomLine(ctx, canvas, data);
  if(cfg.type === "pie" || cfg.type === "donut")
    renderCustomPie(ctx, canvas, data, cfg.type === "donut");
}

function renderCustomBar(ctx, canvas, data){
  var isLight = document.body.classList.contains("light-theme");
  var isCyan  = document.body.classList.contains("cyan-theme");
  var textColor  = isLight ? "#0f172a" : "#e5e7eb";
  var labelColor = isLight ? "#6b7280" : "#9ca3af";

  var w = canvas.width, h = canvas.height;
  var padding = 40;
  var chartW = w - padding*2;
  var chartH = h - padding*2;
  var barW   = Math.min(chartW / data.length * 0.7, 60);
  var maxVal = Math.max.apply(null, data.map(function(d){return d.value;}).concat([1]));

  ctx.clearRect(0,0,w,h);

  data.forEach(function(d, idx){
    var barH = (d.value / maxVal) * chartH;
   var xBase= padding + (chartW/data.length) * idx;
    var x    = xBase + (chartW/data.length - barW)/2;
    var y    = h - padding - barH;

    var grad = ctx.createLinearGradient(x,y,x,h-padding);
    if(isCyan){ grad.addColorStop(0,"#139DCB");grad.addColorStop(1,"#2193C9"); }
    else      { grad.addColorStop(0,"#9248B9");grad.addColorStop(1,"#C724B1"); }
    ctx.fillStyle = grad;
    ctx.fillRect(x,y,barW,barH);

    ctx.fillStyle = textColor;
    ctx.font = "bold 11px Segoe UI";
    ctx.textAlign = "center";
    ctx.fillText(d.value, x+barW/2, y-4);

    ctx.fillStyle = labelColor;
    ctx.font = "10px Segoe UI";
    ctx.save();
    ctx.translate(x+barW/2, h-padding+12);
    ctx.rotate(-Math.PI/4);
    ctx.fillText(d.label.substring(0,14),0,0);
    ctx.restore();
  });
}

function renderCustomLine(ctx, canvas, data){
  var isLight = document.body.classList.contains("light-theme");
  var isCyan  = document.body.classList.contains("cyan-theme");
 var textColor  = isLight ? "#0f172a" : "#e5e7eb";
  var labelColor = isLight ? "#6b7280" : "#9ca3af";

  var w = canvas.width, h = canvas.height;
  var padding = 40;
  var chartW = w - padding*2;
  var chartH = h - padding*2;
  var maxVal = Math.max.apply(null, data.map(function(d){return d.value;}).concat([1]));

  ctx.clearRect(0,0,w,h);

  ctx.beginPath();
  ctx.lineWidth = 3;
  ctx.strokeStyle = isCyan ? "#139DCB" : "#9248B9";

  data.forEach(function(d, idx){
    var x = padding + (chartW/(data.length-1)) * idx;
    var y = h - padding - (d.value/maxVal)*chartH;
    if(idx===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
  });
  ctx.stroke();

  data.forEach(function(d, idx){
    var x = padding + (chartW/(data.length-1)) * idx;
    var y = h - padding - (d.value/maxVal)*chartH;
    ctx.beginPath();
    ctx.arc(x,y,4,0,Math.PI*2);
    ctx.fillStyle = isCyan ? "#2193C9" : "#C724B1";
    ctx.fill();

    ctx.fillStyle = textColor;
    ctx.font = "bold 11px Segoe UI";
   ctx.textAlign = "center";
    ctx.fillText(d.value, x, y-8);

    ctx.fillStyle = labelColor;
    ctx.font = "10px Segoe UI";
    ctx.save();
    ctx.translate(x, h-padding+12);
    ctx.rotate(-Math.PI/4);
    ctx.fillText(d.label.substring(0,14),0,0);
    ctx.restore();
  });
}

function renderCustomPie(ctx, canvas, data, isDonut){
  var isLight = document.body.classList.contains("light-theme");
  var isCyan  = document.body.classList.contains("cyan-theme");
  var textColor = isLight ? "#0f172a" : "#e5e7eb";

  var w = canvas.width, h = canvas.height;
  var cx = w/2, cy = h/2;
  var radius = Math.min(w,h)/2 - 50;

  var total = data.reduce(function(s,d){return s+d.value;},0);
  var colors = isCyan ?
    ["#139DCB","#2193C9","#7B56BB","#9248B9","#AF33B5","#C724B1"] :
    ["#C724B1","#AF33B5","#9248B9","#7B56BB","#2193C9","#139DCB"];

  ctx.clearRect(0,0,w,h);
  var start = -Math.PI/2;

  data.forEach(function(d, idx){
    var slice = (d.value/total)*Math.PI*2;
    ctx.beginPath();
    ctx.arc(cx,cy,radius,start,start+slice);
    if(isDonut){
      ctx.arc(cx,cy,radius*0.5,start+slice,start,true);
    }else{
      ctx.lineTo(cx,cy);
    }
    ctx.closePath();
    ctx.fillStyle = colors[idx%colors.length];
    ctx.fill();

    var mid = start + slice/2;
    var r   = isDonut ? radius*0.75 : radius*0.7;
    var lx  = cx + Math.cos(mid)*r;
    var ly  = cy + Math.sin(mid)*r;
    ctx.fillStyle = "#fff";
    ctx.font = "11px Segoe UI";
    ctx.textAlign = "center";
    ctx.fillText(d.value, lx, ly);

    start += slice;
  });

  // legend
  var ly = 20;
  data.forEach(function(d, idx){
    ctx.fillStyle = colors[idx%colors.length];
    ctx.fillRect(18, ly, 12, 12);
   ctx.fillStyle = textColor;
    ctx.font = "10px Segoe UI";
    ctx.textAlign = "left";
    ctx.fillText(d.label.substring(0,18)+": "+d.value, 36, ly+10);
    ly += 18;
  });
}

// ================= MASTER DATA COUNTS =================
function loadMasterCounts(){
  var site = (typeof _spPageContextInfo !== "undefined" && _spPageContextInfo.webAbsoluteUrl) || location.origin;
  var url  = site.replace(/\/$/, "") + "/_api/web/lists/getbytitle('Master Data')/items?$select=Current_Status,Contract_x0020_End_x0020_Date_x00&$top=5000";

  var xhr = new XMLHttpRequest();
  xhr.open("GET", url, true);
  xhr.setRequestHeader("Accept","application/json;odata=verbose");
  xhr.onreadystatechange = function(){
    if(xhr.readyState === 4){
      if(xhr.status >= 200 && xhr.status < 300){
        try{
          var json = JSON.parse(xhr.responseText);
          var rows = json.value || (json.d && json.d.results) || [];
          var today = new Date();
          today.setHours(0, 0, 0, 0);
          var activeUsers = 0;
          var handsets = 0;

          rows.forEach(function(r){
            var status = (r.Current_Status || "").toString().trim().toLowerCase();
            if(status === "active") activeUsers++;
            if(status === "active"){
              var hsEndRaw = r.Contract_x0020_End_x0020_Date_x00;
              if(hsEndRaw){
                var hsEnd = new Date(hsEndRaw);
                if(!isNaN(hsEnd)){
                  hsEnd.setHours(0, 0, 0, 0);
                  if(hsEnd > today) handsets++;
                }
              }
            }
          });

          MASTER_STATS.activeUsers = activeUsers;
          MASTER_STATS.handsets = handsets;
          updateTopMetrics();
        }catch(e){
          console.error("Error parsing Master Data response", e);
        }
      }else{
        console.error("Error loading Master Data:", xhr.status, xhr.responseText);
      }
    }
  };
  xhr.send();
}

function updateTopMetrics(){
  var au = document.getElementById("activeUsersValue");
  var hs = document.getElementById("handsetsValue");
  if(!au || !hs) return;

  if(MASTER_STATS.activeUsers != null){
    au.textContent = Number(MASTER_STATS.activeUsers).toLocaleString("en-US");
  }else{
    au.textContent = "-";
  }
  if(MASTER_STATS.handsets != null){
    hs.textContent = Number(MASTER_STATS.handsets).toLocaleString("en-US");
  }else{
    hs.textContent = "-";
  }
}

