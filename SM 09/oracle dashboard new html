function renderStatusChart(){
  var canvas = document.getElementById("statusChart");
  if(!canvas) return;
  var ctx = canvas.getContext("2d");

  canvas.width  = canvas.clientWidth || 500;
  canvas.height = 260;

  var counts = getStatusCounts();
  var labels = CONFIG.statuses;
  var values = labels.map(function(s){ return counts[s]; });
  var maxVal = Math.max.apply(null, values.concat([1]));

  var isLight = document.body.classList.contains("light-theme");
  var isCyan  = document.body.classList.contains("cyan-theme");
  var textColor  = isLight ? "#0f172a" : "#e5e7eb";
  var labelColor = isLight ? "#6b7280" : "#9ca3af";

  var padding = 40;
  var w = canvas.width;
  var h = canvas.height;
  var chartW = w - padding*2;
  var chartH = h - padding*2;
  var barW   = chartW / labels.length * 0.7;

  ctx.clearRect(0,0,w,h);

  labels.forEach(function(label, idx){
    var val   = values[idx];
    var barH  = (val / maxVal) * chartH;
    var xBase = padding + (chartW / labels.length) * idx;
    var x     = xBase + (chartW/labels.length - barW)/2;
    var y     = h - padding - barH;

    var grad = ctx.createLinearGradient(x,y,x,h-padding);
    if(isCyan){ grad.addColorStop(0,"#139DCB"); grad.addColorStop(1,"#2193C9"); }
    else      { grad.addColorStop(0,"#9248B9"); grad.addColorStop(1,"#C724B1"); }

    ctx.fillStyle = grad;
    ctx.fillRect(x,y,barW,barH);

    ctx.fillStyle = textColor;
    ctx.font = "bold 12px Segoe UI";
    ctx.textAlign = "center";
    ctx.fillText(val, x+barW/2, y-4);

    ctx.fillStyle = labelColor;
    ctx.font = "10px Segoe UI";
    ctx.save();
    ctx.translate(x+barW/2, h-padding+12);
    ctx.rotate(-Math.PI/4);
    ctx.fillText(label.substring(0,14), 0, 0);
    ctx.restore();
  });
}

function renderAgingChart(){
  var canvas = document.getElementById("agingChart");
  if(!canvas) return;
  var ctx = canvas.getContext("2d");

  canvas.width  = canvas.clientWidth || 500;
  canvas.height = 260;

  var buckets = getAgingBuckets();
  var total   = buckets.reduce(function(sum,b){return sum+b.count;},0);
  if(!total){
    ctx.clearRect(0,0,canvas.width,canvas.height);
    return;
  }

  var isLight = document.body.classList.contains("light-theme");
  var isCyan  = document.body.classList.contains("cyan-theme");
  var textColor = isLight ? "#0f172a" : "#e5e7eb";

  var w = canvas.width, h = canvas.height;
  var cx = w/2, cy = h/2;
  var radius = Math.min(w,h)/2 - 40;

  var colors = isCyan ?
    ["#139DCB","#2193C9","#9248B9"] :
    ["#C724B1","#AF33B5","#9248B9"];

  ctx.clearRect(0,0,w,h);
  var start = -Math.PI/2;

  buckets.forEach(function(b, idx){
    var slice = (b.count / total) * Math.PI*2;
    ctx.beginPath();
    ctx.moveTo(cx,cy);
    ctx.arc(cx,cy,radius,start,start+slice);
    ctx.closePath();
    ctx.fillStyle = colors[idx%colors.length];
    ctx.fill();

    var mid = start + slice/2;
    var lx = cx + Math.cos(mid) * (radius*0.7);
    var ly = cy + Math.sin(mid) * (radius*0.7);
    ctx.fillStyle = "#fff";
    ctx.font = "bold 12px Segoe UI";
    ctx.textAlign = "center";
    ctx.fillText(b.count, lx, ly);

    start += slice;
  });

  // legend
  var ly = 20;
  buckets.forEach(function(b, idx){
    ctx.fillStyle = colors[idx%colors.length];
    ctx.fillRect(18, ly, 12, 12);
    ctx.fillStyle = textColor;
    ctx.font = "11px Segoe UI";
    ctx.textAlign = "left";
    ctx.fillText(b.label+": "+b.count, 36, ly+10);
    ly += 18;
  });
}

