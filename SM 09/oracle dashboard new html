<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Oracle Service Request Portal</title>

<!-- Lucide Icons - LOCAL VERSION -->
<script src="http://sharedspaces:8086/sites/OP/Shared%20Documents/lucide.min.js"></script>

<style>
* { margin: 0; padding: 0; box-sizing: border-box; }

/* Hide SharePoint page title "Dashboard" */
h1.ms-core-pageTitle,
.ms-core-pageTitle {
  display: none !important;
}

/* THEMES */
:root {
  --bg-primary: linear-gradient(135deg, #1a0a27 0%, #2a1a3a 50%, #1d0f19 100%);
  --bg-card: rgba(26, 10, 39, 0.7);
  --bg-header: rgba(26, 10, 39, 0.9);
  --bg-sidebar: rgba(26, 10, 39, 0.85);
  --border-color: rgba(146, 72, 185, 0.25);
  --border-hover: rgba(146, 72, 185, 0.6);
  --text-primary: #FFFDFE;
  --text-secondary: #cbd5e1;
  --text-muted: #94a3b8;
  --table-hover: rgba(146, 72, 185, 0.05);
}

/* Light mode for Magenta */
body.light-theme {
  --bg-primary: linear-gradient(135deg, #fdf0fc 0%, #f5e6ff 50%, #fef8ff 100%);
  --bg-card: rgba(255, 255, 255, 0.96);
  --bg-header: rgba(255, 255, 255, 0.98);
  --bg-sidebar: rgba(250, 235, 255, 0.98);
  --border-color: rgba(146, 72, 185, 0.18);
  --border-hover: rgba(146, 72, 185, 0.4);
  --text-primary: #1e293b;
  --text-secondary: #475569;
  --text-muted: #64748b;
  --table-hover: rgba(146, 72, 185, 0.06);
}

/* Cyan Theme (dark) */
body.cyan-theme {
  --bg-primary: linear-gradient(135deg, #0a1a27 0%, #1a2a3a 50%, #0f1d19 100%);
  --bg-card: rgba(10, 26, 39, 0.75);
  --bg-header: rgba(10, 26, 39, 0.95);
  --bg-sidebar: rgba(10, 26, 39, 0.9);
  --border-color: rgba(19, 157, 203, 0.25);
  --border-hover: rgba(19, 157, 203, 0.6);
  --text-primary: #f9fafb;
  --text-secondary: #e5e7eb;
  --text-muted: #9ca3af;
  --table-hover: rgba(19, 157, 203, 0.06);
}

/* Cyan Theme (light) */
body.cyan-theme.light-theme {
  --bg-primary: linear-gradient(135deg, #f0f9ff 0%, #e6f4ff 50%, #f8fcff 100%);
  --bg-card: rgba(255, 255, 255, 0.96);
  --bg-header: rgba(255, 255, 255, 0.98);
  --bg-sidebar: rgba(227, 245, 255, 0.98);
  --border-color: rgba(19, 157, 203, 0.18);
  --border-hover: rgba(19, 157, 203, 0.4);
  --text-primary: #0f172a;
  --text-secondary: #1f2937;
  --text-muted: #6b7280;
  --table-hover: rgba(19, 157, 203, 0.06);
}

/* Cyan theme accents */
body.cyan-theme .logo {
  background: linear-gradient(135deg, #139DCB, #2193C9);
  box-shadow: 0 0 20px rgba(19, 157, 203, 0.5);
}
body.cyan-theme .header-title,
body.cyan-theme .section-title {
  background: linear-gradient(135deg, #139DCB, #2193C9, #9248B9);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
body.cyan-theme .card-icon,
body.cyan-theme .status-badge {
  background: linear-gradient(135deg, rgba(19, 157, 203, 0.18), rgba(33, 147, 201, 0.18));
}

/* Base body + background */
body {
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
  background: var(--bg-primary);
  color: var(--text-primary);
  overflow-y: auto;
}

/* Background Particles Container */
.bg-particles {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  pointer-events: none;
  z-index: 0;
}

/* PORTAL SHELL – one rounded card */
.portal-shell {
  max-width: 1400px;
  margin: 12px auto 24px;
  padding: 10px 14px 18px;
  border-radius: 22px;
  background: radial-gradient(circle at top left,
              rgba(255, 255, 255, 0.08),
              transparent 55%) ,
              rgba(15, 23, 42, 0.65);
  box-shadow: 0 22px 40px rgba(15, 23, 42, 0.65);
  position: relative;
  z-index: 2;
}
body.light-theme .portal-shell {
  background: radial-gradient(circle at top left,
              rgba(248, 244, 255, 0.95),
              rgba(253, 242, 255, 0.98));
  box-shadow: 0 18px 32px rgba(148, 163, 184, 0.45);
}

/* Header */
.header {
  background: var(--bg-header);
  backdrop-filter: blur(10px);
  border-radius: 16px 16px 0 0;
  border: 1px solid var(--border-color);
  border-bottom: none;
  padding: 0.9rem 1.5rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.logo {
  width: 40px;
  height: 40px;
  background: linear-gradient(135deg, #AF33B5, #C724B1);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 900;
  font-size: 1.4rem;
  box-shadow: 0 0 20px rgba(199, 36, 177, 0.55);
  position: relative;
  z-index: 2;
}

.signal-waves {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 80px; height: 80px;
  pointer-events: none;
  z-index: 1;
}
.signal-wave {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  border: 2px solid rgba(146, 72, 185, 0.4);
  border-radius: 50%;
  animation: signalPulse 3s ease-out infinite;
}
.signal-wave:nth-child(2){ animation-delay:1s;}
.signal-wave:nth-child(3){ animation-delay:2s;}

@keyframes signalPulse {
  0% { width:40px;height:40px;opacity:1; }
  100% { width:100px;height:100px;opacity:0; }
}

.header-title {
  font-size: 1.4rem;
  font-weight: 700;
  background: linear-gradient(135deg, #C724B1, #9248B9, #139DCB);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.color-scheme-selector {
  padding: 0.45rem 0.9rem;
  background: rgba(15, 23, 42, 0.6);
  border: 1px solid var(--border-color);
  border-radius: 20px;
  color: var(--text-primary);
  font-size: 0.8rem;
  cursor: pointer;
  transition: all 0.25s;
}
.color-scheme-selector:hover,
.color-scheme-selector:focus {
  border-color: var(--border-hover);
  outline: none;
  box-shadow: 0 0 12px rgba(146, 72, 185, 0.35);
}

.theme-toggle {
  width: 38px; height: 38px;
  border-radius: 50%;
  background: rgba(15, 23, 42, 0.65);
  border: 1px solid var(--border-color);
 display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.25s;
  font-size: 1.1rem;
}
.theme-toggle:hover {
  transform: scale(1.06) rotate(10deg);
  border-color: var(--border-hover);
  box-shadow: 0 0 16px rgba(146, 72, 185, 0.35);
}

/* NEW: make theme selector + toggle light in light-theme */
body.light-theme .color-scheme-selector {
  background: #f9fafb;
  color: #111827;
  border-color: rgba(148, 163, 184, 0.8);
  box-shadow: 0 0 10px rgba(148, 163, 184, 0.45);
}
body.light-theme .theme-toggle {
  background: #f9fafb;
  color: #111827;
  border-color: rgba(148, 163, 184, 0.8);
  box-shadow: 0 0 10px rgba(148, 163, 184, 0.45);
}

.status-badge {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.35rem 0.9rem;
  background: rgba(19, 157, 203, 0.1);
  border: 1px solid rgba(19, 157, 203, 0.35);
  border-radius: 20px;
  font-size: 0.8rem;
}
.status-dot {
  width: 7px;height:7px;
  border-radius: 50%;
  background:#139DCB;
  animation:pulse 2s infinite;
}
@keyframes pulse{
  0%,100%{opacity:1;box-shadow:0 0 7px #139DCB;}
  50%{opacity:.5;box-shadow:0 0 13px #139DCB;}
}

/* MAIN LAYOUT */
.main-container {
 display: flex;
  height: auto;
  max-height: calc(100vh - 150px);
  border-radius: 0 0 16px 16px;
  border: 1px solid var(--border-color);
  border-top: none;
  overflow: hidden;
  background: linear-gradient(120deg,
              rgba(255,255,255,0.04),
              rgba(255,255,255,0.02));
}

/* Sidebar */
.sidebar {
  width: 240px;
  background: linear-gradient(180deg,
              rgba(252, 231, 255, 0.96),
              rgba(248, 232, 255, 0.98));
  backdrop-filter: blur(14px);
  border-right: 1px solid rgba(248, 187, 255, 0.7);
  padding: 1.5rem 0;
  transition: width 0.3s;
  position: relative;
}
body:not(.light-theme) .sidebar {
  background: linear-gradient(180deg,
              rgba(40, 16, 65, 0.98),
              rgba(32, 12, 55, 0.98));
}

.sidebar.collapsed { width: 78px; }

.sidebar-toggle {
  position: absolute;
  top: 0.8rem;
  right: -14px;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: linear-gradient(135deg, #9248B9, #AF33B5);
  border: 2px solid rgba(26, 10, 39, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  box-shadow: 0 0 12px rgba(146, 72, 185, 0.6);
  color: #fff;
  font-size: 0.8rem;
}
.sidebar-toggle:hover { transform: scale(1.05); }

.nav-items {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  padding: 0 0.9rem;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: 0.9rem;
  padding: 0.7rem 0.9rem;
  border-radius: 12px;
  cursor: pointer;
  position: relative;
  transition: all 0.25s;
}
.nav-item::before{
  content:'';
  position:absolute;
  left:0;top:0;
  width:3px;height:100%;
  background: linear-gradient(180deg,#C724B1,#9248B9);
  transform:scaleY(0);
  transition:transform 0.25s;
}
.nav-item:hover{
  background:rgba(199,36,177,0.06);
}
.nav-item.active{
  background:rgba(199,36,177,0.12);
  border:1px solid rgba(199,36,177,0.35);
}
.nav-item.active::before{ transform:scaleY(1); }

.nav-icon{
  width:24px;height:24px;
  display:flex;
  align-items:center;
  justify-content:center;
}
.nav-label{
  font-size:0.9rem;
  font-weight:500;
}
.sidebar.collapsed .nav-label{
  opacity:0;
  width:0;
}

/* CONTENT */
.content {
  flex: 1;
  padding: 1.3rem 1.4rem 1.4rem;
  overflow-y: auto;
  background: linear-gradient(180deg,
              rgba(255, 255, 255, 0.96),
              rgba(253, 244, 255, 0.98));
}
body:not(.light-theme) .content{
  background: radial-gradient(circle at top,
              rgba(32, 10, 52, 0.96),
              rgba(12, 10, 25, 0.98));
}

/* SECTION HEADER */
.section-header {
  margin-bottom: 1.1rem;
  padding-top: 0.4rem;
}
.section-title{
  font-size:1.45rem;
  font-weight:700;
  background:linear-gradient(135deg,#C724B1,#9248B9,#139DCB);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}

/* SECTIONS */
.section{ display:none; animation:fadeIn .4s;}
.section.active{ display:block;}

@keyframes fadeIn{
  from{opacity:0;transform:translateY(10px);}
  to{opacity:1;transform:translateY(0);}
}

/* TOP METRICS (Active Users + Handsets) */
.top-metrics-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:1rem;
  margin-bottom:1.1rem;
}
.metric-card .card-value{
  font-size:2.1rem;
}

/* Cards */
.cards-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:1rem;
  margin-bottom:1rem;
}
.card{
  background:var(--bg-card);
  backdrop-filter:blur(10px);
  border-radius:16px;
  border:1px solid var(--border-color);
  padding:1rem 1.1rem;
  position:relative;
  overflow:hidden;
  transition:all .25s;
}
.card:hover{
  transform:translateY(-3px);
  box-shadow:0 10px 22px rgba(0,0,0,0.28);
  border-color:var(--border-hover);
}
.card::before{
  content:'';
  position:absolute;
  top:0;left:0;
  width:100%;height:3px;
  background:linear-gradient(90deg,#C724B1,#9248B9,#139DCB);
}

.card-header{
  display:flex;
  justify-content:space-between;
  align-items:flex-start;
  margin-bottom:0.6rem;
}
.card-title{
  font-size:.8rem;
  text-transform:uppercase;
  color:var(--text-muted);
  letter-spacing:.05em;
}
.card-value{
  font-size:2.1rem;
  font-weight:700;
  margin-top:0.2rem;
  background:linear-gradient(135deg,#9248B9,#C724B1);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
}
.card-label{
  font-size:.88rem;
  color:var(--text-secondary);
}
.card-icon{
  width:36px;height:36px;
  border-radius:12px;
  background:linear-gradient(135deg,rgba(146,72,185,0.2),rgba(199,36,177,0.2));
  display:flex;align-items:center;justify-content:center;
}

/* Progress bar in cards */
.progress-bar{
  width:100%;height:6px;
  border-radius:4px;
  background:rgba(146,72,185,0.1);
  overflow:hidden;
  margin-top:.4rem;
}
.progress-fill{
  height:100%;
  border-radius:4px;
  background:linear-gradient(90deg,#9248B9,#C724B1);
}

/* Data table */
.table-container{
  background:var(--bg-card);
  border-radius:16px;
  border:1px solid var(--border-color);
  padding:0.6rem;
}
.table-wrapper{
  max-height:calc(100vh - 310px);
  overflow:auto;
}
.data-table{
  width:100%;
  border-collapse:collapse;
}
.data-table thead{
  position:sticky;
  top:0;
  background:linear-gradient(135deg,rgba(146,72,185,1) 0%,rgba(99,102,241,0.98) 100%);
}
body.light-theme .data-table thead{
  background:linear-gradient(135deg,rgba(146,72,185,.2),rgba(99,102,241,.2));
}
.data-table th,
.data-table td{
  padding:0.6rem 0.8rem;
  border-bottom:1px solid var(--border-color);
  font-size:.85rem;
  white-space:nowrap;
}
.data-table th{
  color:var(--text-primary);
  text-transform:uppercase;
  letter-spacing:.06em;
  cursor:pointer;
}
.data-table tbody tr:hover{
  background:var(--table-hover);
}
.status-pill{
  display:inline-block;
  padding:0.2rem 0.6rem;
  border-radius:999px;
  font-size:.72rem;
  text-transform:uppercase;
  letter-spacing:.06em;
}
.status-completed{background:rgba(34,197,94,0.18);color:#4ade80;border:1px solid rgba(34,197,94,0.4);}
.status-inprocess{background:rgba(59,130,246,0.18);color:#60a5fa;border:1px solid rgba(59,130,246,0.4);}
.status-pending{background:rgba(251,191,36,0.18);color:#fbbf24;border:1px solid rgba(251,191,36,0.4);}
.status-onhold{background:rgba(239,68,68,0.18);color:#f87171;border:1px solid rgba(239,68,68,0.4);}

/* Search + pagination */
.table-controls{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin:0 0 0.5rem;
  gap:0.8rem;
  flex-wrap:wrap;
}
.table-search{
  flex:1; min-width:220px;
}
.table-search input{
  width:100%;
  padding:0.55rem 0.9rem;
  border-radius:10px;
  border:1px solid var(--border-color);
  background:var(--bg-card);
  color:var(--text-primary);
  font-size:.85rem;
}
.table-search input:focus{
  outline:none;
  border-color:var(--border-hover);
}

.pagination-controls{
  display:flex;
  align-items:center;
  flex-wrap:wrap;
  gap:0.4rem;
  margin-top:0.4rem;
  justify-content:center;
}
.pagination-btn{
  padding:0.35rem 0.75rem;
  border-radius:6px;
  border:1px solid var(--border-color);
  background:var(--bg-card);
  font-size:.8rem;
  cursor:pointer;
}
.pagination-btn.active{
  background:linear-gradient(135deg,#9248B9,#C724B1);
  color:#fff;
}
.rows-per-page{
  display:flex;align-items:center;gap:0.4rem;
  font-size:.8rem;color:var(--text-secondary);
}
.rows-per-page select{
  padding:0.3rem 0.5rem;
  border-radius:6px;
  border:1px solid var(--border-color);
  background:var(--bg-card);
  color:var(--text-primary);
}

/* Simple filters (status + age) */
.filters{
  display:flex;
  flex-wrap:wrap;
  gap:1rem;
  margin-bottom:0.9rem;
}
.filter-group{
  min-width:200px;
  flex:1;
}
.filter-label{
  font-size:.75rem;
  text-transform:uppercase;
  color:var(--text-muted);
  margin-bottom:0.3rem;
}
.filter-select{
  width:100%;
  padding:0.55rem 0.7rem;
  border-radius:8px;
  border:1px solid var(--border-color);
  background:var(--bg-card);
  color:var(--text-primary);
  font-size:.85rem;
}

/* Loading */
.loading{
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  min-height:220px;
  gap:0.6rem;
}
.spinner{
  width:44px;height:44px;
  border-radius:50%;
  border:4px solid rgba(146,72,185,0.15);
  border-top-color:#9248B9;
  animation:spin 1s linear infinite;
}
@keyframes spin{to{transform:rotate(360deg);}}

/* Mobile responsive */
@media(max-width:768px){
  .portal-shell{margin:4px 6px;}
  .sidebar{
    position:fixed;
    left:-240px;top:0;
    height:100vh;
    z-index:900;
 }
  .sidebar.collapsed{ left:0;width:200px;}
  .content{padding:0.9rem;}
}
</style>
</head>
<body>

<div class="bg-particles" id="particles"></div>

<div class="portal-shell">
  <!-- HEADER -->
  <div class="header">
    <div class="logo-section">
      <div class="logo">
        <div class="signal-waves">
          <div class="signal-wave"></div>
          <div class="signal-wave"></div>
          <div class="signal-wave"></div>
        </div>
        <i data-lucide="radio"></i>
      </div>
      <div class="header-title">Oracle Service Request Portal</div>
    </div>
    <div class="header-actions">
      <select class="color-scheme-selector" id="colorSchemeSelector" onchange="switchColorScheme()">
        <option value="magenta">Magenta Theme</option>
        <option value="cyan">Cyan Theme</option>
      </select>
      <div class="theme-toggle" onclick="toggleTheme()">
        <i data-lucide="moon" id="themeIcon"></i>
      </div>
      <div class="status-badge">
        <div class="status-dot"></div>
        <span>Live</span>
      </div>
    </div>
  </div>

  <!-- MAIN -->
  <div class="main-container">
    <!-- SIDEBAR -->
    <div class="sidebar" id="sidebar">
      <div class="sidebar-toggle" onclick="toggleSidebar()">
        <span id="toggleIcon">◀</span>
      </div>
      <div class="nav-items">
        <div class="nav-item active" data-section="dashboard" onclick="switchSection('dashboard')">
          <div class="nav-icon"><i data-lucide="bar-chart-3"></i></div>
          <div class="nav-label">Dashboard</div>
        </div>
        <div class="nav-item" data-section="charts" onclick="switchSection('charts')">
          <div class="nav-icon"><i data-lucide="trending-up"></i></div>
          <div class="nav-label">Analytics</div>
        </div>
        <div class="nav-item" data-section="customCharts" onclick="switchSection('customCharts')">
          <div class="nav-icon"><i data-lucide="pie-chart"></i></div>
          <div class="nav-label">Custom Charts</div>
        </div>
        <div class="nav-item" data-section="data" onclick="switchSection('data')">
          <div class="nav-icon"><i data-lucide="database"></i></div>
          <div class="nav-label">Data View</div>
        </div>
        <div class="nav-item" data-section="reports" onclick="switchSection('reports')">
          <div class="nav-icon"><i data-lucide="file-text"></i></div>
          <div class="nav-label">Reports</div>
        </div>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="content">
      <!-- DASHBOARD -->
      <div id="dashboard" class="section active">
        <div class="loading" id="dashboardLoading">
          <div class="spinner"></div>
          <div>Loading dashboard...</div>
        </div>

        <div id="dashboardContent" style="display:none;">
          <!-- Top metrics -->
          <div class="top-metrics-grid">
            <div class="card metric-card">
              <div class="card-header">
                <div>
                  <div class="card-title">Active Users</div>
                  <div class="card-value" id="activeUsersValue">-</div>
                </div>
                <div class="card-icon"><i data-lucide="users"></i></div>
              </div>
            </div>
            <div class="card metric-card">
              <div class="card-header">
                <div>
                  <div class="card-title">No. of Handsets</div>
                  <div class="card-value" id="handsetsValue">-</div>
                </div>
                <div class="card-icon"><i data-lucide="smartphone"></i></div>
              </div>
            </div>
          </div>

          <!-- Status Overview -->
