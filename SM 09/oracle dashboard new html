function loadData(){
  var site = (typeof _spPageContextInfo !== "undefined" && _spPageContextInfo.webAbsoluteUrl) || location.origin;
  var base = site.replace(/\/$/, "");
var url = base + "/_api/web/lists/getbytitle('" + encodeURIComponent(CONFIG.listTitle) + "')/items" +
            "?$select=Id,Request_ID," +
              encodeURIComponent(CONFIG.statusField) + "," +
              encodeURIComponent(CONFIG.transactionField) + "," +
              "SR_x0020_Date," +
              "Completed_x0020_Date," +
              "Created" +
            "&$top=5000&$format=json";

  var xhr = new XMLHttpRequest();
  xhr.open("GET", url, true);
  xhr.setRequestHeader("Accept","application/json;odata=verbose");
  xhr.onreadystatechange = function(){
    if(xhr.readyState === 4){
      if(xhr.status >= 200 && xhr.status < 300){
        try{
          var json = JSON.parse(xhr.responseText);
          var rows = json.value || (json.d && json.d.results) || [];
