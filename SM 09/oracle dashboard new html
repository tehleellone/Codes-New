// ================= UTILITIES =================
function daysBetween(iso){
  if(!iso) return null;
  var d = new Date(iso);
  if(isNaN(d)) return null;
  return Math.floor((new Date() - d) / (24*3600*1000));
}
function daysBetweenDates(fromIso, toIso){
  if(!fromIso || !toIso) return null;
  var from = new Date(fromIso);
  var to = new Date(toIso);
  if(isNaN(from) || isNaN(to)) return null;
  return Math.floor((to - from) / (24*3600*1000));
}
function calcRecordAge(srDate, completedDate, status){
  if(!srDate) return null;
  var isClosed = CONFIG.closedStatuses.indexOf(status) >= 0;
  if(isClosed && completedDate){
    return daysBetweenDates(srDate, completedDate);
  }
  return daysBetweenDates(srDate, new Date());
}
function formatDate(v){
  if(!v) return "-";
  var d = new Date(v);
  if(isNaN(d)) return "-";
  return d.toLocaleDateString();
}
function safeValue(v){
  if(v === null || v === undefined || v === "") return "-";
  return v.toString();
}

// ================= DATA PROCESSING =================
function processData(rows){
  if(!rows || !rows.length){
    document.getElementById("dashboardLoading").style.display = "none";
    return;
  }

  DATA.raw = rows.map(function(r){
    var srDate      = r.SR_x0020_Date || r.Created;
    var status      = (r[CONFIG.statusField] || r.Status || "").toString();
    var transaction = r[CONFIG.transactionField];
    var completed   = r.Completed_x0020_Date;

    var item = {
      id: r.Id || r.ID,
      requestId: r.Request_ID || "",
      status: status,
      transactionType: transaction,
      srDate: srDate,
      completedDate: completed,
      created: r.Created,
      age: calcRecordAge(srDate, completed, status)
    };

    item.ageBucket = getAgeBucket(item.age);
    return item;
  });

  DATA.filtered = DATA.raw.slice();

  buildTableHeaders();
  renderDashboard();
  renderDataTable();
  renderFilters();
}
// aging helper used in charts/custom charts
function getAgeBucket(age){
  if(age == null) return "Unknown";
  if(age <= 10) return "1–10 days";
  if(age <= 30) return "11–30 days";
  return "31+ days";
}

// ================= STATUS / AGING STATS =================
function getStatusCounts(){
  var counts = {};
  CONFIG.statuses.forEach(function(s){ counts[s] = 0; });
  DATA.filtered.forEach(function(r){
    if(counts.hasOwnProperty(r.status)){ counts[r.status]++; }
  });
  return counts;
}
function getAgingBuckets(){
  var open = DATA.filtered.filter(function(r){
    return CONFIG.closedStatuses.indexOf(r.status) < 0;
  });
  var buckets = [
    { label: "1–10 days",  count: 0, test: function(a){ return a!=null && a>=0 && a<=10; } },
    { label: "11–30 days", count: 0, test: function(a){ return a!=null && a>=11 && a<=30; } },
    { label: "31+ days",   count: 0, test: function(a){ return a!=null && a>=31; } }
  ];
  open.forEach(function(r){
    buckets.forEach(function(b){ if(b.test(r.age)) b.count++; });
  });
  return buckets;
}
function getStatusCountsFromRaw(){
  var counts = {};
  CONFIG.statuses.forEach(function(s){ counts[s] = 0; });
  DATA.raw.forEach(function(r){  // ← Use DATA.raw instead of DATA.filtered
    if(counts.hasOwnProperty(r.status)){ counts[r.status]++; }
  });
  return counts;
}

function getAgingBucketsFromRaw(){
  var open = DATA.raw.filter(function(r){  // ← Use DATA.raw
    return CONFIG.closedStatuses.indexOf(r.status) < 0;
  });
  var buckets = [
    { label: "1–10 days",  count: 0, test: function(a){ return a!=null && a>=0 && a<=10; } },
    { label: "11–30 days", count: 0, test: function(a){ return a!=null && a>=11 && a<=30; } },
    { label: "31+ days",   count: 0, test: function(a){ return a!=null && a>=31; } }
  ];
  open.forEach(function(r){
    buckets.forEach(function(b){ if(b.test(r.age)) b.count++; });
  });
  return buckets;
}
