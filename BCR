#bcr-root [data-lucide]{stroke:currentColor;fill:none;stroke-width:2;flex-shrink:0}
.insight-ico{display:flex;align-items:center;justify-content:center}
.nav-item .nav-icon{display:flex;align-items:center;flex-shrink:0;width:17px;height:17px}
.portal-shell{display:flex!important;flex-direction:column!important;position:relative;z-index:1}
.header{flex-shrink:0;order:1}
.main-container{flex:1;order:2;min-height:0;display:flex}
.dev-console{display:none}
</style>
