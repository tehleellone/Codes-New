    ],y,m,w);
    var ag=buildAgentStats(BCR.filtered).sort(function(a,b){return b.total-a.total;}).slice(0,20);
    y=pdfHead(pdf,'Agent Activity',y,m,12);
    y=pdfTable(pdf,['Agent','Total','Emarati','Non Em.','TDRA','Mgr CB','Top Complaint'],
      ag.map(function(a){ return [a.name,a.total,a.emarati,a.nonEmarati,a.tdra,a.manager,pretty(a.topCat)]; }),y,m,w);
    var byComp={}; BCR.filtered.forEach(function(r){ if(r.Complaint_Summary) byComp[r.Complaint_Summary]=(byComp[r.Complaint_Summary]||0)+1; });
    var cs=Object.keys(byComp).sort(function(a,b){return byComp[b]-byComp[a];});
    y=pdfHead(pdf,'Complaint Breakdown',y,m,12);
    y=pdfTable(pdf,['Complaint','Count','% of Total'],cs.map(function(c){return [pretty(c),byComp[c],pct(byComp[c],s.total)];}),y,m,w);
    // charts (render if hidden)
