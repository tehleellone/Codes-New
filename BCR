.detail-drawer h3{font-size:1rem;font-weight:800;margin-bottom:1rem;color:var(--acc)}
.detail-close{float:right;background:var(--bg-input);border:1px solid var(--border);border-radius:8px;padding:.3rem .7rem;cursor:pointer;font-size:.75rem;color:var(--t1)}
.history-block{margin-top:1rem;padding-top:1rem;border-top:1px solid var(--border)}
.history-item{font-size:.78rem;color:var(--t2);padding:.45rem .6rem;border-left:2px solid var(--nab2);background:var(--bg-secondary);border-radius:6px;margin-bottom:.4rem}
.script-panel{position:fixed;inset:0;z-index:6000;background:rgba(0,0,0,.4);display:none;align-items:center;justify-content:center;padding:1rem}
.script-panel.open{display:flex}
.script-panel-inner{width:min(660px,100%);max-height:85vh;overflow-y:auto;background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:1.25rem;box-shadow:var(--ch)}
.script-acc-item{border:1px solid var(--border);border-radius:10px;margin-bottom:.5rem;overflow:hidden}
.script-acc-head{padding:.75rem 1rem;cursor:pointer;font-weight:700;font-size:.84rem;background:var(--bg-secondary);display:flex;justify-content:space-between;align-items:center;gap:.5rem}
.script-acc-head:hover{background:var(--bg-hover)}
.script-acc-head .chev{transition:transform .2s;flex-shrink:0}
.script-acc-item.open .script-acc-head{color:var(--acc)}
.script-acc-item.open .chev{transform:rotate(180deg)}
.script-acc-body{display:none;padding:.85rem 1rem;font-size:.82rem;color:var(--t2);line-height:1.65;border-top:1px solid var(--border)}
.script-acc-item.open .script-acc-body{display:block}
.agent-mode .sidebar{display:none}
.agent-mode .content{padding:1.5rem}
.agent-form-wrap{max-width:1100px;margin:0 auto}
@media(max-width:900px){.chart-grid{grid-template-columns:1fr}.landing-page{flex-direction:column}}
@media(max-width:768px){.form-grid{grid-template-columns:1fr}.header-center{display:none}}
