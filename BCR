/* ── AG Grid set filter (checkbox list, not "contains") ──── */
function BcrSetFilter(){}
BcrSetFilter.prototype.init=function(params){ this.params=params; this.selected=new Set(); this.gui=document.createElement('div'); this.gui.className='bcr-set-filter'; this._build(); };
BcrSetFilter.prototype._cell=function(data){ if(!data) return '—'; var v=data[this.params.colDef.field]; return (v===null||v===undefined||v==='')?'—':String(v); };
BcrSetFilter.prototype._all=function(){ var vals=new Set(), self=this; this.params.api.forEachNode(function(n){ if(n.data) vals.add(self._cell(n.data)); }); return Array.from(vals).sort(function(a,b){return a.localeCompare(b);}); };
BcrSetFilter.prototype._build=function(){
  var self=this, all=this._all(); this.gui.innerHTML='';
  var search=document.createElement('input'); search.type='text'; search.placeholder='Search...'; search.className='bcr-set-search'; this.gui.appendChild(search);
  var list=document.createElement('div'); list.className='bcr-set-list'; this.gui.appendChild(list);
  function render(term){
    list.innerHTML='';
    all.filter(function(v){return !term||v.toLowerCase().indexOf(term.toLowerCase())>=0;}).forEach(function(v){
      var row=document.createElement('label'); row.className='bcr-set-option';
      var cb=document.createElement('input'); cb.type='checkbox'; cb.checked=self.selected.has(v);
      cb.onchange=function(){ if(cb.checked) self.selected.add(v); else self.selected.delete(v); self.params.filterChangedCallback(); };
      row.appendChild(cb); row.appendChild(document.createTextNode(' '+pretty(v))); list.appendChild(row);
    });
  }
  render(''); search.oninput=function(){ render(search.value); };
  var actions=document.createElement('div'); actions.className='bcr-set-actions';
  var bAll=document.createElement('button'); bAll.type='button'; bAll.textContent='Select all'; bAll.onclick=function(){ all.forEach(function(v){self.selected.add(v);}); render(search.value); self.params.filterChangedCallback(); };
  var bClr=document.createElement('button'); bClr.type='button'; bClr.textContent='Clear'; bClr.onclick=function(){ self.selected.clear(); render(search.value); self.params.filterChangedCallback(); };
  actions.appendChild(bAll); actions.appendChild(bClr); this.gui.appendChild(actions);
};
BcrSetFilter.prototype.getGui=function(){ return this.gui; };
BcrSetFilter.prototype.isFilterActive=function(){ return this.selected.size>0; };
BcrSetFilter.prototype.doesFilterPass=function(p){ if(!this.selected.size) return true; if(!p.data) return true; return this.selected.has(this._cell(p.data)); };
BcrSetFilter.prototype.getModel=function(){ return this.selected.size?{values:Array.from(this.selected)}:null; };
BcrSetFilter.prototype.setModel=function(m){ this.selected=new Set(m&&m.values?m.values:[]); };
BcrSetFilter.prototype.destroy=function(){};

