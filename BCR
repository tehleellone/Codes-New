    y=pdfHead(pdf,'Key Metrics',y,m,12);
    y=pdfTable(pdf,['Metric','Value','Detail'],[
      ['Total Contacts',s.total,'Current filter'],
      ['Emarati',s.emarati,pct(s.emarati,s.total)],
      ['Non Emarati',s.nonEmarati,pct(s.nonEmarati,s.total)],
      ['TDRA Mentioned',s.tdra,pct(s.tdra,s.total)],
      ['Manager Callback',s.manager,pct(s.manager,s.total)],
      ['Duplicate Contacts',s.dup,'Same MSISDN < 7 days'],
