function buildAgentStats(list){
  var map={};
  list.forEach(function(r){
    var n=r.Agent_Name||'—';
    if(!map[n]) map[n]={name:n,total:0,emarati:0,nonEmarati:0,tdra:0,manager:0,dup:0,cats:{}};
    var a=map[n]; a.total++;
    if(r.Customer_Type==='Emarati') a.emarati++;
    if(r.Customer_Type==='Non_Emarati') a.nonEmarati++;
    if(r.TDRA_Mentioned==='Yes') a.tdra++;
    if(r.Manager_Callback==='Yes') a.manager++;
    if(r.Duplicate_Flag==='Yes') a.dup++;
    if(r.Complaint_Summary) a.cats[r.Complaint_Summary]=(a.cats[r.Complaint_Summary]||0)+1;
  });
  return Object.keys(map).map(function(n){
    var a=map[n]; a.topCat=Object.keys(a.cats).sort(function(x,y){return a.cats[y]-a.cats[x];})[0]||'—'; return a;
  });
}
