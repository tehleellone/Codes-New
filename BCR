function loadPdfLib(){
  return new Promise(function(res,rej){
    if(window.jspdf){ res(); return; }
    var s=document.createElement('script'); s.src='https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js';
    s.onload=function(){res();}; s.onerror=function(){rej(new Error('jsPDF load failed'));}; document.head.appendChild(s);
  });
}
function pdfSpace(pdf,y,need,m){ var h=pdf.internal.pageSize.getHeight(); if(y+need>h-m){ pdf.addPage(); return m; } return y; }
function pdfHead(pdf,txt,y,m,sz){ y=pdfSpace(pdf,y,sz*0.6+6,m); pdf.setFont('helvetica','bold'); pdf.setFontSize(sz); pdf.setTextColor(30,30,40); pdf.text(txt,m,y); return y+sz*0.45+4; }
function pdfLine(pdf,txt,y,m,w,sz){ pdf.setFont('helvetica','normal'); pdf.setFontSize(sz||10); pdf.setTextColor(70,70,80); pdf.splitTextToSize(String(txt),w).forEach(function(l){ y=pdfSpace(pdf,y,5,m); pdf.text(l,m,y); y+=4.5; }); return y+2; }
function pdfTable(pdf,headers,rows,y,m,w){
  var cw=w/headers.length; y=pdfSpace(pdf,y,8,m);
  pdf.setFillColor(37,99,235); pdf.rect(m,y-4,w,6,'F'); pdf.setFont('helvetica','bold'); pdf.setFontSize(8); pdf.setTextColor(255,255,255);
  headers.forEach(function(h,i){ pdf.text(String(h),m+i*cw+1,y); }); y+=6;
  pdf.setFont('helvetica','normal'); pdf.setTextColor(50,50,60);
  rows.forEach(function(row,ri){ y=pdfSpace(pdf,y,5,m); if(ri%2===0){ pdf.setFillColor(244,246,252); pdf.rect(m,y-3.5,w,5,'F'); } row.forEach(function(c,i){ pdf.text(String(c==null?'—':c).substring(0,26),m+i*cw+1,y); }); y+=5; });
  return y+4;
}
function pdfChart(pdf,key,title,y,m,w){
  var ch=BCR.charts[key]; if(!ch||!ch.canvas) return y;
  try{ var img=ch.canvas.toDataURL('image/png',1.0); var h=48; y=pdfHead(pdf,title,y,m,11); y=pdfSpace(pdf,y,h+4,m); pdf.addImage(img,'PNG',m,y,w,h); return y+h+6; }catch(e){ return y; }
}
function exportPDF(){
  var btn=$('exportPdfBtn'); if(btn){ btn.disabled=true; btn.textContent='Generating PDF...'; }
