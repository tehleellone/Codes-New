/* ── FORM (new entry → review → confirm) ─────────────────── */
function getFormDefaults(){
  var o={Contact_Date:todayStr()};
  FORM_FIELDS.forEach(function(f){ o[f.key]= f.type==='yn'?'No':''; });
  o.Contact_Date=todayStr();
  return o;
}
function renderForm(){
  var c=$('mainContent');
  var sections={};
  FORM_FIELDS.forEach(function(f){ (sections[f.section]=sections[f.section]||[]).push(f); });
  var html='<div class="dashboard-section agent-form-wrap"><div class="form-card">'
    +'<div class="table-header"><div class="table-title">New Entry</div><button type="button" class="script-toggle-btn" id="formScriptBtn">Show_Script</button></div>'
    +'<div id="dupBanner" class="warn-banner" style="display:none"></div>';
  Object.keys(sections).forEach(function(sec){
    html+='<div class="form-section-title">'+pretty(sec)+'</div><div class="form-grid">';
    sections[sec].forEach(function(f){
      html+='<div class="form-group"><label class="form-label">'+f.key+(f.req?' <span class="req">*</span>':'')+'</label>';
      if(f.type==='select'){
        html+='<select class="form-select" id="fld_'+f.key+'"><option value="">— Select —</option>'+(CHOICES[f.key]||[]).map(function(o){return '<option value="'+esc(o)+'">'+esc(pretty(o))+'</option>';}).join('')+'</select>';
      } else if(f.type==='yn'){
        html+='<select class="form-select" id="fld_'+f.key+'"><option value="No">No</option><option value="Yes">Yes</option></select>';
      } else if(f.type==='textarea'){
        html+='<textarea class="form-textarea" id="fld_'+f.key+'" placeholder="Required if Complaint_Summary = Other"></textarea>';
      } else {
        html+='<input class="form-input" type="'+(f.type==='date'?'date':'text')+'" id="fld_'+f.key+'">';
      }
      html+='</div>';
    });
    html+='</div>';
  });
  html+='<div class="form-actions"><button type="button" class="btn-secondary" id="formClearBtn">Clear</button><button type="button" class="btn-primary" id="formReviewBtn">Review_And_Confirm</button></div></div></div>';
  c.innerHTML=html;
  populateForm(Object.keys(BCR.pending).length?BCR.pending:getFormDefaults());
  $('formScriptBtn').onclick=openScript;
  $('formClearBtn').onclick=function(){ BCR.pending={}; populateForm(getFormDefaults()); };
  $('formReviewBtn').onclick=function(){
    var data=collectForm();
    if(!validateForm(data)) return;
    BCR.pending=data; BCR.formMode='review'; renderMain();
  };
  var ms=$('fld_MSISDN'); if(ms) ms.addEventListener('blur',function(){ updateDupBanner(ms.value.trim()); });
}
function collectForm(){
  var d={}; FORM_FIELDS.forEach(function(f){ var el=$('fld_'+f.key); if(el) d[f.key]=el.value.trim(); }); return d;
}
function validateForm(d){
  var ok=true, firstBad=null;
  FORM_FIELDS.forEach(function(f){ var el=$('fld_'+f.key); if(el) el.classList.remove('invalid'); });
  for(var i=0;i<FORM_FIELDS.length;i++){
    var f=FORM_FIELDS[i]; if(!f.req) continue;
    if(!d[f.key]){ var el=$('fld_'+f.key); if(el) el.classList.add('invalid'); if(!firstBad) firstBad=el; ok=false; }
  }
  if(d.Complaint_Summary==='Other' && !d.Complaint_Details){ var e2=$('fld_Complaint_Details'); if(e2) e2.classList.add('invalid'); if(!firstBad) firstBad=e2; ok=false; toast('Complaint_Details required when Complaint_Summary = Other','error'); }
  if(!ok){ if(firstBad) firstBad.focus(); toast('Please fill all required fields','error'); }
  return ok;
}
function populateForm(d){
  FORM_FIELDS.forEach(function(f){ var el=$('fld_'+f.key); if(!el) return; el.value = d[f.key]!=null ? d[f.key] : (f.type==='yn'?'No':''); });
  updateDupBanner(d.MSISDN);
}
function updateDupBanner(msisdn){
  var box=$('dupBanner'); if(!box) return;
  BCR.dupWarn=checkDuplicate(msisdn);
  if(BCR.dupWarn){ box.style.display='block'; box.innerHTML='⚠️ Duplicate: this MSISDN was contacted within 7 days. Previous_Entry_ID <b>'+esc(BCR.dupWarn.Reference_ID)+'</b> ('+esc(BCR.dupWarn.Contact_Date)+'). Duplicate_Flag will be set to Yes.'; }
  else { box.style.display='none'; box.innerHTML=''; }
}
function renderReview(){
  var c=$('mainContent'); var d=BCR.pending;
  var html='<div class="dashboard-section agent-form-wrap"><div class="form-card">'
    +'<div class="review-banner">Review all details, then Confirm. Click Edit to make changes.</div>'
    +'<div class="table-header"><div class="table-title">Review Entry</div><button type="button" class="script-toggle-btn" id="reviewScriptBtn">Show_Script</button></div>';
  if(BCR.dupWarn) html+='<div class="warn-banner">⚠️ Duplicate_Flag = Yes · Previous_Entry_ID '+esc(BCR.dupWarn.Reference_ID)+'</div>';
  html+='<div class="review-grid">';
  FORM_FIELDS.forEach(function(f){ html+='<div class="review-item"><div class="review-key">'+f.key+'</div><div class="review-val">'+esc(pretty(d[f.key])||'—')+'</div></div>'; });
  html+='</div><div class="form-actions"><button type="button" class="btn-secondary" id="reviewEditBtn">Edit</button><button type="button" class="btn-primary" id="reviewConfirmBtn">Confirm_Submit</button></div></div></div>';
  c.innerHTML=html;
  $('reviewScriptBtn').onclick=openScript;
  $('reviewEditBtn').onclick=function(){ BCR.formMode='entry'; renderMain(); };
  $('reviewConfirmBtn').onclick=submitRecord;
}
function submitRecord(){
  var d=Object.assign({},BCR.pending);
  var dup=checkDuplicate(d.MSISDN);
  var rec=makeRecord(Object.assign(d,{
    Reference_ID:nextRefId(), Serial_Number:BCR.all.length+1, Entry_Month:monthStr(d.Contact_Date),
    Contact_Time:new Date().toISOString(), Agent_Name:USER.name, Agent_Email:USER.email,
    Duplicate_Flag:dup?'Yes':'No', Previous_Entry_ID:dup?dup.Reference_ID:''
  }));
  function done(){
    BCR.pending={}; BCR.formMode='entry'; BCR.dupWarn=null;
    if(isAdmin()){ BCR.view='dashboard'; renderMain(); }
    else { renderMain(); }
  }
  if(USE_DUMMY){
    BCR.all.unshift(rec); saveRecords();
    toast('Entry saved · '+(isAdmin()?rec.Reference_ID:'reference logged'),'success');
    done(); return;
  }
  showLoading('Saving to SharePoint...');
  saveRecordToSharePoint(rec,function(err){
    hideLoading();
    if(err) return;
    BCR.all.unshift(rec);
    toast('Entry saved to BCR_Records','success');
    done();
  });
}

/* ── script panel (accordion) ────────────────────────────── */
function openScript(){
  var inner=$('scriptPanelInner');
  var html='<div class="table-header"><div class="table-title">📋 Agent Script</div><button type="button" class="btn-secondary" id="closeScriptBtn">Close</button></div>';
  SCRIPT_DATA.forEach(function(s,i){
    html+='<div class="script-acc-item" data-i="'+i+'"><div class="script-acc-head"><span>'+esc(s.q)+'</span><span class="chev">▼</span></div><div class="script-acc-body"><div style="font-size:.7rem;color:var(--t3);font-weight:700;text-transform:uppercase;margin-bottom:.4rem">Script_Topic: '+esc(s.id)+'</div>'+esc(s.a)+'</div></div>';
  });
  inner.innerHTML=html;
  $('scriptPanel').classList.add('open');
  $('closeScriptBtn').onclick=closeScript;
  inner.querySelectorAll('.script-acc-head').forEach(function(h){
    h.onclick=function(){ var item=h.parentElement; var open=item.classList.contains('open'); inner.querySelectorAll('.script-acc-item').forEach(function(x){x.classList.remove('open');}); if(!open) item.classList.add('open'); };
  });
}
function closeScript(){ $('scriptPanel').classList.remove('open'); }
$('scriptPanel').onclick=function(e){ if(e.target.id==='scriptPanel') closeScript(); };

/* ── nav + main render ───────────────────────────────────── */
function renderNav(){
  var nav=$('navItems'); nav.innerHTML='';
  if(!isAdmin()) return;
  nav.innerHTML='<div class="nav-section-label">BCR</div>';
  var items=[
    {view:'dashboard',label:'Dashboard',icon:'layout-dashboard'},
    {view:'form',label:'New Entry',icon:'file-plus'}
  ];
  items.forEach(function(it){
    var d=document.createElement('div');
    d.className='nav-item'+(BCR.view===it.view?' active':'');
    d.innerHTML='<span class="nav-icon">'+bcrIcon(it.icon,17)+'</span><span class="nav-label">'+it.label+'</span>';
    d.onclick=function(){ BCR.view=it.view; BCR.formMode='entry'; renderMain(); };
    nav.appendChild(d);
  });
  bcrIcons();
}
function renderMain(){
  renderNav();
  $('headerUser').textContent=USER.name+' · '+USER.role;
  $('headerDate').textContent=new Date().toLocaleDateString('en-GB',{weekday:'short',day:'numeric',month:'short',year:'numeric'});
  var showScript = (!isAdmin()) || BCR.view==='form';
  $('headerScriptBtn').style.display = showScript ? 'inline-flex' : 'none';
  $('headerScriptBtn').onclick=openScript;
  var shell=$('portalShell');
  if(!isAdmin()){
    shell.classList.add('agent-mode');
    if(BCR.formMode==='review') renderReview(); else renderForm();
    return;
  }
  shell.classList.remove('agent-mode');
  if(BCR.view==='form'){ if(BCR.formMode==='review') renderReview(); else renderForm(); }
  else renderDashboard();
}

/* ── landing + launch ────────────────────────────────────── */
var LANDING_FEATURES = {
  Admin:[
    {t:'Admin Dashboard',d:'KPIs, charts, AG Grid, PDF & Excel export',ic:'<rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>'},
    {t:'Analytics & Insights',d:'Trends, agent activity, complaint breakdown',ic:'<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/>'},
    {t:'Full Records',d:'Filter, drill down, view history, internal notes',ic:'<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>'}
  ],
  Agent:[
    {t:'Quick Entry Form',d:'Log every customer contact in seconds',ic:'<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>'},
    {t:'Guided Script',d:'On-screen responses for every customer question',ic:'<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>'},
    {t:'Review & Confirm',d:'Check details before you submit',ic:'<polyline points="20 6 9 17 4 12"/>'}
  ]
};
function setupLanding(user){
  USER.name=user.Title; USER.email=user.User_Email; USER.role=user.Role;
  $('lAvatar').textContent=initials(USER.name);
  $('lName').textContent=USER.name; $('lEmail').textContent=USER.email; $('lRole').textContent=USER.role;
  var feats=LANDING_FEATURES[USER.role]||LANDING_FEATURES.Agent;
  $('landingFeatures').innerHTML=feats.map(function(f){
    return '<div class="landing-feature"><div class="landing-feature-icon"><svg viewBox="0 0 24 24">'+f.ic+'</svg></div><div><div class="landing-feature-title">'+f.t+'</div><div class="landing-feature-desc">'+f.d+'</div></div></div>';
  }).join('');
  $('landingTagline').textContent = isAdmin()
    ? 'Monitor and analyse every barred-account customer contact.'
    : 'Log every customer reach-out quickly, with the guided script.';
  var btn=$('launchBtn'); btn.disabled=false;
  $('launchBtnText').textContent = isAdmin()?'Go to Dashboard':'Go to Form';
  btn.onclick=function(){ showLoading('Launching BCR...'); setTimeout(launchPortal,400); };
  $('accessNote').innerHTML=bcrIcon('check-circle',14)+'<span style="color:var(--green);font-weight:600;margin-left:6px">Access granted — '+esc(USER.role)+'</span>';
  bcrIcons();
}
function launchPortal(){
  $('landingPage').style.cssText='display:none!important';
  $('portalShell').style.display='flex';
  $('portalShell').style.flexDirection='column';
  BCR.view=isAdmin()?'dashboard':'form'; BCR.formMode='entry'; BCR.pending={};
  if(USE_DUMMY){ hideLoading(); renderMain(); return; }
  showLoading('Loading BCR_Records...');
  loadRecords(function(){ hideLoading(); renderMain(); });
}

/* ── theme ───────────────────────────────────────────────── */
function applyTheme(){
  var scheme=localStorage.getItem('bcr_scheme')||'blue';
  var dark=localStorage.getItem('bcr_dark')==='true';
  var theme = dark ? (scheme==='magenta'?'magenta-dark':'dark') : scheme;
  document.body.setAttribute('data-theme',theme);
  var sel=$('colorSchemeSelector'); if(sel) sel.value=scheme;
  if(BCR.chartsVisible) renderCharts();
}
function initTheme(){
  applyTheme();
  $('colorSchemeSelector').onchange=function(){ localStorage.setItem('bcr_scheme',this.value); applyTheme(); };
  $('themeToggle').onclick=function(){ localStorage.setItem('bcr_dark', localStorage.getItem('bcr_dark')==='true'?'false':'true'); applyTheme(); };
}

/* ── dev console ─────────────────────────────────────────── */
function initDev(){
  var sel=$('devUserSelect');
  sel.innerHTML=BCR_ACCESS.map(function(a){ return '<option value="'+esc(a.User_Email)+'">'+esc(a.Title)+' ('+esc(a.Role)+')</option>'; }).join('');
  $('devLoginBtn').onclick=function(){ var acc=findAccess(sel.value); if(acc){ setupLanding(acc); $('landingPage').style.display='flex'; bcrIcons(); } };
  document.addEventListener('keydown',function(e){ if(e.ctrlKey&&e.shiftKey&&(e.key==='D'||e.key==='d')){ var dc=$('devConsole'); dc.style.display=dc.style.display==='none'?'flex':'none'; } });
  setupLanding(BCR_ACCESS[0]);
  bcrIcons();
}

/* ── sidebar / exit ──────────────────────────────────────── */
function initShellControls(){
  $('sidebarToggle').onclick=function(){ $('sidebar').classList.toggle('collapsed'); };
  $('logoutBtn').onclick=function(){ $('portalShell').style.display='none'; $('landingPage').style.display='flex'; };
}

/* ── init ────────────────────────────────────────────────── */
function init(){
  initTheme();
  initShellControls();
  loadLucide(function(){
    if(USE_DUMMY){
      initDev();
      loadRecords(function(){
        $('landingPage').style.display='flex';
        hideLoading();
        bcrIcons();
      });
    } else {
      $('landingPage').style.display='flex';
      initAccess();
    }
  });
}
document.addEventListener('DOMContentLoaded', init);

window.BCR = BCR;
})();
</script>
